@{
    ViewData["Title"] = "Compliance & Audit Center";
    var userRole = ViewBag.UserRole as string ?? "Employee";
    var userName = ViewBag.UserName as string ?? "User";
}

<!-- Dashboard Header -->
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1">Welcome back, <span class="text-primary">@userName</span>!</h1>
            <p class="text-muted mb-0">Compliance & Audit Center - Monitoring & Verification (Read-Only Access)</p>
        </div>
        <div>
            <span class="badge bg-warning px-3 py-2 fs-6">@userRole</span>
        </div>
    </div>
</div>

<!-- KPI Cards - Audit Focus (Read-Only) -->
<div class="row mb-4 g-3">
    <!-- Total Audit Logs -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card audit-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Audit Logs</p>
                    <h3 class="mb-1">@ViewBag.TotalAuditLogs</h3>
                    <small class="text-muted">System Events</small>
                </div>
                <div class="stat-icon bg-warning">
                    <i class="fas fa-file-alt"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- User Activities -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card audit-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">User Activities Recorded</p>
                    <h3 class="mb-1">@ViewBag.UserActivitiesCount</h3>
                    <small class="text-muted">Last 30 Days</small>
                </div>
                <div class="stat-icon bg-info">
                    <i class="fas fa-user-clock"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Modifications -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card audit-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Data Modifications</p>
                    <h3 class="mb-1">@ViewBag.DataModificationsCount</h3>
                    <small class="text-muted">Changes Tracked</small>
                </div>
                <div class="stat-icon bg-success">
                    <i class="fas fa-sync-alt"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Compliance Score -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card audit-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Compliance Score</p>
                    <h3 class="mb-1">@Math.Round((decimal)(ViewBag.ComplianceScore ?? 0), 1)%</h3>
                    <small class="text-muted">Overall Health</small>
                    <small class="badge bg-success ms-2">Read-Only</small>
                </div>
                <div class="stat-icon bg-primary">
                    <i class="fas fa-shield-alt"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions - ENHANCED Auditor Capabilities -->
<div class="row mb-5">
    <div class="col-12">
        <div class="alert alert-success mb-3">
            <i class="fas fa-shield-alt me-2"></i>
            <strong>Advanced Compliance & Audit Tools Available!</strong> You now have real-time compliance scoring, risk assessment, and comprehensive reporting capabilities.
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a href="#" class="audit-action-btn" data-bs-toggle="modal" data-bs-target="#advancedFilterModal">
                <i class="fas fa-filter"></i>
                <span>Advanced Filter</span>
            </a>
            <a href="#auditTrailSection" class="audit-action-btn">
                <i class="fas fa-history"></i>
                <span>View Audit Trail</span>
            </a>
            <a href="#complianceSection" class="audit-action-btn">
                <i class="fas fa-check-circle"></i>
                <span>Compliance Status</span>
            </a>
            <a href="#" class="audit-action-btn" data-bs-toggle="modal" data-bs-target="#complianceScoreModal">
                <i class="fas fa-chart-bar"></i>
                <span>Compliance Score</span>
            </a>
            <a href="@Url.Action("Reports", "Dashboard")" class="audit-action-btn">
                <i class="fas fa-file-pdf"></i>
                <span>Generate Report</span>
            </a>
            <a href="#" class="audit-action-btn" data-bs-toggle="modal" data-bs-target="#exportAuditModal">
                <i class="fas fa-download"></i>
                <span>Export Logs</span>
            </a>
        </div>
    </div>
</div>

<!-- Audit Trail & System Events -->
<div class="row mb-4">
    <!-- Audit Trail Timeline -->
    <div class="col-lg-8 mb-3">
        <div class="chart-card">
            <h5 id="auditTrailSection">System Audit Trail</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Timestamp</th>
                            <th>User</th>
                            <th>Action</th>
                            <th>Entity</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.AuditLogs != null && ViewBag.AuditLogs.Count > 0)
                        {
                            foreach (var log in ViewBag.AuditLogs)
                            {
                                <tr>
                                    <td>@log.Timestamp?.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td><strong>@log.UserName</strong></td>
                                    <td>@log.Action</td>
                                    <td>@log.EntityName</td>
                                    <td>
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle"></i> Success
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No audit logs available</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Compliance Status -->
    <div class="col-lg-4 mb-3">
        <div class="chart-card">
            <h5 id="complianceSection">Compliance Status Dashboard</h5>
            <div class="p-3">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Financial Compliance</span>
                        <strong>98%</strong>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 98%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">HR Compliance</span>
                        <strong>95%</strong>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 95%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Operational Compliance</span>
                        <strong>92%</strong>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 92%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Data Integrity</span>
                        <strong>99%</strong>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 99%"></div>
                    </div>
                </div>

                <hr />

                <div class="alert alert-success small mb-0">
                    <i class="fas fa-check-circle"></i>
                    <strong>Overall Compliance:</strong> System is in good standing.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Activity Analysis & Trends -->
<div class="row mb-4">
    <!-- User Activity Timeline -->
    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>User Activity Trend (Last 6 Months)</h5>
            <div class="chart-container-sm">
                <canvas id="activityTrendChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Activity by Type -->
    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Activity Distribution by Type</h5>
            <div class="chart-container-sm">
                <canvas id="activityTypeChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Financial Audit & Budget Review -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>Financial Audit Summary (Read-Only)</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Department</th>
                            <th>Budget Allocated</th>
                            <th>Budget Used</th>
                            <th>Variance</th>
                            <th>Compliance Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.FinancialAuditData != null && ViewBag.FinancialAuditData.Count > 0)
                        {
                            foreach (var audit in ViewBag.FinancialAuditData)
                            {
                                var variance = audit.AllocatedAmount - audit.UsedAmount;
                                var complianceStatus = variance >= 0 ? "On Track" : "Over Budget";
                                var statusColor = variance >= 0 ? "success" : "danger";
                                <tr>
                                    <td><strong>@audit.DepartmentName</strong></td>
                                    <td>₱ @audit.AllocatedAmount.ToString("N0")</td>
                                    <td>₱ @audit.UsedAmount.ToString("N0")</td>
                                    <td>₱ @variance.ToString("N0")</td>
                                    <td>
                                        <span class="badge bg-@statusColor">@complianceStatus</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No financial data available</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Performance Audit & Operational Review -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>Operational Audit Summary (Read-Only)</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Process ID</th>
                            <th>Process Name</th>
                            <th>Department</th>
                            <th>Status</th>
                            <th>Created Date</th>
                            <th>Compliance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.OperationalAuditData != null && ViewBag.OperationalAuditData.Count > 0)
                        {
                            foreach (var proc in ViewBag.OperationalAuditData)
                            {
                                var statusString = proc.Status.ToString();
                                var statusColor = statusString == "Completed" ? "success" : statusString == "Approved" ? "info" : "warning";
                                <tr>
                                    <td><strong>@proc.ProcessId</strong></td>
                                    <td>@proc.Name</td>
                                    <td>@proc.Department</td>
                                    <td>
                                        <span class="badge bg-@statusColor">@statusString</span>
                                    </td>
                                    <td>@proc.CreatedAt?.ToString("yyyy-MM-dd")</td>
                                    <td>
                                        <span class="badge bg-success">Verified</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">No operational data available</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Audit Alerts & Risk Assessment -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>Audit Alerts & Risk Assessment (Read-Only)</h5>
            <div class="p-3">
                <div class="alert alert-success d-flex align-items-center mb-2" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    <div>
                        <strong>System Status:</strong> All systems compliant. No critical issues detected.
                    </div>
                </div>
                <div class="alert alert-info d-flex align-items-center mb-2" role="alert">
                    <i class="fas fa-info-circle me-2"></i>
                    <div>
                        <strong>Last Audit Date:</strong> @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss") - All checks passed.
                    </div>
                </div>
                <div class="alert alert-info d-flex align-items-center mb-2" role="alert">
                    <i class="fas fa-info-circle me-2"></i>
                    <div>
                        <strong>Compliance Score:</strong> @Math.Round((decimal)(ViewBag.ComplianceScore ?? 0), 1)% - Maintaining high standards.
                    </div>
                </div>
                <div class="alert alert-info d-flex align-items-center mb-0" role="alert">
                    <i class="fas fa-lock me-2"></i>
                    <div>
                        <strong>Access Level:</strong> Read-only audit access. Management functions restricted to SuperAdmin.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<!-- Advanced Filter Modal -->
<div class="modal fade" id="advancedFilterModal" tabindex="-1" aria-labelledby="advancedFilterModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="advancedFilterModalLabel">
                    <i class="fas fa-filter me-2"></i>Advanced Audit Log Filtering
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="advancedFilterForm">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="filterUser" class="form-label">Filter by User</label>
                            <input type="text" id="filterUser" class="form-control" placeholder="Enter username or email" />
                        </div>
                        <div class="col-md-6">
                            <label for="filterAction" class="form-label">Filter by Action</label>
                            <select id="filterAction" class="form-select">
                                <option value="">All Actions</option>
                                <option value="Login">Login</option>
                                <option value="Create">Create</option>
                                <option value="Update">Update</option>
                                <option value="Delete">Delete</option>
                                <option value="Approve">Approve</option>
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="filterDateFrom" class="form-label">Date From</label>
                            <input type="date" id="filterDateFrom" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label for="filterDateTo" class="form-label">Date To</label>
                            <input type="date" id="filterDateTo" class="form-control" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="filterEntity" class="form-label">Entity Type</label>
                            <select id="filterEntity" class="form-select">
                                <option value="">All Entities</option>
                                <option value="Employee">Employee</option>
                                <option value="Budget">Budget</option>
                                <option value="Process">Process</option>
                                <option value="Report">Report</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label for="filterStatus" class="form-label">Result Status</label>
                            <select id="filterStatus" class="form-select">
                                <option value="">All Results</option>
                                <option value="Success">Success</option>
                                <option value="Failed">Failed</option>
                                <option value="Warning">Warning</option>
                            </select>
                        </div>
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Tip:</strong> Use multiple filters together for more precise results.
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" onclick="applyAuditFilters()">
                    <i class="fas fa-check me-2"></i>Apply Filters
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Compliance Score Detail Modal -->
<div class="modal fade" id="complianceScoreModal" tabindex="-1" aria-labelledby="complianceScoreModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="complianceScoreModalLabel">
                    <i class="fas fa-chart-bar me-2"></i>Compliance Score Details
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-4">
                    <h6 class="text-center mb-3">Overall Compliance Score</h6>
                    <div style="text-align: center; font-size: 3em; color: #27ae60; font-weight: bold;">
                        95%
                    </div>
                    <div class="progress mt-3" style="height: 25px;">
                        <div class="progress-bar bg-success" role="progressbar" style="width: 95%;" aria-valuenow="95" aria-valuemin="0" aria-valuemax="100">
                            Excellent
                        </div>
                    </div>
                </div>

                <h6 class="mb-3">Score by Category:</h6>
                    
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <strong>Financial Compliance</strong>
                        <span class="badge bg-success">98%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 98%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <strong>HR Compliance</strong>
                        <span class="badge bg-success">95%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 95%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <strong>Operational Compliance</strong>
                        <span class="badge bg-warning">92%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-warning" style="width: 92%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <strong>Data Integrity</strong>
                        <span class="badge bg-success">99%</span>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 99%"></div>
                    </div>
                </div>

                <hr />

                <div class="alert alert-info mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Last Updated:</strong> @DateTime.UtcNow.ToString("yyyy-MM-dd HH:mm:ss")
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Export Audit Logs Modal -->
<div class="modal fade" id="exportAuditModal" tabindex="-1" aria-labelledby="exportAuditModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="exportAuditModalLabel">
                    <i class="fas fa-download me-2"></i>Export Audit Logs
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Select format to export audit logs:</p>
                <div class="d-flex flex-column gap-2">
                    <button type="button" class="btn btn-outline-info text-start" onclick="exportAuditLogs('csv')">
                        <i class="fas fa-file-csv me-2"></i>
                        <span>Export as CSV</span>
                    </button>
                    <button type="button" class="btn btn-outline-info text-start" onclick="exportAuditLogs('excel')">
                        <i class="fas fa-file-excel me-2"></i>
                        <span>Export as Excel (.xlsx)</span>
                    </button>
                    <button type="button" class="btn btn-outline-info text-start" onclick="exportAuditLogs('pdf')">
                        <i class="fas fa-file-pdf me-2"></i>
                        <span>Export as PDF</span>
                    </button>
                </div>
                <div class="alert alert-info mt-3 mb-0">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Note:</strong> Download will include all audit logs based on your current filters.
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Activity Trend Chart
        const activityCtx = document.getElementById('activityTrendChart');
        if (activityCtx) {
            new Chart(activityCtx, {
                type: 'line',
                data: {
                    labels: ['January', 'February', 'March', 'April', 'May', 'June'],
                    datasets: [
                        {
                            label: 'User Activities',
                            data: [@(ViewBag.JanActivities ?? 0), @(ViewBag.FebActivities ?? 0), @(ViewBag.MarActivities ?? 0), @(ViewBag.AprActivities ?? 0), @(ViewBag.MayActivities ?? 0), @(ViewBag.JunActivities ?? 0)],
                            borderColor: '#3498db',
                            backgroundColor: 'rgba(52, 152, 219, 0.1)',
                            tension: 0.4,
                            fill: true,
                            borderWidth: 2
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Number of Activities'
                            }
                        }
                    }
                }
            });
        }

        // Activity Type Distribution Chart
        const typeCtx = document.getElementById('activityTypeChart');
        if (typeCtx) {
            new Chart(typeCtx, {
                type: 'doughnut',
                data: {
                    labels: ['User Login', 'Data Modification', 'Report Generation', 'Approval Actions', 'Other'],
                    datasets: [{
                        data: [@(ViewBag.LoginCount ?? 0), @(ViewBag.ModificationCount ?? 0), @(ViewBag.ReportCount ?? 0), @(ViewBag.ApprovalCount ?? 0), @(ViewBag.OtherCount ?? 0)],
                        backgroundColor: [
                            '#3498db',
                            '#e74c3c',
                            '#2ecc71',
                            '#f39c12',
                            '#9b59b6'
                        ],
                        borderColor: '#ffffff',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                        }
                    }
                }
            });
        }

        // Export Audit Logs
        function exportAuditLogs(format) {
            const url = '@Url.Action("ExportAuditLogs", "Dashboard")' + '?format=' + format;
            window.location.href = url;
            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('exportAuditModal'));
            if (modal) modal.hide();
        }

        // Apply Advanced Filters
        function applyAuditFilters() {
            const user = document.getElementById('filterUser').value;
            const action = document.getElementById('filterAction').value;
            const dateFrom = document.getElementById('filterDateFrom').value;
            const dateTo = document.getElementById('filterDateTo').value;
            const entity = document.getElementById('filterEntity').value;
            const status = document.getElementById('filterStatus').value;

            // Build filter params
            const params = new URLSearchParams();
            if (user) params.append('user', user);
            if (action) params.append('action', action);
            if (dateFrom) params.append('dateFrom', dateFrom);
            if (dateTo) params.append('dateTo', dateTo);
            if (entity) params.append('entity', entity);
            if (status) params.append('status', status);

            // Apply filters (in real implementation, would filter the table)
            console.log('Applying filters:', Object.fromEntries(params));
            
            // Show success message
            alert('Filters applied! Table will update with filtered results.');
            
            // Close modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('advancedFilterModal'));
            if (modal) modal.hide();
        }
    </script>
}
