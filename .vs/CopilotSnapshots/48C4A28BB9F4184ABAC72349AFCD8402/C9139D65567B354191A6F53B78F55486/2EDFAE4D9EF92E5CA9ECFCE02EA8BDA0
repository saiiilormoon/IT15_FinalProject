@{
    ViewData["Title"] = "Financial Dashboard";
    var userRole = ViewBag.UserRole as string ?? "Employee";
    var userName = ViewBag.UserName as string ?? "User";
    var totalBudgetAllocated = ViewBag.TotalBudgetAllocated ?? 0m;
    var totalBudgetUsed = ViewBag.TotalBudgetUsed ?? 0m;
    var remainingBudget = (decimal)totalBudgetAllocated - (decimal)totalBudgetUsed;
    var budgetUtilizationRate = ViewBag.BudgetUtilizationRate ?? 0m;
}

<!-- Dashboard Header -->
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1">Welcome back, <span class="text-primary">@userName</span>!</h1>
            <p class="text-muted mb-0">Here's your organization's financial summary for today.</p>
        </div>
        <div>
            <span class="badge bg-primary px-3 py-2 fs-6">@userRole</span>
        </div>
    </div>
</div>

<!-- KPI Cards - Financial Focus -->
<div class="row mb-4 g-3">
    <!-- Total Budget Allocated -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Budget Allocated</p>
                    <h3 class="mb-1">
                        @if ((decimal)totalBudgetAllocated == 0)
                        {
                            <span>₱ 0.00</span>
                        }
                        else
                        {
                            <span>₱ @((decimal)totalBudgetAllocated).ToString("N0")</span>
                        }
                    </h3>
                    <small class="text-muted">FY 2024-2025</small>
                </div>
                <div class="stat-icon bg-primary">
                    <i class="fas fa-coins"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Budget Used -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Budget Used</p>
                    <h3 class="mb-1">
                        @if ((decimal)totalBudgetUsed == 0)
                        {
                            <span>₱ 0.00</span>
                        }
                        else
                        {
                            <span>₱ @((decimal)totalBudgetUsed).ToString("N0")</span>
                        }
                    </h3>
                    <small class="text-muted">Current Spending</small>
                </div>
                <div class="stat-icon bg-info">
                    <i class="fas fa-arrow-down"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Remaining Budget -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Remaining Budget</p>
                    <h3 class="mb-1">
                        @if (remainingBudget == 0)
                        {
                            <span>₱ 0.00</span>
                        }
                        else
                        {
                            <span>₱ @remainingBudget.ToString("N0")</span>
                        }
                    </h3>
                    <small class="text-muted">Available</small>
                </div>
                <div class="stat-icon bg-success">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Budget Utilization Rate -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Budget Utilization</p>
                    <h3 class="mb-1">@Math.Round((decimal)budgetUtilizationRate, 1)%</h3>
                    <div class="mt-2">
                        @{
                            var utilRate = (decimal)budgetUtilizationRate;
                            if (utilRate <= 70)
                            {
                                <span class="badge bg-success"><i class="fas fa-check-circle"></i> Healthy</span>
                            }
                            else if (utilRate <= 90)
                            {
                                <span class="badge bg-warning text-dark"><i class="fas fa-exclamation-triangle"></i> Caution</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="fas fa-times-circle"></i> Critical</span>
                            }
                        }
                    </div>
                </div>
                <div class="stat-icon bg-warning">
                    <i class="fas fa-percentage"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row mb-5">
    <div class="col-12">
        <div class="d-flex gap-2 flex-wrap">
            <a href="@Url.Action("Budget", "Dashboard")" class="financial-action-btn">
                <i class="fas fa-plus-circle"></i>
                <span>New Budget</span>
            </a>
            <a href="@Url.Action("Reports", "Dashboard")" class="financial-action-btn">
                <i class="fas fa-file-pdf"></i>
                <span>View Reports</span>
            </a>
            <a href="#" class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#exportModal">
                <i class="fas fa-download"></i>
                <span>Export Data</span>
            </a>
            <a href="#" class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#forecastModal">
                <i class="fas fa-chart-line"></i>
                <span>Budget Forecast</span>
            </a>
        </div>
    </div>
</div>

<!-- Department Budget Status & Monthly Trend -->
<div class="row mb-4">
    <!-- Department Budget Status -->
    <div class="col-lg-8 mb-3">
        <div class="chart-card">
            <h5>Department Budget Utilization</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Department</th>
                            <th>Allocated</th>
                            <th>Used</th>
                            <th>Remaining</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.DepartmentBudgets != null && ViewBag.DepartmentBudgets.Count > 0)
                        {
                            foreach (var dept in ViewBag.DepartmentBudgets)
                            {
                                var utilPercent = dept.AllocatedAmount > 0 ? (dept.UsedAmount / dept.AllocatedAmount * 100) : 0;
                                <tr>
                                    <td><strong>@dept.DepartmentName</strong></td>
                                    <td>₱ @dept.AllocatedAmount.ToString("N0")</td>
                                    <td>₱ @dept.UsedAmount.ToString("N0")</td>
                                    <td>₱ @dept.RemainingAmount.ToString("N0")</td>
                                    <td>
                                        @if (utilPercent <= 70)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle"></i> Healthy (@utilPercent.ToString("F0")%)
                                            </span>
                                        }
                                        else if (utilPercent <= 90)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-exclamation-triangle"></i> Caution (@utilPercent.ToString("F0")%)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times-circle"></i> Critical (@utilPercent.ToString("F0")%)
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No budget data available</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Budget Health Summary -->
    <div class="col-lg-4 mb-3">
        <div class="chart-card">
            <h5>Budget Health Overview</h5>
            <div class="p-3">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Within Budget</span>
                        <strong>70%</strong>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-success" style="width: 70%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">At Risk (70-90%)</span>
                        <strong>25%</strong>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-warning" style="width: 25%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Over Budget</span>
                        <strong>5%</strong>
                    </div>
                    <div class="progress">
                        <div class="progress-bar bg-danger" style="width: 5%"></div>
                    </div>
                </div>

                <hr />

                <div class="alert alert-info small mb-0">
                    <i class="fas fa-info-circle"></i>
                    <strong>Recommendation:</strong> Operations dept is at 80% utilization. Monitor closely for month-end.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Monthly Spending Trend Chart -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>Monthly Budget Trend (Last 6 Months)</h5>
            <div class="chart-container">
                <canvas id="monthlyTrendChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Department Comparison & Top Spending Depts -->
<div class="row mb-4">
    <!-- Department Comparison -->
    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Department Spending Comparison</h5>
            <div class="chart-container-sm">
                <canvas id="deptComparisonChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Top Spending Departments -->
    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Top Spending Departments</h5>
            <div class="p-3">
                <ul class="activity-list">
                    <li class="activity-item">
                        <div class="activity-icon bg-primary" style="background: linear-gradient(135deg, #1e3c72, #2a5298); color: white;">
                            <i class="fas fa-building"></i>
                        </div>
                                        <div class="activity-content flex-grow-1">
                                            <h6>Operations Department</h6>
                                            <small>₱ 80,00,000 allocated | 65% used</small>
                                        </div>
                        <div class="text-end">
                            <span class="badge bg-warning">80%</span>
                        </div>
                    </li>
                    <li class="activity-item">
                        <div class="activity-icon bg-info" style="background: linear-gradient(135deg, #3498db, #2980b9); color: white;">
                            <i class="fas fa-cogs"></i>
                        </div>
                                        <div class="activity-content flex-grow-1">
                                            <h6>IT Department</h6>
                                            <small>₱ 50,00,000 allocated | 50% used</small>
                                        </div>
                        <div class="text-end">
                            <span class="badge bg-success">65%</span>
                        </div>
                    </li>
                    <li class="activity-item">
                        <div class="activity-icon bg-success" style="background: linear-gradient(135deg, #1d976c, #27ae60); color: white;">
                            <i class="fas fa-chart-bar"></i>
                        </div>
                                        <div class="activity-content flex-grow-1">
                                            <h6>Finance Department</h6>
                                            <small>₱ 30,00,000 allocated | 42% used</small>
                                        </div>
                        <div class="text-end">
                            <span class="badge bg-danger">84%</span>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<!-- Alerts & Notifications -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>Financial Alerts & Notifications</h5>
            <div class="p-3">
                <div class="alert alert-warning d-flex align-items-center mb-2" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <div>
                        <strong>Operations Department</strong> - Budget utilization at 80%. Monitor spending for remaining days.
                    </div>
                </div>
                <div class="alert alert-info d-flex align-items-center mb-2" role="alert">
                    <i class="fas fa-info-circle me-2"></i>
                    <div>
                        <strong>Month-End Approaching</strong> - 5 days remaining in current budget period. Review pending expenses.
                    </div>
                </div>
                <div class="alert alert-success d-flex align-items-center mb-0" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    <div>
                        <strong>Good News!</strong> - 70% of departments are within healthy budget limits.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportModalLabel">Export Financial Data</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Select format to export financial reports:</p>
                <div class="btn-group-vertical w-100" role="group">
                    <button type="button" class="btn btn-outline-primary text-start">
                        <i class="fas fa-file-excel me-2"></i>
                        Export to Excel (.xlsx)
                    </button>
                    <button type="button" class="btn btn-outline-primary text-start">
                        <i class="fas fa-file-pdf me-2"></i>
                        Export to PDF
                    </button>
                    <button type="button" class="btn btn-outline-primary text-start">
                        <i class="fas fa-file-csv me-2"></i>
                        Export to CSV
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Forecast Modal -->
<div class="modal fade" id="forecastModal" tabindex="-1" aria-labelledby="forecastModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="forecastModalLabel">Budget Forecast</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Projected Budget Status:</p>
                <div class="alert alert-info">
                    <strong>Current Spending Rate:</strong> 15% per week
                </div>
                <div class="alert alert-warning">
                    <strong>Projected Year-End:</strong> 95% utilization (OVER BUDGET by 5%)
                </div>
                <div class="alert alert-success">
                    <strong>Recommendation:</strong> Implement cost controls in Q3 to avoid overage.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Monthly Trend Chart
        const monthlyTrendCtx = document.getElementById('monthlyTrendChart').getContext('2d');
        new Chart(monthlyTrendCtx, {
            type: 'line',
            data: {
                labels: ['January', 'February', 'March', 'April', 'May', 'June'],
                datasets: [
                    {
                        label: 'Budget Allocated',
                        data: [50, 50, 50, 50, 50, 50],
                        borderColor: '#1e3c72',
                        backgroundColor: 'rgba(30, 60, 114, 0.1)',
                        tension: 0.4,
                        fill: true,
                        borderWidth: 2
                    },
                    {
                        label: 'Budget Used',
                        data: [20, 30, 35, 32, 38, 42],
                        borderColor: '#e74c3c',
                        backgroundColor: 'rgba(231, 76, 60, 0.1)',
                        tension: 0.4,
                        fill: true,
                        borderWidth: 2
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Amount (Lakhs)'
                        }
                    }
                }
            }
        });

        // Department Comparison Chart
        const deptComparisonCtx = document.getElementById('deptComparisonChart').getContext('2d');
        new Chart(deptComparisonCtx, {
            type: 'doughnut',
            data: {
                labels: ['Operations', 'IT', 'Finance', 'HR', 'Marketing'],
                datasets: [{
                    data: [80, 50, 30, 20, 25],
                    backgroundColor: [
                        '#1e3c72',
                        '#2a5298',
                        '#3498db',
                        '#2980b9',
                        '#27ae60'
                    ],
                    borderColor: '#ffffff',
                    borderWidth: 2
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                    }
                }
            }
        });
    </script>
}
