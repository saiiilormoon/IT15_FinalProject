@{
    ViewData["Title"] = "HR Management Center";
    var userRole = ViewBag.UserRole as string ?? "Employee";
    var userName = ViewBag.UserName as string ?? "User";
}

<style>
    .hr-kpi-card {
        border-left: 4px solid #0066cc;
        background: linear-gradient(135deg, #f8f9ff 0%, #ffffff 100%);
    }
    .hr-action-btn {
        background: linear-gradient(135deg, #0066cc 0%, #0052a3 100%);
        color: white;
        border: none;
        padding: 10px 16px;
        border-radius: 6px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    .hr-action-btn:hover {
        background: linear-gradient(135deg, #0052a3 0%, #003d7a 100%);
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(0, 102, 204, 0.3);
    }
</style>

<!-- Dashboard Header with Back Button -->
<div class="page-header mb-4 d-flex justify-content-between align-items-center">
    <div>
        <h1 class="h2 mb-1">Welcome back, <span class="text-primary">@userName</span>!</h1>
        <p class="text-muted mb-0">Human Resources Management Center - Employee & Talent Management</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <span class="badge bg-primary px-3 py-2 fs-6">@userRole</span>
        <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-primary btn-sm">
            <i class="fas fa-arrow-left me-2"></i>Go Back to Dashboard
        </a>
    </div>
</div>

<!-- KPI Cards - HR Focus (Read-Only Metrics) -->
<div class="row mb-4 g-3">
    <!-- Total Employees -->
    <div class="col-lg-4 col-md-6">
        <div class="stat-card hr-kpi-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Employees</p>
                    <h3 class="mb-1">@ViewBag.TotalEmployees</h3>
                    <small class="text-muted">Active Staff</small>
                </div>
                <div class="stat-icon bg-primary">
                    <i class="fas fa-users text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Departments -->
    <div class="col-lg-4 col-md-6">
        <div class="stat-card hr-kpi-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Departments</p>
                    <h3 class="mb-1">@ViewBag.TotalDepartments</h3>
                    <small class="text-muted">Organizational Units</small>
                </div>
                <div class="stat-icon bg-primary">
                    <i class="fas fa-building text-white"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Avg Performance Rating -->
    <div class="col-lg-4 col-md-6">
        <div class="stat-card hr-kpi-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Avg Performance Rating</p>
                    <h3 class="mb-1">@Math.Round((decimal)(ViewBag.AvgPerformanceRating ?? 0), 1) / 5.0</h3>
                    <small class="text-muted">Overall Score</small>
                </div>
                <div class="stat-icon bg-primary">
                    <i class="fas fa-star text-white"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions - ENHANCED: Now HR Can Create/Manage Everything -->
<div class="row mb-5">
    <div class="col-12">
        <div class="alert alert-info alert-dismissible fade show mb-3" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            <strong>Full HR Capabilities Unlocked!</strong> You can now create employees, departments, and record performance evaluations. All changes are tracked and auditable.
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a href="#" class="hr-action-btn" data-bs-toggle="modal" data-bs-target="#createEmployeeModal">
                <i class="fas fa-user-plus"></i>
                <span>Add Employee</span>
            </a>
            <a href="#" class="hr-action-btn" data-bs-toggle="modal" data-bs-target="#createDepartmentModal">
                <i class="fas fa-building"></i>
                <span>Create Department</span>
            </a>
            <a href="#" class="hr-action-btn" data-bs-toggle="modal" data-bs-target="#recordPerformanceModal">
                <i class="fas fa-star"></i>
                <span>Record Performance</span>
            </a>
            <a href="@Url.Action("Reports", "Dashboard")" class="hr-action-btn">
                <i class="fas fa-file-pdf"></i>
                <span>Generate Reports</span>
            </a>
            <a href="@Url.Action("Employees", "Dashboard")" class="hr-action-btn">
                <i class="fas fa-users"></i>
                <span>View Employees</span>
            </a>
            <a href="@Url.Action("Departments", "Dashboard")" class="hr-action-btn">
                <i class="fas fa-sitemap"></i>
                <span>Manage Departments</span>
            </a>
        </div>
    </div>
</div>

<!-- Employee Management & Performance -->
<div class="row mb-4">
    <!-- Employee Directory -->
    <div class="col-lg-8 mb-3">
        <div class="chart-card">
            <h5>Employee Directory</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Employee Name</th>
                            <th>Department</th>
                            <th>Position</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.EmployeesList != null && ViewBag.EmployeesList.Count > 0)
                        {
                            foreach (var emp in ViewBag.EmployeesList)
                            {
                                <tr>
                                    <td><strong>@emp.EmployeeName</strong></td>
                                    <td>@emp.DepartmentName</td>
                                    <td>@emp.Position</td>
                                    <td>
                                        <span class="badge bg-success">
                                            <i class="fas fa-check-circle"></i> Active
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">No employees assigned yet</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Department Summary -->
    <div class="col-lg-4 mb-3">
        <div class="chart-card">
            <h5>Department Summary</h5>
            <div class="p-3">
                @if (ViewBag.DepartmentSummary != null)
                {
                    int index = 0;
                    foreach (var dept in ViewBag.DepartmentSummary)
                    {
                        index++;
                        var deptPercent = ((int)dept.EmployeeCount * 100) / (int)ViewBag.TotalEmployees;
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted">@dept.DepartmentName</span>
                                <strong>@dept.EmployeeCount</strong>
                            </div>
                            <div class="progress">
                                <div class="progress-bar" style="width: @deptPercent%"></div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center text-muted">No department data available</div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Performance Monitoring & HR Metrics -->
<div class="row mb-4">
    <!-- Top Performers -->
    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Top Performers</h5>
            <div class="p-3">
                <ul class="activity-list">
                    @if (ViewBag.TopPerformers != null && ViewBag.TopPerformers.Count > 0)
                    {
                        foreach (var perf in ViewBag.TopPerformers)
                        {
                            <li class="activity-item">
                                <div class="activity-icon bg-success" style="background: linear-gradient(135deg, #27ae60, #16a085); color: white;">
                                    <i class="fas fa-crown"></i>
                                </div>
                                <div class="activity-content flex-grow-1">
                                    <h6>@perf.EmployeeName</h6>
                                    <small>Rating: @perf.PerformanceRating / 5.0</small>
                                </div>
                                <div class="text-end">
                                    <span class="badge bg-success">@perf.PerformanceRating.ToString("F1")</span>
                                </div>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="text-center text-muted py-3">No performance data available</li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <!-- Performance Distribution -->
    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Performance Distribution</h5>
            <div class="chart-container-sm">
                <canvas id="performanceDistributionChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Performance Records & Trends -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>Performance Records (Last 10)</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Evaluation Period</th>
                            <th>Rating</th>
                            <th>Tasks Completed</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.PerformanceRecords != null && ViewBag.PerformanceRecords.Count > 0)
                        {
                            foreach (var record in ViewBag.PerformanceRecords)
                            {
                                var ratingColor = record.PerformanceRating >= 4 ? "success" : record.PerformanceRating >= 3 ? "warning" : "danger";
                                <tr>
                                    <td><strong>@record.EmployeeName</strong></td>
                                    <td>@record.EvaluationPeriod</td>
                                    <td>
                                        <span class="badge bg-@ratingColor">@record.PerformanceRating / 5.0</span>
                                    </td>
                                    <td>@record.TasksCompleted</td>
                                    <td>
                                        <span class="badge bg-info">Recorded</span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No performance records yet</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- HR Metrics & Insights -->
<div class="row mb-4">
    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Employee Headcount Trend</h5>
            <div class="chart-container-sm">
                <canvas id="headcountTrendChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Department Performance</h5>
            <div class="chart-container-sm">
                <canvas id="deptPerformanceChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Alerts & Recommendations -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>HR Alerts & Recommendations</h5>
            <div class="p-3">
                <div class="alert alert-info d-flex align-items-center mb-2" role="alert">
                    <i class="fas fa-info-circle me-2"></i>
                    <div>
                        <strong>Action Required:</strong> Review pending performance evaluations and record any outstanding reviews.
                    </div>
                </div>
                <div class="alert alert-success d-flex align-items-center mb-2" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    <div>
                        <strong>Performance Insight:</strong> Average team performance is @Math.Round((decimal)(ViewBag.AvgPerformanceRating ?? 0), 1) / 5.0 - Keep up the good work!
                    </div>
                </div>
                <div class="alert alert-warning d-flex align-items-center mb-0" role="alert">
                    <i class="fas fa-exclamation-triangle me-2"></i>
                    <div>
                        <strong>Organizational Insight:</strong> You have @ViewBag.TotalEmployees employees across @ViewBag.TotalDepartments departments.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<!-- Create Employee Modal -->
<div class="modal fade" id="createEmployeeModal" tabindex="-1" aria-labelledby="createEmployeeModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title" id="createEmployeeModalLabel">
                    <i class="fas fa-user-plus me-2"></i>Add New Employee
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="AssignEmployee" asp-controller="Dashboard">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="employeeUser" class="form-label">Select User Account</label>
                        <select id="employeeUser" name="userId" class="form-select form-select-lg" required>
                            <option value="">-- Select User --</option>
                            <option value="user1">John Smith</option>
                            <option value="user2">Sarah Johnson</option>
                            <option value="user3">Michael Brown</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="employeeDept" class="form-label">Department</label>
                        <select id="employeeDept" name="departmentId" class="form-select form-select-lg" required>
                            <option value="">-- Select Department --</option>
                            <option value="1">Operations</option>
                            <option value="2">IT</option>
                            <option value="3">Finance</option>
                            <option value="4">HR</option>
                            <option value="5">Marketing</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="employeePosition" class="form-label">Position/Job Title</label>
                        <input type="text" id="employeePosition" name="position" class="form-control form-control-lg" 
                               placeholder="e.g., Senior Manager" required />
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Tip:</strong> Make sure the user account is already created in the system before assigning to a department.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-info">
                        <i class="fas fa-check me-2"></i>Add Employee
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Create Department Modal -->
<div class="modal fade" id="createDepartmentModal" tabindex="-1" aria-labelledby="createDepartmentModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title" id="createDepartmentModalLabel">
                    <i class="fas fa-building me-2"></i>Create New Department
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="CreateDepartment" asp-controller="Dashboard">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="deptName" class="form-label">Department Name</label>
                        <input type="text" id="deptName" name="departmentName" class="form-control form-control-lg" 
                               placeholder="e.g., Operations Management" required />
                    </div>

                    <div class="mb-3">
                        <label for="deptStatus" class="form-label">Status</label>
                        <select id="deptStatus" name="status" class="form-select form-select-lg" required>
                            <option value="Active" selected>Active</option>
                            <option value="Inactive">Inactive</option>
                            <option value="Pending">Pending</option>
                        </select>
                    </div>

                    <div class="alert alert-success">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> New departments are created in Active status by default and can be managed from the Departments page.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-check me-2"></i>Create Department
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Record Performance Modal -->
<div class="modal fade" id="recordPerformanceModal" tabindex="-1" aria-labelledby="recordPerformanceModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="recordPerformanceModalLabel">
                    <i class="fas fa-star me-2"></i>Record Performance Evaluation
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="RecordPerformance" asp-controller="Dashboard">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="perfEmployee" class="form-label">Employee</label>
                        <select id="perfEmployee" name="employeeId" class="form-select form-select-lg" required>
                            <option value="">-- Select Employee --</option>
                            <option value="emp1">John Smith</option>
                            <option value="emp2">Sarah Johnson</option>
                            <option value="emp3">Michael Brown</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="evalPeriod" class="form-label">Evaluation Period</label>
                        <input type="text" id="evalPeriod" name="evaluationPeriod" class="form-control form-control-lg" 
                               placeholder="e.g., Q1 2025" value="Q1 2025" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="tasksCompleted" class="form-label">Tasks Completed</label>
                            <input type="number" id="tasksCompleted" name="tasksCompleted" class="form-control form-control-lg" 
                                   min="0" value="0" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="tasksPending" class="form-label">Tasks Pending</label>
                            <input type="number" id="tasksPending" name="tasksPending" class="form-control form-control-lg" 
                                   min="0" value="0" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="perfRating" class="form-label">Performance Rating (1-5)</label>
                        <select id="perfRating" name="performanceRating" class="form-select form-select-lg" required>
                            <option value="">-- Select Rating --</option>
                            <option value="5">5 - Excellent</option>
                            <option value="4">4 - Good</option>
                            <option value="3">3 - Average</option>
                            <option value="2">2 - Below Average</option>
                            <option value="1">1 - Needs Improvement</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="remarks" class="form-label">Comments/Remarks</label>
                        <textarea id="remarks" name="remarks" class="form-control" rows="3" 
                                  placeholder="Add any comments or feedback..."></textarea>
                    </div>

                    <div class="alert alert-warning">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Tip:</strong> Comprehensive feedback helps employees improve and grow within the organization.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-check me-2"></i>Record Performance
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Performance Distribution Chart
        const perfCtx = document.getElementById('performanceDistributionChart');
        if (perfCtx) {
            new Chart(perfCtx, {
                type: 'doughnut',
                data: {
                    labels: ['Excellent (4.5-5.0)', 'Good (3.5-4.4)', 'Average (2.5-3.4)', 'Below Average (<2.5)'],
                    datasets: [{
                        data: [@(ViewBag.ExcellentCount ?? 0), @(ViewBag.GoodCount ?? 0), @(ViewBag.AverageCount ?? 0), @(ViewBag.BelowAverageCount ?? 0)],
                        backgroundColor: [
                            '#27ae60',
                            '#3498db',
                            '#f39c12',
                            '#e74c3c'
                        ],
                        borderColor: '#ffffff',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                        }
                    }
                }
            });
        }

        // Headcount Trend Chart
        const headcountCtx = document.getElementById('headcountTrendChart');
        if (headcountCtx) {
            new Chart(headcountCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                    datasets: [{
                        label: 'Total Employees',
                        data: [@(ViewBag.TotalEmployees ?? 0), @(ViewBag.TotalEmployees ?? 0), @(ViewBag.TotalEmployees ?? 0), @(ViewBag.TotalEmployees ?? 0), @(ViewBag.TotalEmployees ?? 0), @(ViewBag.TotalEmployees ?? 0)],
                        borderColor: '#3498db',
                        backgroundColor: 'rgba(52, 152, 219, 0.1)',
                        tension: 0.4,
                        fill: true,
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            title: {
                                display: true,
                                text: 'Number of Employees'
                            }
                        }
                    }
                }
            });
        }

        // Department Performance Chart
        const deptPerfCtx = document.getElementById('deptPerformanceChart');
        if (deptPerfCtx) {
            new Chart(deptPerfCtx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(ViewBag.DepartmentLabels ?? "[]"),
                    datasets: [{
                        label: 'Avg Performance Rating',
                        data: @Html.Raw(ViewBag.DepartmentPerformanceData ?? "[]"),
                        backgroundColor: '#3498db',
                        borderColor: '#2980b9',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 5,
                            title: {
                                display: true,
                                text: 'Rating'
                            }
                        }
                    }
                }
            });
        }
    </script>
}
