@{
    ViewData["Title"] = "Expense Tracking";
}

<!-- Dashboard Header -->
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1">Expense Tracking & Management</h1>
            <p class="text-muted mb-0">Log, track, and approve organizational expenses</p>
        </div>
        <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#logExpenseModal">
            <i class="fas fa-plus-circle me-2"></i>Log New Expense
        </button>
    </div>
</div>

<!-- Expense Summary Cards -->
<div class="row mb-5 g-3">
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Expenses</p>
                    <h3 class="mb-1">? @((ViewBag.TotalExpenses ?? 0m).ToString("N0"))</h3>
                    <small class="text-muted">This Month</small>
                </div>
                <div class="stat-icon bg-primary">
                    <i class="fas fa-receipt"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Pending Approval</p>
                    <h3 class="mb-1">@(ViewBag.PendingExpenses ?? 0)</h3>
                    <small class="text-muted">Awaiting Review</small>
                </div>
                <div class="stat-icon bg-warning">
                    <i class="fas fa-hourglass-half"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Approved Expenses</p>
                    <h3 class="mb-1">@(ViewBag.ApprovedExpenses ?? 0)</h3>
                    <small class="text-muted">Authorized</small>
                </div>
                <div class="stat-icon bg-success">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Rejected Expenses</p>
                    <h3 class="mb-1">@(ViewBag.RejectedExpenses ?? 0)</h3>
                    <small class="text-muted">Not Approved</small>
                </div>
                <div class="stat-icon bg-danger">
                    <i class="fas fa-times-circle"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filter & Search -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Department</label>
                        <select class="form-select">
                            <option>All Departments</option>
                            <option>IT</option>
                            <option>HR</option>
                            <option>Operations</option>
                            <option>Finance</option>
                            <option>Marketing</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Status</label>
                        <select class="form-select">
                            <option>All Status</option>
                            <option>Pending</option>
                            <option>Approved</option>
                            <option>Rejected</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Date Range</label>
                        <input type="date" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">&nbsp;</label>
                        <button class="btn btn-primary w-100">
                            <i class="fas fa-search"></i> Filter
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Expense Table -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>Expense Log</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Department</th>
                            <th>Category</th>
                            <th>Description</th>
                            <th>Amount</th>
                            <th>Requested By</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>2025-03-20</td>
                            <td>IT</td>
                            <td>Equipment</td>
                            <td>New Laptop Purchase</td>
                            <td><strong>? 1,20,000</strong></td>
                            <td>John Doe</td>
                            <td><span class="badge bg-warning">Pending</span></td>
                            <td>
                                <button class="btn btn-sm btn-success" onclick="approveExpense(1, this)">
                                    <i class="fas fa-check"></i> Approve
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="rejectExpense(1, this)">
                                    <i class="fas fa-times"></i>
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>2025-03-19</td>
                            <td>HR</td>
                            <td>Training</td>
                            <td>Employee Training Program</td>
                            <td><strong>? 50,000</strong></td>
                            <td>Jane Smith</td>
                            <td><span class="badge bg-success">Approved</span></td>
                            <td>
                                <button class="btn btn-sm btn-info" onclick="viewExpense(2)">
                                    <i class="fas fa-eye"></i> View
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>2025-03-18</td>
                            <td>Operations</td>
                            <td>Utilities</td>
                            <td>Monthly Electric Bill</td>
                            <td><strong>? 75,000</strong></td>
                            <td>Mike Johnson</td>
                            <td><span class="badge bg-success">Approved</span></td>
                            <td>
                                <button class="btn btn-sm btn-info" onclick="viewExpense(3)">
                                    <i class="fas fa-eye"></i> View
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>2025-03-17</td>
                            <td>Finance</td>
                            <td>Software</td>
                            <td>Accounting Software License</td>
                            <td><strong>? 30,000</strong></td>
                            <td>Sarah Wilson</td>
                            <td><span class="badge bg-danger">Rejected</span></td>
                            <td>
                                <button class="btn btn-sm btn-info" onclick="viewExpense(4)">
                                    <i class="fas fa-eye"></i> View
                                </button>
                            </td>
                        </tr>
                        <tr>
                            <td>2025-03-16</td>
                            <td>Marketing</td>
                            <td>Travel</td>
                            <td>Conference Travel Expenses</td>
                            <td><strong>? 2,50,000</strong></td>
                            <td>Alex Brown</td>
                            <td><span class="badge bg-warning">Pending</span></td>
                            <td>
                                <button class="btn btn-sm btn-success" onclick="approveExpense(5, this)">
                                    <i class="fas fa-check"></i> Approve
                                </button>
                                <button class="btn btn-sm btn-danger" onclick="rejectExpense(5, this)">
                                    <i class="fas fa-times"></i>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Expense by Category Chart -->
<div class="row mb-4">
    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Expenses by Category</h5>
            <div class="chart-container-sm">
                <canvas id="expenseCategoryChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-6 mb-3">
        <div class="chart-card">
            <h5>Department-wise Expenses</h5>
            <div class="chart-container-sm">
                <canvas id="deptExpenseChart"></canvas>
            </div>
        </div>
    </div>
</div>

<!-- Log Expense Modal -->
<div class="modal fade" id="logExpenseModal" tabindex="-1" aria-labelledby="logExpenseModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="logExpenseModalLabel">Log New Expense</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Expense Date</label>
                            <input type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Department</label>
                            <select class="form-select" required>
                                <option selected disabled>Select Department</option>
                                <option>IT</option>
                                <option>HR</option>
                                <option>Operations</option>
                                <option>Finance</option>
                                <option>Marketing</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Category</label>
                            <select class="form-select" required>
                                <option selected disabled>Select Category</option>
                                <option>Salaries</option>
                                <option>Equipment</option>
                                <option>Utilities</option>
                                <option>Travel</option>
                                <option>Marketing</option>
                                <option>Training</option>
                                <option>Software</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Amount (?)</label>
                            <input type="number" class="form-control" placeholder="0.00" required />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" placeholder="Enter expense details..." required></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Authorized By</label>
                        <select class="form-select" required>
                            <option selected disabled>Select Authorizer</option>
                            <option>Admin User 1</option>
                            <option>Admin User 2</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Save Expense</button>
            </div>
        </div>
    </div>
</div>

<!-- Approve Modal -->
<div class="modal fade" id="approveModal" tabindex="-1" aria-labelledby="approveModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="approveModalLabel">Approve Expense</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-info">
                    <strong>Expense Details:</strong><br>
                    Department: IT<br>
                    Amount: ? 1,20,000<br>
                    Category: Equipment<br>
                    Description: New Laptop Purchase
                </div>
                <div class="mb-3">
                    <label class="form-label">Approval Comments</label>
                    <textarea class="form-control" rows="3" placeholder="Add approval notes..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success">Approve Expense</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Expense Category Chart
        const expenseCategoryCtx = document.getElementById('expenseCategoryChart').getContext('2d');
        new Chart(expenseCategoryCtx, {
            type: 'pie',
            data: {
                labels: ['Salaries', 'Equipment', 'Utilities', 'Travel', 'Marketing', 'Training'],
                datasets: [{
                    data: [400000, 150000, 100000, 300000, 80000, 70000],
                    backgroundColor: [
                        '#1e3c72',
                        '#2a5298',
                        '#3498db',
                        '#2980b9',
                        '#27ae60',
                        '#f39c12'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: {
                        position: 'bottom',
                    }
                }
            }
        });

        // Department Expense Chart
        const deptExpenseCtx = document.getElementById('deptExpenseChart').getContext('2d');
        new Chart(deptExpenseCtx, {
            type: 'bar',
            data: {
                labels: ['IT', 'HR', 'Operations', 'Finance', 'Marketing'],
                datasets: [{
                    label: 'Monthly Expenses',
                    data: [350000, 120000, 450000, 200000, 180000],
                    backgroundColor: [
                        '#1e3c72',
                        '#2a5298',
                        '#3498db',
                        '#27ae60',
                        '#f39c12'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                scales: {
                    y: {
                        beginAtZero: true,
                        title: {
                            display: true,
                            text: 'Amount (?)'
                        }
                    }
                }
            }
        });
    </script>
}
