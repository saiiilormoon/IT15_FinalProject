@{
    ViewData["Title"] = "Operational Processing";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var userRole = ViewBag.UserRole as string ?? "Employee";
    var isAdmin = userRole == "Admin" || userRole == "SuperAdmin";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            @if (isAdmin)
            {
                <h2>Operational Processing & Reports</h2>
                <p>Manage daily operations and generate operational reports.</p>
            }
            else if (userRole == "HR")
            {
                <h2>HR Requests & Reports</h2>
                <p>Manage employee requests and generate HR reports.</p>
            }
            else if (userRole == "Accountant")
            {
                <h2>Financial Requests & Approvals</h2>
                <p>Review and approve financial requests and expense reports.</p>
            }
            else if (userRole == "Auditor")
            {
                <h2>Audit Trail & Compliance</h2>
                <p>View system audit logs and compliance records.</p>
            }
            else
            {
                <h2>My Requests & Submissions</h2>
                <p>Track your submitted requests and their status.</p>
            }
        </div>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            @if (isAdmin)
            {
                <a asp-action="ApprovedAndCompleted" class="btn btn-outline-info">
                    <i class="fas fa-check-double me-1"></i>Approved & Completed
                </a>
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newProcessModal">
                    <i class="fas fa-plus me-2"></i>New Process
                </button>
            }
            else if (userRole == "HR")
            {
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newProcessModal">
                    <i class="fas fa-plus me-2"></i>New Request
                </button>
            }
            else if (userRole == "Accountant")
            {
                <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newProcessModal">
                    <i class="fas fa-plus me-2"></i>New Approval
                </button>
            }
        </div>
    </div>
</div>

<!-- Stat Cards - Role Based -->
<div class="row g-3 mb-4">
    @if (isAdmin)
    {
        <!-- ADMIN: Operational Process KPIs -->
        {
            var allProcesses = (ViewBag.OperationalProcesses as List<CVM_FinalProject.Models.OperationalProcess>) ?? new List<CVM_FinalProject.Models.OperationalProcess>();
            var activeCount = allProcesses.Count;
            var pendingCount = allProcesses.Count(p => p.Status == CVM_FinalProject.Models.ProcessStatus.Pending);
            var approvedCount = allProcesses.Count(p => p.Status == CVM_FinalProject.Models.ProcessStatus.Approved);
            var completedThisMonth = allProcesses.Count(p => p.Status == CVM_FinalProject.Models.ProcessStatus.Completed && 
                                                              p.CompletedAt.HasValue && 
                                                              p.CompletedAt.Value.Month == DateTime.Now.Month &&
                                                              p.CompletedAt.Value.Year == DateTime.Now.Year);
        }
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <h3>@pendingCount</h3>
                <p>Pending Requests</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-check-double"></i>
                </div>
                <h3>@completedThisMonth</h3>
                <p>Completed This Month</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning">
                    <i class="fas fa-clock"></i>
                </div>
                <h3>@approvedCount</h3>
                <p>In Archive</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-file-alt"></i>
                </div>
                <h3>@activeCount</h3>
                <p>Total Processes</p>
            </div>
        </div>
    }
    else if (userRole == "HR")
    {
        <!-- HR: Employee Request KPIs -->
        {
            var hrRequests = (ViewBag.EmployeeRequests as List<dynamic>) ?? new List<dynamic>();
            var pendingRequests = hrRequests.Count(r => r.Status == "Pending");
            var approvedRequests = hrRequests.Count(r => r.Status == "Approved");
            var rejectedRequests = hrRequests.Count(r => r.Status == "Rejected");
            var totalRequests = hrRequests.Count;
        }
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning text-dark">
                    <i class="fas fa-hourglass-half"></i>
                </div>
                <h3>@pendingRequests</h3>
                <p>Pending Requests</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h3>@approvedRequests</h3>
                <p>Approved</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-danger">
                    <i class="fas fa-times-circle"></i>
                </div>
                <h3>@rejectedRequests</h3>
                <p>Rejected</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-inbox"></i>
                </div>
                <h3>@totalRequests</h3>
                <p>Total Requests</p>
            </div>
        </div>
    }
    else if (userRole == "Accountant")
    {
        <!-- ACCOUNTANT: Financial Request KPIs -->
        @{
            var finRequests = (ViewBag.FinancialRequests as List<dynamic>) ?? new List<dynamic>();
            var pendingFin = finRequests.Count(r => r.Status == "Pending");
            var approvedFin = finRequests.Count(r => r.Status == "Approved");
            var totalAmount = finRequests.Sum(r => (decimal)r.Amount);
            var approvedAmount = finRequests.Where(r => r.Status == "Approved").Sum(r => (decimal)r.Amount);
        }
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning text-dark">
                    <i class="fas fa-hourglass-half"></i>
                </div>
                <h3>@pendingFin</h3>
                <p>Pending Approvals</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h3>@approvedFin</h3>
                <p>Approved</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-peso-sign"></i>
                </div>
                <h3>₱@totalAmount.ToString("N0")</h3>
                <p>Total Amount</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary">
                    <i class="fas fa-thumbs-up"></i>
                </div>
                <h3>₱@approvedAmount.ToString("N0")</h3>
                <p>Approved Amount</p>
            </div>
        </div>
    }
    else if (userRole == "Auditor")
    {
        <!-- AUDITOR: Audit KPIs -->
        @{
            var auditLogs = (ViewBag.AuditLogs as List<dynamic>) ?? new List<dynamic>();
            var totalLogs = auditLogs.Count;
            var createsCount = auditLogs.Count(l => l.Action == "CREATE");
            var updatesCount = auditLogs.Count(l => l.Action == "UPDATE");
            var deletesCount = auditLogs.Count(l => l.Action == "DELETE");
        }
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-file-alt"></i>
                </div>
                <h3>@totalLogs</h3>
                <p>Total Audit Logs</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary">
                    <i class="fas fa-plus-circle"></i>
                </div>
                <h3>@createsCount</h3>
                <p>Creates</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning text-dark">
                    <i class="fas fa-edit"></i>
                </div>
                <h3>@updatesCount</h3>
                <p>Updates</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-danger">
                    <i class="fas fa-trash"></i>
                </div>
                <h3>@deletesCount</h3>
                <p>Deletes</p>
            </div>
        </div>
    }
    else
    {
        <!-- EMPLOYEE: Personal Request KPIs -->
        @{
            var myRequests = (ViewBag.MyRequests as List<dynamic>) ?? new List<dynamic>();
            var myPending = myRequests.Count(r => r.Status == "Pending");
            var myApproved = myRequests.Count(r => r.Status == "Approved");
            var myRejected = myRequests.Count(r => r.Status == "Rejected");
            var myTotal = myRequests.Count;
        }
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning text-dark">
                    <i class="fas fa-hourglass-half"></i>
                </div>
                <h3>@myPending</h3>
                <p>Pending</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-check-circle"></i>
                </div>
                <h3>@myApproved</h3>
                <p>Approved</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-danger">
                    <i class="fas fa-times-circle"></i>
                </div>
                <h3>@myRejected</h3>
                <p>Rejected</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-inbox"></i>
                </div>
                <h3>@myTotal</h3>
                <p>Total Requests</p>
            </div>
        </div>
    }
</div>

