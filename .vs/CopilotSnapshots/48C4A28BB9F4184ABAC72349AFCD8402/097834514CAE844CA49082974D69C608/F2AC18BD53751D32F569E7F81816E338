<!-- Filter and Search - Admin Only -->
@if (isAdmin)
{
    <div class="chart-card mb-4">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="fas fa-search"></i></span>
                    <input type="text" class="form-control" placeholder="Search processes..." id="searchInput" onkeyup="filterTable()">
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Department</label>
                <select class="form-select" id="deptFilter" onchange="filterTable()">
                    <option value="">All Departments</option>
                    <option value="HR">Human Resources</option>
                    <option value="Finance">Finance</option>
                    <option value="Operations">Operations</option>
                    <option value="Sales">Sales</option>
                    <option value="IT">IT</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-semibold">Status</label>
                <select class="form-select" id="statusFilter" onchange="filterTable()">
                    <option value="">All</option>
                    <option value="PENDING">Pending</option>
                    <option value="ACTIVE">Active</option>
                    <option value="COMPLETED">Completed</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small fw-semibold">&nbsp;</label>
                <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                    <i class="fas fa-redo me-1"></i>Reset
                </button>
            </div>
        </div>
    </div>
}

<!-- Processes Table - Role Based View -->
<div class="data-table">
    @if (isAdmin)
    {
        <!-- ADMIN/SUPERADMIN: Show Operational Processes -->
        @Html.AntiForgeryToken()
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Operational Processes</h5>
            <span class="badge bg-primary" id="recordCount">Showing @(ViewBag.OperationalProcesses?.Count ?? 0) records</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="processTable">
                <thead>
                    <tr>
                        <th>Process ID</th>
                        <th>Process Name</th>
                        <th>Department</th>
                        <th>Assigned To</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.OperationalProcesses != null && ViewBag.OperationalProcesses.Count > 0)
                    {
                        @foreach (var process in ViewBag.OperationalProcesses)
                        {
                            string statusClass = "bg-secondary";
                            string statusText = process.Status.ToString();

                            if (process.Status == CVM_FinalProject.Models.ProcessStatus.Pending)
                            {
                                statusClass = "bg-warning text-dark";
                                statusText = "Pending";
                            }
                            else if (process.Status == CVM_FinalProject.Models.ProcessStatus.Approved || process.Status == CVM_FinalProject.Models.ProcessStatus.Active)
                            {
                                statusClass = "bg-success";
                                statusText = "Active";
                            }
                            else if (process.Status == CVM_FinalProject.Models.ProcessStatus.Completed)
                            {
                                statusClass = "bg-secondary";
                                statusText = "Completed";
                            }

                            <tr data-process-id="@process.ProcessId" data-status="@process.Status">
                                <td><span class="fw-semibold text-primary">#@process.ProcessId</span></td>
                                <td>@process.Name</td>
                                <td>@process.Department</td>
                                <td>@process.AssignedTo</td>
                                <td>@process.Priority</td>
                                <td><span class="badge @statusClass">@statusText</span></td>
                                <td>@process.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" title="View" onclick="viewProcess('@process.ProcessId', '@process.Name', '@process.Department', '@process.AssignedTo', '@statusText', '@process.CreatedAt.ToString("MMM dd, yyyy")')"><i class="fas fa-eye"></i></button>
                                        <button class="btn btn-outline-secondary" title="Edit" onclick="openEditModal('@process.ProcessId', '@process.Name', '@process.Department', '@process.AssignedTo')"><i class="fas fa-edit"></i></button>
                                        <button class="btn btn-outline-success" title="Approve" onclick="approveProcess('@process.ProcessId', this)"><i class="fas fa-check"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">
                                <i class="fas fa-check-circle me-2"></i>No pending processes.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (userRole == "HR")
    {
        <!-- HR: Show Employee Requests -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Employee Requests</h5>
            <span class="badge bg-primary">Showing @(ViewBag.EmployeeRequests?.Count ?? 0) requests</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Request ID</th>
                        <th>Employee</th>
                        <th>Request Type</th>
                        <th>Department</th>
                        <th>Status</th>
                        <th>Date Requested</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.EmployeeRequests != null && ViewBag.EmployeeRequests.Count > 0)
                    {
                        @foreach (var request in ViewBag.EmployeeRequests)
                        {
                            <tr>
                                <td><span class="fw-semibold text-primary">#@request.RequestId</span></td>
                                <td>@request.EmployeeName</td>
                                <td>@request.RequestType</td>
                                <td>@request.Department</td>
                                <td>
                                    @{
                                        string statusClass = "bg-secondary";
                                        if (request.Status == "Pending") statusClass = "bg-warning text-dark";
                                        else if (request.Status == "Approved") statusClass = "bg-success";
                                        else if (request.Status == "Rejected") statusClass = "bg-danger";
                                    }
                                    <span class="badge @statusClass">@request.Status</span>
                                </td>
                                <td>@request.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" title="View" onclick="viewRequest('@request.RequestId', '@request.EmployeeName', '@request.RequestType', '@request.Status')"><i class="fas fa-eye"></i></button>
                                        @if (request.Status == "Pending")
                                        {
                                            <button class="btn btn-outline-success" title="Approve" onclick="approveRequest('@request.RequestId')"><i class="fas fa-check"></i></button>
                                            <button class="btn btn-outline-danger" title="Reject" onclick="rejectRequest('@request.RequestId')"><i class="fas fa-times"></i></button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="fas fa-check-circle me-2"></i>No employee requests at this time.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (userRole == "Accountant")
    {
        <!-- ACCOUNTANT: Show Financial/Expense Requests -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Financial Requests & Approvals</h5>
            <span class="badge bg-primary">Showing @(ViewBag.FinancialRequests?.Count ?? 0) requests</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Request ID</th>
                        <th>Department</th>
                        <th>Request Type</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date Submitted</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.FinancialRequests != null && ViewBag.FinancialRequests.Count > 0)
                    {
                        @foreach (var request in ViewBag.FinancialRequests)
                        {
                            <tr>
                                <td><span class="fw-semibold text-primary">#@request.RequestId</span></td>
                                <td>@request.Department</td>
                                <td>@request.RequestType</td>
                                <td><span class="fw-semibold">₱@request.Amount.ToString("N2")</span></td>
                                <td>
                                    @{
                                        string statusClass = "bg-secondary";
                                        if (request.Status == "Pending") statusClass = "bg-warning text-dark";
                                        else if (request.Status == "Approved") statusClass = "bg-success";
                                        else if (request.Status == "Rejected") statusClass = "bg-danger";
                                    }
                                    <span class="badge @statusClass">@request.Status</span>
                                </td>
                                <td>@request.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" title="View" onclick="viewFinancialRequest('@request.RequestId', '@request.Department', '₱@request.Amount.ToString("N2")', '@request.Status')"><i class="fas fa-eye"></i></button>
                                        @if (request.Status == "Pending")
                                        {
                                            <button class="btn btn-outline-success" title="Approve" onclick="approveFinancial('@request.RequestId')"><i class="fas fa-check"></i></button>
                                            <button class="btn btn-outline-danger" title="Reject" onclick="rejectFinancial('@request.RequestId')"><i class="fas fa-times"></i></button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="fas fa-check-circle me-2"></i>No financial requests at this time.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (userRole == "Auditor")
    {
        <!-- AUDITOR: Show Audit Logs/Compliance Records -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Audit Logs & Compliance Records</h5>
            <span class="badge bg-primary">Showing @(ViewBag.AuditLogs?.Count ?? 0) records</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Log ID</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity Type</th>
                        <th>Department</th>
                        <th>Timestamp</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.AuditLogs != null && ViewBag.AuditLogs.Count > 0)
                    {
                        @foreach (var log in ViewBag.AuditLogs)
                        {
                            <tr>
                                <td><span class="fw-semibold text-primary">#@log.LogId</span></td>
                                <td>@log.UserName</td>
                                <td>
                                    @{
                                        string actionBadgeClass = "bg-secondary";
                                        if (log.Action == "CREATE") actionBadgeClass = "bg-info";
                                        else if (log.Action == "UPDATE") actionBadgeClass = "bg-warning text-dark";
                                        else if (log.Action == "DELETE") actionBadgeClass = "bg-danger";
                                        else if (log.Action == "APPROVE") actionBadgeClass = "bg-success";
                                    }
                                    <span class="badge @actionBadgeClass">@log.Action</span>
                                </td>
                                <td>@log.EntityType</td>
                                <td>@log.Department</td>
                                <td>@log.Timestamp.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm" title="View Details" onclick="viewAuditLog('@log.LogId', '@log.UserName', '@log.Action', '@log.EntityType')"><i class="fas fa-eye"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="fas fa-check-circle me-2"></i>No audit logs at this time.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <!-- EMPLOYEE: Show Own Requests/Submissions -->
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">My Requests & Submissions</h5>
            <span class="badge bg-primary">Showing @(ViewBag.MyRequests?.Count ?? 0) requests</span>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Request ID</th>
                        <th>Request Type</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.MyRequests != null && ViewBag.MyRequests.Count > 0)
                    {
                        @foreach (var request in ViewBag.MyRequests)
                        {
                            <tr>
                                <td><span class="fw-semibold text-primary">#@request.RequestId</span></td>
                                <td>@request.RequestType</td>
                                <td>@request.Description</td>
                                <td>
                                    @{
                                        string statusClass = "bg-secondary";
                                        if (request.Status == "Pending") statusClass = "bg-warning text-dark";
                                        else if (request.Status == "Approved") statusClass = "bg-success";
                                        else if (request.Status == "Rejected") statusClass = "bg-danger";
                                    }
                                    <span class="badge @statusClass">@request.Status</span>
                                </td>
                                <td>@request.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <button class="btn btn-outline-primary btn-sm" title="View" onclick="viewMyRequest('@request.RequestId', '@request.RequestType', '@request.Status')"><i class="fas fa-eye"></i></button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                <i class="fas fa-inbox me-2"></i>No requests submitted yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Pagination -->
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-end mb-0">
            <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">Next</a></li>
        </ul>
    </nav>
