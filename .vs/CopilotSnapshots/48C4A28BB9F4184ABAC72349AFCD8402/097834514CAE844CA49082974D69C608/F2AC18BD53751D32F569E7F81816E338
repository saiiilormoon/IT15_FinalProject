@section Scripts {
<script>
    // Initialize: Update record count
    function initializeApprovedProcesses() {
        updateRecordCount();
    }

    // Update record count after filtering
    function updateRecordCount() {
        var rows = document.querySelectorAll('#processTable tbody tr');
        var visibleCount = 0;
        rows.forEach(row => {
            if (row.style.display !== 'none') {
                visibleCount++;
            }
        });
        document.getElementById('recordCount').textContent = `Showing ${visibleCount} records`;
    }

    // Helper to get antiforgery token for AJAX
    function getAntiForgeryToken() {
        var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        return tokenInput ? tokenInput.value : '';
    }

    // View Process Modal - displays process details
    function viewProcess(id, name, dept, assignedTo, status, date) {
        document.getElementById('viewProcessId').innerText = '#' + id;
        document.getElementById('viewProcessName').innerText = name;
        document.getElementById('viewDepartment').innerText = dept;
        document.getElementById('viewAssignedTo').innerText = assignedTo;
        document.getElementById('viewStatus').innerHTML = getStatusBadge(status);
        document.getElementById('viewDate').innerText = date;
        
        var modal = new bootstrap.Modal(document.getElementById('viewProcessModal'));
        modal.show();
    }

    // Open Edit Process Modal
    function openEditModal(id, name, dept, assignedTo) {
        document.getElementById('editProcessId').value = id;
        document.getElementById('editProcessIdDisplay').value = '#' + id;
        document.getElementById('editProcessName').value = name;
        document.getElementById('editDepartment').value = dept;
        document.getElementById('editAssignedTo').value = assignedTo;
        
        var modal = new bootstrap.Modal(document.getElementById('editProcessModal'));
        modal.show();
    }

    // Get status badge HTML
    function getStatusBadge(status) {
        const badgeClass = {
            'APPROVED': 'bg-success',
            'Approved': 'bg-success',
            'ACTIVE': 'bg-success',
            'Active': 'bg-success',
            'PENDING': 'bg-warning text-dark',
            'Pending': 'bg-warning text-dark',
            'COMPLETED': 'bg-secondary',
            'Completed': 'bg-secondary'
        };
        const cssClass = badgeClass[status] || 'bg-secondary';
        return '<span class="badge ' + cssClass + '">' + status + '</span>';
    }

    // Approve process - changes status to APPROVED 

    function approveProcess(id, btn) {
        if (!confirm('Are you sure you want to approve this process?')) return;
        
        var token = getAntiForgeryToken();
        btn.disabled = true;

        // Get the row
        var row = document.querySelector('#processTable tbody tr[data-process-id="' + id + '"]');
        
        // Send to server
        fetch('@Url.Action("ApproveProcessAjax", "Dashboard")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({ processId: id })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Show success message
                showAlert('success', 'Process #' + id + ' approved successfully!');
                
                // Wait a moment then redirect to Approved & Completed page
                setTimeout(() => {
                    window.location.href = '@Url.Action("ApprovedAndCompleted", "Dashboard")';
                }, 1500);
            } else {
                alert(data.message || 'Failed to approve process');
                btn.disabled = false;
            }
        })
        .catch(err => {
            console.error('Error:', err);
            alert('Request failed');
            btn.disabled = false;
        });
    }

    // Complete/Mark process as done
    function completeProcess(id, btn) {
        if (!confirm('Mark process ' + id + ' as completed?')) return;
        
        var token = getAntiForgeryToken();
        btn.disabled = true;

        // Get the row
        var row = document.querySelector('#processTable tbody tr[data-process-id="' + id + '"]');

        // Send to server
        fetch('@Url.Action("CompleteProcessAjax", "Dashboard")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': token
            },
            body: JSON.stringify({ processId: id })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Show success message
                showAlert('success', 'Process #' + id + ' marked as completed!');
                
                // Wait a moment then reload the page to see updated data from database
                setTimeout(() => {
                    window.location.reload();
                }, 1500);
            } else {
                alert(data.message || 'Failed to complete process');
                btn.disabled = false;
            }
        })
        .catch(err => {
            console.error('Error:', err);
            alert('Request failed');
            btn.disabled = false;
        });
    }

    // Show alert message
    function showAlert(type, message) {
        var alertHtml = '<div class="alert alert-' + (type === 'success' ? 'success' : 'danger') + ' alert-dismissible fade show" role="alert">' +
            '<i class="fas ' + (type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle') + ' me-2"></i>' + message +
            '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
            '</div>';
        
        var alertContainer = document.querySelector('.chart-card');
        if (alertContainer) {
            alertContainer.insertAdjacentHTML('beforebegin', alertHtml);
            setTimeout(() => {
                var alert = document.querySelector('.alert');
                if (alert) alert.remove();
            }, 3000);
        }
    }

    // Handle edit form submission
    document.getElementById('editProcessForm')?.addEventListener('submit', function(e) {
        e.preventDefault();
        var id = document.getElementById('editProcessId').value;
        var name = document.getElementById('editProcessName').value;
        var dept = document.getElementById('editDepartment').value;
        var assignedTo = document.getElementById('editAssignedTo').value;
        
        // Find and update the row
        var row = document.querySelector('#processTable tbody tr[data-process-id="' + id + '"]');
        if (row) {
            row.cells[1].textContent = name;
            row.cells[2].textContent = dept;
            row.cells[3].textContent = assignedTo;
            showAlert('success', 'Process updated successfully!');
        }
        
        // Close modal
        bootstrap.Modal.getInstance(document.getElementById('editProcessModal')).hide();
    });

    // Filter table - Operations page can now filter by different status types
    function filterTable() {
        const search = document.getElementById('searchInput').value.toLowerCase();
        const dept = document.getElementById('deptFilter').value;
        const status = document.getElementById('statusFilter').value;
        const rows = document.querySelectorAll('#processTable tbody tr');
        let visibleCount = 0;
        
        rows.forEach(row => {
            const text = row.textContent.toLowerCase();
            const rowDept = row.cells[2].textContent;
            const rowStatus = row.cells[5].textContent.trim();
            
            const matchSearch = text.includes(search);
            const matchDept = !dept || rowDept.includes(dept);
            const matchStatus = !status || rowStatus.includes(status);
            
            // Show row if it matches search AND dept AND (status filter is empty/All OR matches status)
            if (matchSearch && matchDept && matchStatus) {
                row.style.display = '';
                visibleCount++;
            } else {
                row.style.display = 'none';
            }
        });
        
        document.getElementById('recordCount').textContent = `Showing ${visibleCount} records`;
    }
    
    function resetFilters() {
        document.getElementById('searchInput').value = '';
        document.getElementById('deptFilter').value = '';
        document.getElementById('statusFilter').value = '';
        filterTable();
    }
    
    function filterByStatus(status) {
        document.getElementById('statusFilter').value = status.charAt(0).toUpperCase() + status.slice(1);
        filterTable();
    }
    
    function generateProcessReport(id) {
        alert('Generating report for process: ' + id);
    }
    
    
    function submitNewProcess() {
        // Form will auto-submit now since we're using proper form tag
        // This function is kept for backward compatibility
        document.getElementById('newProcessForm').submit();
    }
    
    function generateReport() {
        alert('Generating operational report...\n\nReport will be downloaded shortly.');
        bootstrap.Modal.getInstance(document.getElementById('generateReportModal')).hide();
    }
    
    // View Request Details - HR
    function viewRequest(id, employee, type, status) {
        alert('Request #' + id + '\nEmployee: ' + employee + '\nType: ' + type + '\nStatus: ' + status);
    }

    // Approve/Reject HR Requests
    function approveRequest(id) {
        if (!confirm('Approve request #' + id + '?')) return;
        alert('Request #' + id + ' has been approved.');
        location.reload();
    }

    function rejectRequest(id) {
        if (!confirm('Reject request #' + id + '?')) return;
        alert('Request #' + id + ' has been rejected.');
        location.reload();
    }

    // View Financial Request - Accountant
    function viewFinancialRequest(id, dept, amount, status) {
        alert('Financial Request #' + id + '\nDepartment: ' + dept + '\nAmount: ' + amount + '\nStatus: ' + status);
    }

    // Approve/Reject Financial Requests
    function approveFinancial(id) {
        if (!confirm('Approve financial request #' + id + '?')) return;
        alert('Financial request #' + id + ' has been approved.');
        location.reload();
    }

    function rejectFinancial(id) {
        if (!confirm('Reject financial request #' + id + '?')) return;
        alert('Financial request #' + id + ' has been rejected.');
        location.reload();
    }

    // View Audit Log - Auditor
    function viewAuditLog(id, user, action, entityType) {
        alert('Audit Log #' + id + '\nUser: ' + user + '\nAction: ' + action + '\nEntity Type: ' + entityType);
    }

    // View My Request - Employee
    function viewMyRequest(id, type, status) {
        alert('Request #' + id + '\nType: ' + type + '\nStatus: ' + status);
    }
