@{
    ViewData["Title"] = "Financial Dashboard";
    var userRole = ViewBag.UserRole as string ?? "Employee";
    var userName = ViewBag.UserName as string ?? "User";
    var totalBudgetAllocated = ViewBag.TotalBudgetAllocated ?? 0m;
    var totalBudgetUsed = ViewBag.TotalBudgetUsed ?? 0m;
    var remainingBudget = (decimal)totalBudgetAllocated - (decimal)totalBudgetUsed;
    var budgetUtilizationRate = ViewBag.BudgetUtilizationRate ?? 0m;
}

<!-- Dashboard Header -->
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1">Welcome back, <span class="text-primary">@userName</span>!</h1>
            <p class="text-muted mb-0">Here's your organization's financial summary for today.</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="badge bg-primary px-3 py-2 fs-6">@userRole</span>
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-arrow-left me-2"></i>Go Back to Dashboard
            </a>
        </div>
    </div>
</div>

<!-- KPI Cards - Financial Focus (ENHANCED) -->
<div class="row mb-4 g-3">
    <!-- Total Budget Allocated -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Budget Allocated</p>
                    <h3 class="mb-1">
                        @if ((decimal)totalBudgetAllocated == 0)
                        {
                            <span>? 0.00</span>
                        }
                        else
                        {
                            <span>? @((decimal)totalBudgetAllocated).ToString("N0")</span>
                        }
                    </h3>
                    <small class="text-muted">FY 2024-2025</small>
                </div>
                <div class="stat-icon bg-primary">
                    <i class="fas fa-coins"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Budget Used -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Total Budget Used</p>
                    <h3 class="mb-1">
                        @if ((decimal)totalBudgetUsed == 0)
                        {
                            <span>? 0.00</span>
                        }
                        else
                        {
                            <span>? @((decimal)totalBudgetUsed).ToString("N0")</span>
                        }
                    </h3>
                    <small class="text-muted">Current Spending</small>
                </div>
                <div class="stat-icon bg-info">
                    <i class="fas fa-arrow-down"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Remaining Budget -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Remaining Budget</p>
                    <h3 class="mb-1">
                        @if (remainingBudget == 0)
                        {
                            <span>? 0.00</span>
                        }
                        else
                        {
                            <span>? @remainingBudget.ToString("N0")</span>
                        }
                    </h3>
                    <small class="text-muted">Available</small>
                </div>
                <div class="stat-icon bg-success">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Budget Utilization Rate -->
    <div class="col-lg-3 col-md-6">
        <div class="stat-card financial-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted small mb-2">Utilization Rate</p>
                    <h3 class="mb-1">
                        @Math.Round((decimal)budgetUtilizationRate, 1)%
                    </h3>
                    <small class="text-muted">Budget Burned</small>
                </div>
                <div class="stat-icon bg-warning">
                    <i class="fas fa-chart-pie"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Actions - Enhanced with Full Capabilities -->
<div class="row mb-5">
    <div class="col-12">
        <div class="d-flex gap-2 flex-wrap">
            <a href="#" class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#createBudgetModal">
                <i class="fas fa-plus-circle"></i>
                <span>Create Budget</span>
            </a>
            <a href="@Url.Action("AccountantDashboard", "Dashboard")" class="financial-action-btn">
                <i class="fas fa-chart-bar"></i>
                <span>Budget Analysis</span>
            </a>
            <a href="@Url.Action("ExpenseTracking", "Dashboard")" class="financial-action-btn">
                <i class="fas fa-receipt"></i>
                <span>Track Expenses</span>
            </a>
            <a href="@Url.Action("FinancialReports", "Dashboard")" class="financial-action-btn">
                <i class="fas fa-file-pdf"></i>
                <span>Financial Reports</span>
            </a>
            <a href="#" class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#exportModal">
                <i class="fas fa-download"></i>
                <span>Export Data</span>
            </a>
            <a href="#" class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#forecastModal">
                <i class="fas fa-chart-line"></i>
                <span>Budget Forecast</span>
            </a>
        </div>
    </div>
</div>

<!-- Department Budget Status & Budget Health -->
<div class="row mb-4">
    <!-- Department Budget Status -->
    <div class="col-lg-8 mb-3">
        <div class="chart-card">
            <h5>Department Budget Utilization</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Department</th>
                            <th>Allocated</th>
                            <th>Used</th>
                            <th>Remaining</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.DepartmentBudgets != null && ViewBag.DepartmentBudgets.Count > 0)
                        {
                            foreach (var dept in ViewBag.DepartmentBudgets)
                            {
                                var utilPercent = dept.AllocatedAmount > 0 ? (dept.UsedAmount / dept.AllocatedAmount * 100) : 0;
                                <tr>
                                    <td><strong>@dept.DepartmentName</strong></td>
                                    <td>? @dept.AllocatedAmount.ToString("N0")</td>
                                    <td>? @dept.UsedAmount.ToString("N0")</td>
                                    <td>? @dept.RemainingAmount.ToString("N0")</td>
                                    <td>
                                        @if (utilPercent <= 70)
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle"></i> Healthy (@utilPercent.ToString("F0")%)
                                            </span>
                                        }
                                        else if (utilPercent <= 90)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-exclamation-triangle"></i> Caution (@utilPercent.ToString("F0")%)
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times-circle"></i> Critical (@utilPercent.ToString("F0")%)
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No budget data available</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Budget Health Summary - Compact -->
    <div class="col-lg-4 mb-3">
        <div class="chart-card">
            <h5>Budget Health</h5>
            <div class="p-3">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Healthy</span>
                        <strong>70%</strong>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 70%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">At Risk</span>
                        <strong>25%</strong>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-warning" style="width: 25%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Over Budget</span>
                        <strong>5%</strong>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-danger" style="width: 5%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Quick Summary & Alerts -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5>Financial Summary & Alerts</h5>
            <div class="p-3">
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="text-center p-2">
                            <h4 class="text-primary mb-1">? @{
                                decimal allocated = ViewBag.TotalBudgetAllocated ?? 0;
                                @allocated.ToString("N0")
                            }</h4>
                            <small class="text-muted">Total Allocated</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center p-2">
                            <h4 class="text-danger mb-1">? @{
                                decimal used = ViewBag.TotalBudgetUsed ?? 0;
                                @used.ToString("N0")
                            }</h4>
                            <small class="text-muted">Total Used</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-center p-2">
                            <h4 class="text-success mb-1">? @{
                                decimal remaining = (ViewBag.TotalBudgetAllocated ?? 0) - (ViewBag.TotalBudgetUsed ?? 0);
                                @remaining.ToString("N0")
                            }</h4>
                            <small class="text-muted">Remaining</small>
                        </div>
                    </div>
                </div>
                
                <hr class="my-3" />
                
                <div class="alert alert-warning d-flex align-items-center mb-2" role="alert" style="font-size: 0.9rem;">
                    <i class="fas fa-exclamation-triangle me-2 flex-shrink-0"></i>
                    <div>
                        <strong>Operations Dept</strong> at 80% utilization. Monitor closely.
                    </div>
                </div>
                <div class="alert alert-info d-flex align-items-center mb-0" role="alert" style="font-size: 0.9rem;">
                    <i class="fas fa-info-circle me-2 flex-shrink-0"></i>
                    <div>
                        <strong>Month-End Approaching:</strong> 5 days remaining. Review pending expenses.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Budget Modal - NEW FEATURE -->
<div class="modal fade" id="createBudgetModal" tabindex="-1" aria-labelledby="createBudgetModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createBudgetModalLabel">
                    <i class="fas fa-plus-circle me-2"></i>Create New Budget
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="CreateBudget" asp-controller="Dashboard">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="departmentSelect" class="form-label">Department</label>
                        <select id="departmentSelect" name="departmentId" class="form-select form-select-lg" required>
                            <option value="">-- Select Department --</option>
                            <option value="1">Operations</option>
                            <option value="2">IT</option>
                            <option value="3">Finance</option>
                            <option value="4">HR</option>
                            <option value="5">Marketing</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="budgetPeriod" class="form-label">Budget Period</label>
                        <input type="text" id="budgetPeriod" name="budgetPeriod" class="form-control form-control-lg" 
                               placeholder="e.g., FY 2024-2025" value="FY 2024-2025" required />
                    </div>

                    <div class="mb-3">
                        <label for="allocatedAmount" class="form-label">Allocated Amount (?)</label>
                        <input type="number" id="allocatedAmount" name="allocatedAmount" class="form-control form-control-lg" 
                               placeholder="0.00" step="0.01" min="0" required />
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> Budget will be created in pending status and requires admin approval before activation.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check me-2"></i>Create Budget
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportModalLabel">Export Financial Data</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Select format to export financial reports:</p>
                <div class="btn-group-vertical w-100" role="group">
                    <button type="button" class="btn btn-outline-primary text-start">
                        <i class="fas fa-file-excel me-2"></i>
                        Export to Excel (.xlsx)
                    </button>
                    <button type="button" class="btn btn-outline-primary text-start">
                        <i class="fas fa-file-pdf me-2"></i>
                        Export to PDF
                    </button>
                    <button type="button" class="btn btn-outline-primary text-start">
                        <i class="fas fa-file-csv me-2"></i>
                        Export to CSV
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Forecast Modal -->
<div class="modal fade" id="forecastModal" tabindex="-1" aria-labelledby="forecastModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="forecastModalLabel">Budget Forecast</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Projected Budget Status:</p>
                <div class="alert alert-info">
                    <strong>Current Spending Rate:</strong> 15% per week
                </div>
                <div class="alert alert-warning">
                    <strong>Projected Year-End:</strong> 95% utilization (OVER BUDGET by 5%)
                </div>
                <div class="alert alert-success">
                    <strong>Recommendation:</strong> Implement cost controls in Q3 to avoid overage.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
}

