@model List<Report>
@using CVM_FinalProject.Models
@using CVM_FinalProject.Services
@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var reportStats = ViewBag.ReportStats as ReportStatsViewModel;
    var userName = ViewBag.UserName as string ?? "User";
    var userRole = ViewBag.UserRole as string ?? "Employee";
}

<!-- Dashboard Header -->
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1">Reports & Analytics</h1>
            <p class="text-muted mb-0">Generate, view, and export detailed system reports</p>
        </div>
        <div>
            <button class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#generateReportModal">
                <i class="fas fa-plus-circle me-2"></i>Generate Report
            </button>
        </div>
    </div>
</div>

<!-- Report Statistics Cards -->
@if (reportStats != null)
{
    <div class="row mb-4 g-3">
        <!-- Total Reports -->
        <div class="col-lg-3 col-md-6">
            <div class="stat-card financial-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-2">Total Reports</p>
                        <h3 class="mb-1">@reportStats.TotalReports</h3>
                        <small class="text-muted">All Time</small>
                    </div>
                    <div class="stat-icon bg-primary">
                        <i class="fas fa-file-alt"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- This Month -->
        <div class="col-lg-3 col-md-6">
            <div class="stat-card financial-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-2">This Month</p>
                        <h3 class="mb-1">@reportStats.ReportsThisMonth</h3>
                        <small class="text-muted">Current Period</small>
                    </div>
                    <div class="stat-icon bg-success">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Report Types -->
        <div class="col-lg-3 col-md-6">
            <div class="stat-card financial-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-2">Report Types</p>
                        <h3 class="mb-1">@reportStats.ReportsByType.Count</h3>
                        <small class="text-muted">Available</small>
                    </div>
                    <div class="stat-icon bg-info">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Report Status -->
        <div class="col-lg-3 col-md-6">
            <div class="stat-card financial-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-2">Report Status</p>
                        <h3 class="mb-1">
                            @{
                                var readyReports = reportStats.TotalReports - (reportStats.ReportsThisMonth ?? 0);
                            }
                            @readyReports
                        </h3>
                        <small class="text-muted">Ready to View</small>
                    </div>
                    <div class="stat-icon bg-warning">
                        <i class="fas fa-check-double"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Quick Actions -->
<div class="row mb-5">
    <div class="col-12">
        <div class="d-flex gap-2 flex-wrap">
            <button class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#generateReportModal">
                <i class="fas fa-plus-circle"></i>
                <span>New Report</span>
            </button>
            <a href="#" class="financial-action-btn" onclick="exportAllReports(event)">
                <i class="fas fa-download"></i>
                <span>Export Reports</span>
            </a>
            <a href="#" class="financial-action-btn" onclick="refreshReports(event)">
                <i class="fas fa-sync-alt"></i>
                <span>Refresh</span>
            </a>
        </div>
    </div>
</div>

<!-- Generate Report Modal -->
<div class="modal fade" id="generateReportModal" tabindex="-1" aria-labelledby="generateReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="generateReportModalLabel">Generate New Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="reportForm">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Report Type</label>
                            <select class="form-select" id="reportType" required>
                                <option value="">-- Select Report Type --</option>
                                <option value="Operational">Operational Processing</option>
                                <option value="Departmental">Departmental</option>
                                <option value="Performance">Performance Summary</option>
                                <option value="Budget">Budget Monitoring</option>
                                <option value="Financial">Financial Overview</option>
                                <option value="Expense">Expense Tracking</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Department (Optional)</label>
                            <select class="form-select" id="department">
                                <option value="">-- All Departments --</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Start Date</label>
                            <input type="date" class="form-control" id="startDate">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">End Date</label>
                            <input type="date" class="form-control" id="endDate">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Export Format</label>
                            <select class="form-select" id="format" required>
                                <option value="pdf">PDF</option>
                                <option value="excel">Excel (.xlsx)</option>
                                <option value="csv">CSV</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Include Details</label>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="includeCharts" checked>
                                <label class="form-check-label" for="includeCharts">
                                    Include Charts
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="generateReport()">
                    <i class="fas fa-file-pdf me-1"></i>Generate Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Generated Reports Table -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
                <h5 class="mb-2 mb-md-0">Generated Reports</h5>
                <div class="d-flex gap-2 flex-wrap">
                    <input type="text" class="form-control form-control-sm" placeholder="Search reports..." id="searchReports" style="width: 250px;">
                    <select class="form-select form-select-sm" id="filterType" style="width: 150px;" onchange="filterReports()">
                        <option value="">All Types</option>
                        @if (reportStats != null && reportStats.ReportsByType.Count > 0)
                        {
                            @foreach (var type in reportStats.ReportsByType)
                            {
                                <option value="@type.ReportType">@type.ReportType</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="reportsTable">
                    <thead>
                        <tr>
                            <th>Report Type</th>
                            <th>Generated By</th>
                            <th>Generated Date</th>
                            <th>Size</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var report in Model)
                            {
                                <tr>
                                    <td>
                                        <i class="fas fa-file-pdf text-danger me-2"></i>
                                        <strong>@report.ReportType</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark">
                                            @(report.User?.FullName ?? "System")
                                        </span>
                                    </td>
                                    <td>
                                        <small>@report.GeneratedAt.ToString("MMM dd, yyyy hh:mm tt")</small>
                                    </td>
                                    <td>
                                        @{
                                            var size = report.ReportData?.Length ?? 0;
                                            var sizeDisplay = size > 1024 ? $"{(size / 1024.0):F1} KB" : $"{size} B";
                                        }
                                        <small>@sizeDisplay</small>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button type="button" class="btn btn-outline-primary" onclick="viewReport('@report.ReportId')" title="View Report">
                                                <i class="fas fa-eye"></i> View
                                            </button>
                                            <button type="button" class="btn btn-outline-secondary" onclick="downloadReport('@report.ReportId')" title="Download Report">
                                                <i class="fas fa-download"></i> Download
                                            </button>
                                            <button type="button" class="btn btn-outline-danger" onclick="deleteReport('@report.ReportId')" title="Delete Report">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="fas fa-inbox me-2" style="font-size: 1.5rem;"></i>
                                    <p class="mt-2">No reports found. Generate your first report to get started.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function generateReport() {
            const reportType = document.getElementById('reportType').value;
            const format = document.getElementById('format').value;
            
            if (!reportType) {
                alert('Please select a report type');
                return;
            }
            
            alert(`Generating ${reportType} report in ${format} format...`);
            bootstrap.Modal.getInstance(document.getElementById('generateReportModal')).hide();
        }

        function viewReport(id) {
            alert('Viewing report: ' + id);
        }

        function searchReports() {
            const searchInput = document.getElementById('searchReports').value.toLowerCase();
            const rows = document.querySelectorAll('#reportsTable tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchInput) ? '' : 'none';
            });
        }

        document.getElementById('searchReports')?.addEventListener('keyup', searchReports);
    </script>
}
