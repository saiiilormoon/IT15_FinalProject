                employeeRequest.CompletedByUserId = admin?.Id;
                employeeRequest.CompletedByName = admin?.FullName;

                _context.EmployeeRequests.Update(employeeRequest);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Employee request {request.RequestId} completed by {admin?.Email} at {DateTime.UtcNow}");

                return Json(new { success = true, message = "Request completed successfully", status = "COMPLETED" });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error completing employee request");
                return Json(new { success = false, message = "An error occurred while completing the request" });
            }
        }

        public class ProcessActionRequest
        {
            public string? ProcessId { get; set; }
            public string? Status { get; set; }
        }

        public class EmployeeRequestActionRequest
        {
            public string? RequestId { get; set; }
            public string? Status { get; set; }
        }
    }
}
