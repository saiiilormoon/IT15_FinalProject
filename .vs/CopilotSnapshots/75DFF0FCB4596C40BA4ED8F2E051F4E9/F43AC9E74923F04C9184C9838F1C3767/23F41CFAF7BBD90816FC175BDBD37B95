        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> CreateOperationalProcess([FromForm] string processName, [FromForm] string department, [FromForm] string assignedTo, [FromForm] string priority, [FromForm] string description)
        {
            try
            {
                if (string.IsNullOrWhiteSpace(processName))
                {
                    TempData["Error"] = "Process name is required";
                    return RedirectToAction("Operations");
                }

                if (string.IsNullOrWhiteSpace(department))
                {
                    TempData["Error"] = "Department is required";
                    return RedirectToAction("Operations");
                }

                if (string.IsNullOrWhiteSpace(assignedTo))
                {
                    TempData["Error"] = "Assigned to is required";
                    return RedirectToAction("Operations");
                }

                var lastProcess = await _context.OperationalProcesses
                    .OrderByDescending(p => p.ProcessId)
                    .FirstOrDefaultAsync();

                int nextNumber = 1;
                if (lastProcess != null && lastProcess.ProcessId.StartsWith("OP-"))
                {
                    if (int.TryParse(lastProcess.ProcessId.Substring(3), out int lastNumber))
                    {
                        nextNumber = lastNumber + 1;
                    }
                }

                string newProcessId = $"OP-{nextNumber:D3}";

                var operationalProcess = new OperationalProcess
                {
                    ProcessId = newProcessId,
                    Name = processName.Trim(),
                    Department = department.Trim(),
                    AssignedTo = assignedTo.Trim(),
                    Status = ProcessStatus.Pending,
                    CreatedAt = DateTime.UtcNow,
                    Notes = string.IsNullOrWhiteSpace(description) ? null : description.Trim()
                };

                _context.OperationalProcesses.Add(operationalProcess);
                await _context.SaveChangesAsync();

                TempData["Success"] = $"Process {newProcessId} created successfully!";
                _logger.LogInformation($"New operational process created: {newProcessId} - {processName}");

                return RedirectToAction("Operations");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error creating operational process");
                TempData["Error"] = "An error occurred while creating the process. Please try again.";
                return RedirectToAction("Operations");
            }
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> ApproveProcessAjax([FromBody] ProcessActionRequest request)
        {
            if (request == null || string.IsNullOrEmpty(request.ProcessId))
            {
                return Json(new { success = false, message = "Invalid request" });
            }

            try
            {
                var process = await _context.OperationalProcesses
                    .FirstOrDefaultAsync(p => p.ProcessId == request.ProcessId);

                if (process == null)
                {
                    return Json(new { success = false, message = "Process not found" });
                }

                process.Status = ProcessStatus.Approved;
                process.ApprovedAt = DateTime.UtcNow;

                _context.OperationalProcesses.Update(process);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Process {request.ProcessId} approved at {DateTime.UtcNow}");

                return Json(new { success = true, message = "Process approved successfully", status = "APPROVED" });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error approving process");
                return Json(new { success = false, message = "An error occurred while approving the process" });
            }
        }

