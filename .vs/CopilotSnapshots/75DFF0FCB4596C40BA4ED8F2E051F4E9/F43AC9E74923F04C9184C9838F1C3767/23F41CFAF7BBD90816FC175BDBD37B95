        [HttpPost]
        [ValidateAntiForgeryToken]
        [Authorize(Roles = "Admin,SuperAdmin")]
        public async Task<IActionResult> ApproveEmployeeRequestAjax([FromBody] EmployeeRequestActionRequest request)
        {
            if (request == null || string.IsNullOrEmpty(request.RequestId))
            {
                return Json(new { success = false, message = "Invalid request" });
            }

            try
            {
                if (!User.IsInRole("Admin"))
                {
                    return Json(new { success = false, message = "Only Admin can approve requests" });
                }

                var employeeRequest = await _context.EmployeeRequests
                    .FirstOrDefaultAsync(r => r.RequestId == request.RequestId);

                if (employeeRequest == null)
                {
                    return Json(new { success = false, message = "Request not found" });
                }

                var admin = await _userManager.GetUserAsync(User);

                employeeRequest.Status = RequestStatus.Approved;
                employeeRequest.ApprovedAt = DateTime.UtcNow;
                employeeRequest.ApprovedByUserId = admin?.Id;
                employeeRequest.ApprovedByName = admin?.FullName;

                _context.EmployeeRequests.Update(employeeRequest);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Employee request {request.RequestId} approved by {admin?.Email} at {DateTime.UtcNow}");

                return Json(new { success = true, message = "Request approved successfully", status = "APPROVED" });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error approving employee request");
                return Json(new { success = false, message = "An error occurred while approving the request" });
            }
        }

