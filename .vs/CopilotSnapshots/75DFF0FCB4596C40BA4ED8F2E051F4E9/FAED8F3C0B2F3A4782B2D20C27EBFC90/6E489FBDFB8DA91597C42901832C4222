@{
    ViewData["Title"] = "Operational Processing";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2>Operational Processing & Reports</h2>
            <p>Manage daily operations and generate operational reports.</p>
        </div>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <a asp-action="ApprovedAndCompleted" class="btn btn-outline-info">
                <i class="fas fa-check-double me-1"></i>Approved & Completed
            </a>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newProcessModal">
                <i class="fas fa-plus me-2"></i>New Process
            </button>
        </div>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    @{
        var allProcesses = (ViewBag.OperationalProcesses as List<CVM_FinalProject.Models.OperationalProcess>) ?? new List<CVM_FinalProject.Models.OperationalProcess>();
        var activeCount = allProcesses.Count;
        var pendingCount = allProcesses.Count(p => p.Status == CVM_FinalProject.Models.ProcessStatus.Pending);
        var approvedCount = allProcesses.Count(p => p.Status == CVM_FinalProject.Models.ProcessStatus.Approved);
        var completedThisMonth = allProcesses.Count(p => p.Status == CVM_FinalProject.Models.ProcessStatus.Completed && 
                                                          p.CompletedAt.HasValue && 
                                                          p.CompletedAt.Value.Month == DateTime.Now.Month &&
                                                          p.CompletedAt.Value.Year == DateTime.Now.Year);
    }
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="fas fa-clipboard-list"></i>
            </div>
            <h3>@pendingCount</h3>
            <p>Pending Requests</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-success">
                <i class="fas fa-check-double"></i>
            </div>
            <h3>@completedThisMonth</h3>
            <p>Completed This Month</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="fas fa-clock"></i>
            </div>
            <h3>@approvedCount</h3>
            <p>In Archive</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-info">
                <i class="fas fa-file-alt"></i>
            </div>
            <h3>@activeCount</h3>
            <p>Total Processes</p>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="quick-action-btn" data-bs-toggle="modal" data-bs-target="#newProcessModal">
            <i class="fas fa-plus-circle"></i>
            <span>New Process</span>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="quick-action-btn" data-bs-toggle="modal" data-bs-target="#generateReportModal">
            <i class="fas fa-file-export"></i>
            <span>Generate Report</span>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="quick-action-btn" onclick="filterByStatus('pending')">
            <i class="fas fa-hourglass-half"></i>
            <span>View Pending</span>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="quick-action-btn" onclick="exportData()">
            <i class="fas fa-download"></i>
            <span>Export Data</span>
        </div>
    </div>
</div>

<!-- Filter and Search -->
<div class="chart-card mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Search</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Search processes..." id="searchInput" onkeyup="filterTable()">
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Department</label>
            <select class="form-select" id="deptFilter" onchange="filterTable()">
                <option value="">All Departments</option>
                <option value="HR">Human Resources</option>
                <option value="Finance">Finance</option>
                <option value="Operations">Operations</option>
                <option value="Sales">Sales</option>
                <option value="IT">IT</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Status</label>
            <select class="form-select" id="statusFilter" onchange="filterTable()">
                <option value="">All</option>
                <option value="PENDING">Pending</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">&nbsp;</label>
            <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                <i class="fas fa-redo me-1"></i>Reset
            </button>
        </div>
    </div>
</div>

<!-- Processes Table -->
<div class="data-table">
    @Html.AntiForgeryToken()
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Operational Processes</h5>
        <span class="badge bg-primary" id="recordCount">Showing @(ViewBag.OperationalProcesses?.Count ?? 0) records</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0" id="processTable">
            <thead>
                <tr>
                    <th>Process ID</th>
                    <th>Process Name</th>
                    <th>Department</th>
                    <th>Assigned To</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (ViewBag.OperationalProcesses != null && ViewBag.OperationalProcesses.Count > 0)
                {
                    @foreach (var process in ViewBag.OperationalProcesses)
                    {
                        string statusClass = process.Status == CVM_FinalProject.Models.ProcessStatus.Pending ? "bg-warning text-dark" : 
                                           (process.Status == CVM_FinalProject.Models.ProcessStatus.Approved ? "bg-success" : "bg-secondary");
                        string statusText = process.Status == CVM_FinalProject.Models.ProcessStatus.Pending ? "PENDING" :
                                          (process.Status == CVM_FinalProject.Models.ProcessStatus.Approved ? "APPROVED" : "COMPLETED");
                        
                        <tr data-process-id="@process.ProcessId" data-status="@process.Status">
                            <td><span class="fw-semibold text-primary">#@process.ProcessId</span></td>
                            <td>@process.Name</td>
                            <td>@process.Department</td>
                            <td>@process.AssignedTo</td>
                            <td><span class="badge @statusClass">@statusText</span></td>
                            <td>@process.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <button class="btn btn-outline-primary" title="View" onclick="viewProcess('@process.ProcessId', '@process.Name', '@process.Department', '@process.AssignedTo', '@statusText', '@process.CreatedAt.ToString("MMM dd, yyyy")')"><i class="fas fa-eye"></i></button>
                                    @if (process.Status == CVM_FinalProject.Models.ProcessStatus.Pending)
                                    {
                                        <button class="btn btn-outline-secondary" title="Edit" onclick="openEditModal('@process.ProcessId', '@process.Name', '@process.Department', '@process.AssignedTo')"><i class="fas fa-edit"></i></button>
                                        <button class="btn btn-outline-success" title="Approve" onclick="approveProcess('@process.ProcessId', this)"><i class="fas fa-check"></i></button>
                                    }
                                    else if (process.Status == CVM_FinalProject.Models.ProcessStatus.Approved)
                                    {
                                        <button class="btn btn-outline-success" title="Mark Complete" onclick="completeProcess('@process.ProcessId', this)"><i class="fas fa-check-double"></i></button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-info" title="Report" onclick="generateProcessReport('@process.ProcessId')"><i class="fas fa-file-alt"></i></button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No operational processes found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-end mb-0">
            <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">Next</a></li>
        </ul>
    </nav>
</div>

<!-- View Process Modal -->
