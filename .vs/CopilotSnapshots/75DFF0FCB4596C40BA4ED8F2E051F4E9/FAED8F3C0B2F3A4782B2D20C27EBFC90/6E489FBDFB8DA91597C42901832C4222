                    <dd class="col-sm-8" id="viewStatus"></dd>

                    <dt class="col-sm-4">Date</dt>
                    <dd class="col-sm-8" id="viewDate"></dd>
                </dl>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

