@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Financial Reports";
}

<!-- Dashboard Header -->
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1">Financial Reports & Analytics</h1>
            <p class="text-muted mb-0">Generate, view, and export detailed financial reports</p>
        </div>
        <button type="button" class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#customReportModal">
            <i class="fas fa-plus-circle me-2"></i>Generate Custom Report
        </button>
    </div>
</div>

<!-- Report Tabs -->
<ul class="nav nav-tabs financial-tabs mb-4" id="reportTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary-report" type="button" role="tab">
            <i class="fas fa-chart-bar me-2"></i>Budget Summary
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="department-tab" data-bs-toggle="tab" data-bs-target="#department-report" type="button" role="tab">
            <i class="fas fa-building me-2"></i>Department Spending
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly-report" type="button" role="tab">
            <i class="fas fa-calendar me-2"></i>Monthly Analysis
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="forecast-tab" data-bs-toggle="tab" data-bs-target="#forecast-report" type="button" role="tab">
            <i class="fas fa-crystal-ball me-2"></i>Forecast
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="variance-tab" data-bs-toggle="tab" data-bs-target="#variance-report" type="button" role="tab">
            <i class="fas fa-chart-line me-2"></i>Variance Analysis
        </button>
    </li>
</ul>

<!-- Tab Content -->
<div class="tab-content" id="reportTabContent">
    <!-- Budget Summary Report -->
    <div class="tab-pane fade show active" id="summary-report" role="tabpanel">
        <div class="row mb-3">
            <div class="col-12">
                <div class="chart-card">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5>Budget Summary Report</h5>
                        <button class="btn btn-sm btn-outline-primary">
                            <i class="fas fa-download"></i> Export
                        </button>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Department</th>
                                    <th>Allocated Budget</th>
                                    <th>Spent Amount</th>
                                    <th>Remaining</th>
                                    <th>% Utilized</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td><strong>Operations</strong></td>
                                    <td>? 80,00,000</td>
                                    <td>? 64,00,000</td>
                                    <td>? 16,00,000</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-danger" style="width: 80%">80%</div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-danger">Critical</span></td>
                                </tr>
                                <tr>
                                    <td><strong>IT</strong></td>
                                    <td>? 50,00,000</td>
                                    <td>? 32,50,000</td>
                                    <td>? 17,50,000</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-warning" style="width: 65%">65%</div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-success">Healthy</span></td>
                                </tr>
                                <tr>
                                    <td><strong>Finance</strong></td>
                                    <td>? 30,00,000</td>
                                    <td>? 25,20,000</td>
                                    <td>? 4,80,000</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-danger" style="width: 84%">84%</div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-warning text-dark">Caution</span></td>
                                </tr>
                                <tr>
                                    <td><strong>HR</strong></td>
                                    <td>? 20,00,000</?>
                                    <td>P 13,00,000</td>
                                    <td>? 7,00,000</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-success" style="width: 65%">65%</div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-success">Healthy</span></td>
                                </tr>
                                <tr>
                                    <td><strong>Marketing</strong></td>
                                    <td>? 25,00,000</td>
                                    <td>? 17,50,000</td>
                                    <td>? 7,50,000</td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-success" style="width: 70%">70%</div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-success">Healthy</span></td>
                                </tr>
                                <tr class="table-active">
                                    <td><strong>TOTAL</strong></td>
                                    <td><strong>? 2,05,00,000</strong></td>
                                    <td><strong>? 1,52,20,000</strong></td>
                                    <td><strong>? 52,80,000</strong></td>
                                    <td>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-info" style="width: 74.2%">74.2%</div>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-success">On Track</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Department Spending Report -->
    <div class="tab-pane fade" id="department-report" role="tabpanel">
        <div class="row mb-3">
            <div class="col-lg-8 mb-3">
                <div class="chart-card">
                    <h5>Department Spending Comparison</h5>
                    <div class="chart-container">
                        <canvas id="deptSpendingChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 mb-3">
                <div class="chart-card">
                    <h5>Department Distribution</h5>
                    <div class="chart-container-sm">
                        <canvas id="deptDistributionChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Monthly Analysis Report -->
    <div class="tab-pane fade" id="monthly-report" role="tabpanel">
        <div class="row mb-3">
            <div class="col-12">
                <div class="chart-card">
                    <h5>Monthly Budget Trend & Analysis</h5>
                    <div class="chart-container">
                        <canvas id="monthlyAnalysisChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-12">
                <div class="chart-card">
                    <h5>Month-by-Month Breakdown</h5>
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Month</th>
                                    <th>Budget</th>
                                    <th>Actual</th>
                                    <th>Variance</th>
                                    <th>% Variance</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>January</td>
                                    <td>? 20,00,000</td>
                                    <td>? 18,50,000</td>
                                    <td class="text-success">? 1,50,000</td>
                                    <td><span class="badge bg-success">-7.5%</span></td>
                                </tr>
                                <tr>
                                    <td>February</td>
                                    <td>? 20,00,000</td>
                                    <td>? 19,80,000</td>
                                    <td class="text-success">? 20,000</td>
                                    <td><span class="badge bg-success">-1%</span></td>
                                </tr>
                                <tr>
                                    <td>March</td>
                                    <td>? 20,00,000</td>
                                    <td>? 21,50,000</td>
                                    <td class="text-danger">-? 1,50,000</td>
                                    <td><span class="badge bg-danger">+7.5%</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Forecast Report -->
    <div class="tab-pane fade" id="forecast-report" role="tabpanel">
        <div class="row mb-3">
            <div class="col-12">
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>Budget Forecast Report</strong> - Based on current spending patterns and historical trends
                </div>
            </div>
        </div>
        <div class="row mb-3">
            <div class="col-12">
                <div class="chart-card">
                    <h5>Projected Budget vs Actual (Next 6 Months)</h5>
                    <div class="chart-container">
                        <canvas id="forecastChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="chart-card">
                    <h5>Year-End Projections</h5>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Department</th>
                                    <th>Original Budget</th>
                                    <th>Projected Spending</th>
                                    <th>Projected Variance</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Operations</td>
                                    <td>? 80,00,000</td>
                                    <td>? 85,00,000</td>
                                    <td class="text-danger">-? 5,00,000 (Over)</td>
                                    <td><span class="badge bg-danger">ALERT</span></td>
                                </tr>
                                <tr>
                                    <td>IT</td>
                                    <td>? 50,00,000</td>
                                    <td>? 48,50,000</td>
                                    <td class="text-success">? 1,50,000</td>
                                    <td><span class="badge bg-success">OK</span></td>
                                </tr>
                                <tr>
                                    <td>Finance</td>
                                    <td>? 30,00,000</td>
                                    <td>? 32,00,000</td>
                                    <td class="text-danger">-? 2,00,000 (Over)</td>
                                    <td><span class="badge bg-warning text-dark">MONITOR</span></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Variance Analysis -->
    <div class="tab-pane fade" id="variance-report" role="tabpanel">
        <div class="row mb-3">
            <div class="col-12">
                <div class="chart-card">
                    <h5>Budget Variance Analysis</h5>
                    <div class="chart-container">
                        <canvas id="varianceChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="chart-card">
                    <h5>Department-wise Variance</h5>
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>Department</th>
                                    <th>Budgeted</th>
                                    <th>Actual</th>
                                    <th>Variance</th>
                                    <th>% Variance</th>
                                    <th>Analysis</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Operations</td>
                                    <td>? 80,00,000</td>
                                    <td>? 64,00,000</td>
                                    <td class="text-danger">-? 16,00,000</td>
                                    <td><span class="badge bg-success">-20%</span></td>
                                    <td>Under budget - Good cost control</td>
                                </tr>
                                <tr>
                                    <td>IT</td>
                                    <td>? 50,00,000</td>
                                    <td>? 32,50,000</td>
                                    <td class="text-success">? 17,50,000</td>
                                    <td><span class="badge bg-success">-35%</span></td>
                                    <td>Significantly under - Review budget allocation</td>
                                </tr>
                                <tr>
                                    <td>Finance</td>
                                    <td>? 30,00,000</td>
                                    <td>? 25,20,000</td>
                                    <td class="text-danger">-? 4,80,000</td>
                                    <td><span class="badge bg-danger">-16%</span></td>
                                    <td>Under control but requires attention</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Custom Report Modal -->
<div class="modal fade" id="customReportModal" tabindex="-1" aria-labelledby="customReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="customReportModalLabel">Generate Custom Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Report Type</label>
                            <select class="form-select" required>
                                <option selected disabled>Select Report Type</option>
                                <option>Budget Summary</option>
                                <option>Department Spending</option>
                                <option>Monthly Analysis</option>
                                <option>Expense Tracking</option>
                                <option>Budget Forecast</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Department</label>
                            <select class="form-select">
                                <option>All Departments</option>
                                <option>Operations</option>
                                <option>IT</option>
                                <option>Finance</option>
                                <option>HR</option>
                                <option>Marketing</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Start Date</label>
                            <input type="date" class="form-control" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">End Date</label>
                            <input type="date" class="form-control" required />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Format</label>
                            <select class="form-select">
                                <option>PDF</option>
                                <option>Excel</option>
                                <option>CSV</option>
                                <option>HTML</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Send to Email</label>
                            <input type="email" class="form-control" placeholder="Optional" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary">Generate Report</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Department Spending Chart
        const deptSpendingCtx = document.getElementById('deptSpendingChart').getContext('2d');
        new Chart(deptSpendingCtx, {
            type: 'bar',
            data: {
                labels: ['Operations', 'IT', 'Finance', 'HR', 'Marketing'],
                datasets: [
                    {
                        label: 'Allocated',
                        data: [80, 50, 30, 20, 25],
                        backgroundColor: 'rgba(30, 60, 114, 0.8)'
                    },
                    {
                        label: 'Spent',
                        data: [64, 32.5, 25.2, 13, 17.5],
                        backgroundColor: 'rgba(231, 76, 60, 0.8)'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });

        // Department Distribution
        const deptDistributionCtx = document.getElementById('deptDistributionChart').getContext('2d');
        new Chart(deptDistributionCtx, {
            type: 'doughnut',
            data: {
                labels: ['Operations', 'IT', 'Finance', 'HR', 'Marketing'],
                datasets: [{
                    data: [80, 50, 30, 20, 25],
                    backgroundColor: ['#1e3c72', '#2a5298', '#3498db', '#27ae60', '#f39c12']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true
            }
        });

        // Monthly Analysis Chart
        const monthlyAnalysisCtx = document.getElementById('monthlyAnalysisChart').getContext('2d');
        new Chart(monthlyAnalysisCtx, {
            type: 'line',
            data: {
                labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                datasets: [
                    {
                        label: 'Budgeted',
                        data: [20, 20, 20, 20, 20, 20],
                        borderColor: '#1e3c72',
                        backgroundColor: 'rgba(30, 60, 114, 0.1)',
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: 'Actual',
                        data: [18.5, 19.8, 21.5, 22, 21, 20.2],
                        borderColor: '#e74c3c',
                        backgroundColor: 'rgba(231, 76, 60, 0.1)',
                        tension: 0.4,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false
            }
        });

        // Forecast Chart
        const forecastCtx = document.getElementById('forecastChart').getContext('2d');
        new Chart(forecastCtx, {
            type: 'line',
            data: {
                labels: ['Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep'],
                datasets: [
                    {
                        label: 'Budget',
                        data: [20, 20, 20, 20, 20, 20],
                        borderColor: '#2a5298',
                        tension: 0.4
                    },
                    {
                        label: 'Projected',
                        data: [21, 21.5, 22, 22.5, 23, 23.5],
                        borderColor: '#e74c3c',
                        borderDash: [5, 5],
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false
            }
        });

        // Variance Chart
        const varianceCtx = document.getElementById('varianceChart').getContext('2d');
        new Chart(varianceCtx, {
            type: 'bar',
            data: {
                labels: ['Operations', 'IT', 'Finance', 'HR', 'Marketing'],
                datasets: [{
                    label: 'Variance (?)',
                    data: [-16, -17.5, -4.8, -7, -7.5],
                    backgroundColor: data => data.raw < 0 ? 'rgba(46, 204, 113, 0.8)' : 'rgba(231, 76, 60, 0.8)'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        });
    </script>
}
