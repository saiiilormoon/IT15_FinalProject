<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CVM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <link href="@Url.Content("~/css/kpi-dashboard.css")" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary-dark: #1e3c72;
            --primary-light: #2a5298;
            --sidebar-width: 260px;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f0f4f8;
            min-height: 100vh;
        }
        
        /* Sidebar Styles */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: linear-gradient(180deg, var(--primary-dark) 0%, var(--primary-light) 100%);
            padding: 20px 0;
            z-index: 1000;
            overflow-y: auto;
            transition: transform 0.3s ease;
        }
        
        .sidebar-brand {
            padding: 15px 20px;
            text-align: center;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 15px;
        }

        .sidebar-brand-logo {
            width: 85px; 
            height: 85px; 
            margin: 0 auto 12px;
            padding: 0;
            background: rgba(255,255,255,0.06);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid rgba(255,255,255,0.18);
            transition: transform 0.25s ease, border-color 0.25s ease, background 0.25s ease;
            overflow: hidden;
        }

        .sidebar-brand-logo .logo-box {
            width: 64px;
            height: 64px;
            background: #ffffff;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 6px;
            box-shadow: inset 0 1px 0 rgba(0,0,0,0.02);
            transition: transform 0.25s ease;
        }

            .sidebar-brand-logo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            }

        .sidebar-brand-logo:hover {
            transform: scale(1.08);
            border-color: rgba(255,255,255,0.4);
            background: rgba(255,255,255,0.09);
        }

        .sidebar-brand-logo:hover .logo-box,
        .sidebar-brand-logo:hover img {
            transform: scale(1.08);
        }
        
        .sidebar-brand h5 {
            color: white;
            font-weight: 700;
            margin: 5px 0 0 0;
            font-size: 1rem;
        }
        
        .sidebar-brand small {
            color: rgba(255,255,255,0.7);
            font-size: 0.7rem;
        }
        
        .sidebar-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .sidebar-menu li {
            margin: 3px 12px;
        }
        
        .sidebar-menu a {
            display: flex;
            align-items: center;
            padding: 10px 15px;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
            font-weight: 500;
            font-size: 0.9rem;
        }
        
        .sidebar-menu a:hover,
        .sidebar-menu a.active {
            background: rgba(255,255,255,0.15);
            color: white;
        }
        
        .sidebar-menu a i {
            width: 22px;
            margin-right: 10px;
            font-size: 1rem;
        }
        
        .menu-divider {
            border-top: 1px solid rgba(255,255,255,0.1);
            margin: 15px 12px;
        }
        
        .menu-label {
            padding: 8px 20px;
            color: rgba(255,255,255,0.5);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
        }
        
        /* Main Content Styles */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
            transition: margin-left 0.3s ease;
        }
        
        /* Top Navbar */
        .top-navbar {
            background: white;
            padding: 12px 25px;
            box-shadow: 0 2px 15px rgba(0,0,0,0.08);
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 999;
        }
        
        .mobile-toggle {
            display: none;
            background: none;
            border: none;
            font-size: 1.3rem;
            color: var(--primary-dark);
            cursor: pointer;
            padding: 5px;
        }
        
        .navbar-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .navbar-search {
            position: relative;
            width: 280px;
        }
        
        .navbar-search input {
            width: 100%;
            padding: 8px 12px 8px 35px;
            border: 2px solid #e1e5eb;
            border-radius: 8px;
            outline: none;
            transition: all 0.3s ease;
            font-size: 0.9rem;
        }
        
        .navbar-search input:focus {
            border-color: var(--primary-light);
        }
        
        .navbar-search i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #999;
            font-size: 0.9rem;
        }
        
        .navbar-user {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .notification-btn {
            position: relative;
            background: none;
            border: none;
            font-size: 1.1rem;
            color: #666;
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        
        .notification-btn:hover {
            background: #f0f4f8;
            color: var(--primary-dark);
        }
        
        .notification-badge {
            position: absolute;
            top: 2px;
            right: 2px;
            width: 16px;
            height: 16px;
            background: #e74c3c;
            color: white;
            font-size: 0.65rem;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .user-dropdown {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            padding: 6px 12px;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        
        .user-dropdown:hover {
            background: #f0f4f8;
        }
        
        .user-avatar {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--primary-dark), var(--primary-light));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 0.9rem;
        }
        
        .user-info h6 {
            margin: 0;
            font-size: 0.85rem;
            color: #333;
        }
        
        .user-info small {
            color: #999;
            font-size: 0.7rem;
        }
        
        /* Page Content */
        .page-content {
            padding: 25px;
        }
        
        .page-header {
            margin-bottom: 25px;
        }
        
        .page-header h2 {
            color: var(--primary-dark);
            font-weight: 700;
            margin-bottom: 5px;
            font-size: 1.5rem;
        }
        
        .page-header p {
            color: #666;
            margin: 0;
            font-size: 0.9rem;
        }
        
        /* Stat Cards */
        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
            border: none;
            height: 100%;
            cursor: pointer;
        }
        
        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
        }
        
        .stat-card .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            color: white;
            margin-bottom: 12px;
        }
        
        .stat-card .stat-icon.bg-primary {
            background: linear-gradient(135deg, var(--primary-dark), var(--primary-light));
        }
        
        .stat-card .stat-icon.bg-success {
            background: linear-gradient(135deg, #1d976c, #27ae60);
        }
        
        .stat-card .stat-icon.bg-warning {
            background: linear-gradient(135deg, #f39c12, #e74c3c);
        }
        
        .stat-card .stat-icon.bg-info {
            background: linear-gradient(135deg, #3498db, #2980b9);
        }
        
        .stat-card .stat-icon.bg-purple {
            background: linear-gradient(135deg, #8e44ad, #9b59b6);
        }
        
        .stat-card h3 {
            font-size: 1.6rem;
            font-weight: 700;
            color: #333;
            margin-bottom: 3px;
        }
        
        .stat-card p {
            color: #666;
            margin: 0;
            font-size: 0.85rem;
        }
        
        .stat-card .stat-change {
            font-size: 0.75rem;
            margin-top: 8px;
        }
        
        .stat-card .stat-change.positive { color: #27ae60; }
        .stat-card .stat-change.negative { color: #e74c3c; }
        
        /* Chart Cards */
        .chart-card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.05);
            height: 100%;
        }
        
        .chart-card h5 {
            color: var(--primary-dark);
            font-weight: 600;
            margin-bottom: 15px;
            font-size: 1rem;
        }
        
        /* Chart container with fixed height */
        .chart-container {
            position: relative;
            height: 220px;
            width: 100%;
        }
        
        .chart-container-sm {
            position: relative;
            height: 180px;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .chart-container canvas,
        .chart-container-sm canvas {
            max-width: 100%;
            max-height: 100%;
        }
        
        /* Data Table */
        .data-table {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 3px 15px rgba(0,0,0,0.05);
        }
        
        .data-table h5 {
            color: var(--primary-dark);
            font-weight: 600;
            margin-bottom: 15px;
            font-size: 1rem;
        }
        
        .table th {
            background: #f8f9fa;
            color: var(--primary-dark);
            font-weight: 600;
            border: none;
            padding: 12px;
            font-size: 0.85rem;
        }
        
        .table td {
            padding: 12px;
            vertical-align: middle;
            border-color: #f0f0f0;
            font-size: 0.85rem;
        }
        
        .badge-status {
            padding: 5px 10px;
            border-radius: 15px;
            font-size: 0.7rem;
            font-weight: 500;
        }
        
        /* Activity List */
        .activity-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .activity-item {
            display: flex;
            align-items: flex-start;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
        }
        
        .activity-item:last-child { border-bottom: none; }
        
        .activity-icon {
            width: 35px;
            height: 35px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            font-size: 0.8rem;
        }
        
        .activity-content h6 {
            margin: 0 0 3px 0;
            font-size: 0.85rem;
            color: #333;
        }
        
        .activity-content small {
            color: #999;
            font-size: 0.75rem;
        }
        
        /* Quick Action Buttons */
        .quick-action-btn {
            background: white;
            border: 2px solid #e1e5eb;
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            transition: all 0.3s ease;
            cursor: pointer;
            text-decoration: none;
            color: #333;
            display: block;
        }
        
        .quick-action-btn:hover {
            border-color: var(--primary-light);
            background: rgba(42,82,152,0.05);
            transform: translateY(-2px);
            color: var(--primary-dark);
        }
        
        .quick-action-btn i {
            font-size: 1.5rem;
            color: var(--primary-light);
            margin-bottom: 8px;
            display: block;
        }
        
        .quick-action-btn span {
            font-size: 0.8rem;
            font-weight: 600;
        }
        
        /* Overlay for mobile */
        .sidebar-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 999;
        }
        
        /* Modal Blur Background */
        .modal-backdrop {
            background: rgba(30, 60, 114, 0.3) !important;
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }
        
        .modal-backdrop.show {
            opacity: 1 !important;
        }
        
        .modal-content {
            border: none;
            border-radius: 16px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.25);
            animation: modalSlideIn 0.3s ease;
        }
        
        @@keyframes modalSlideIn {
            from {
                opacity: 0;
                transform: translateY(-20px) scale(0.95);
            }
            to {
                opacity: 1;
                transform: translateY(0) scale(1);
            }
        }
        
        .modal-header {
            border-bottom: 1px solid #e9ecef;
            padding: 20px 24px;
        }
        
        .modal-body {
            padding: 24px;
        }
        
        .modal-footer {
            border-top: 1px solid #e9ecef;
            padding: 16px 24px;
        }
        
        .modal-title {
            font-weight: 600;
            color: var(--primary-dark);
        }
        
        .btn-close:focus {
            box-shadow: none;
        }

        /* Sidebar KPI Styles */
        .sidebar-kpi {
            background: rgba(255, 255, 255, 0.08);
            border-radius: 8px;
            padding: 8px 12px;
            margin-top: 8px;
            border-left: 3px solid rgba(255, 255, 255, 0.3);
            transition: all 0.3s ease;
        }

        .sidebar-menu li:hover .sidebar-kpi {
            background: rgba(255, 255, 255, 0.12);
            border-left-color: rgba(255, 255, 255, 0.6);
        }

        .kpi-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.75rem;
        }

        .kpi-label {
            font-weight: 600;
            color: rgba(255, 255, 255, 0.7);
            text-transform: capitalize;
        }

        .kpi-value {
            font-weight: 700;
            color: #ffffff;
            font-size: 0.85rem;
            padding: 2px 6px;
            background: rgba(255, 255, 255, 0.15);
            border-radius: 4px;
            min-width: 35px;
            text-align: center;
        }

        .kpi-badge {
            background: #ff6b6b;
            color: white !important;
            border-radius: 12px;
            padding: 3px 8px !important;
            font-weight: 700;
            display: inline-block;
        }

        .kpi-badge.zero {
            background: rgba(255, 255, 255, 0.2) !important;
            color: rgba(255, 255, 255, 0.8) !important;
        }
        
        /* Responsive */
        @@media (max-width: 991px) {
            .sidebar {
                transform: translateX(-100%);
            }
            
            .sidebar.active {
                transform: translateX(0);
            }
            
            .sidebar-overlay.active {
                display: block;
            }
            
            .main-content {
                margin-left: 0;
            }
            
            .mobile-toggle {
                display: block;
            }
            
            .navbar-search {
                display: none;
            }
            
            .user-info {
                display: none;
            }
            
            .page-content {
                padding: 15px;
            }
        }
        
        @@media (max-width: 576px) {
            .stat-card {
                padding: 15px;
            }
            
            .stat-card h3 {
                font-size: 1.3rem;
            }
            
            .page-header h2 {
                font-size: 1.2rem;
            }
        }
    </style>
</head>
<body>

    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="sidebar-brand-logo">
                <img src="@(Url.Content("~/images/logo_MIS.png"))" alt="CVM Logo" />
            </div>
            <h5 class="mb-0">CVM</h5>
            <small>Centralized Organizational Management Information System</small>
        </div>
 
        
        <div class="menu-label">Main Menu</div>
        <ul class="sidebar-menu">
            <li>
                <a href="@Url.Action("Index", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")">
                    <i class="fas fa-tachometer-alt"></i>
                    Dashboard
                </a>
            </li>
        </ul>
        
        @{
            var userRole = ViewBag.UserRole as string ?? "Employee";
            var isAdmin = userRole == "Admin" || userRole == "SuperAdmin";
            var isAccountant = userRole == "Accountant" && !isAdmin; // Accountant WITHOUT Admin role
            var isHR = userRole == "HR" && !isAdmin; // HR WITHOUT Admin role
            var isAuditor = userRole == "Auditor" && !isAdmin; // Auditor WITHOUT Admin role
            var isEmployee = userRole == "Employee" && !isAdmin; // Employee WITHOUT Admin role
        }
        
        <div class="menu-divider"></div>
        <div class="menu-label">Processing & Reports</div>
        <ul class="sidebar-menu">
            @* Operations - Only Admin and HR can see *@
            @if (isAdmin || isHR)
            {
                <li>
                    <a href="@Url.Action("Operations", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Operations" ? "active" : "")">
                        <i class="fas fa-clipboard-list"></i>
                        Operational Processing
                    </a>
                </li>
            }
            @* Employee Requests - Only Employees can submit *@
            @if (isEmployee)
            {
                <li>
                    <a href="@Url.Action("EmployeeRequests", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "EmployeeRequests" ? "active" : "")">
                        <i class="fas fa-file-alt"></i>
                        Employee Requests
                    </a>
                </li>
            }
            @* Reports - Admin and HR can view (Accountant CANNOT generate reports, read-only) *@
            @if (isAdmin || isHR)
            {
                <li>
                    <a href="@Url.Action("Reports", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Reports" ? "active" : "")">
                        <i class="fas fa-building"></i>
                        Departmental Reports
                    </a>
                </li>
            }
        </ul>
        
        @if (isAdmin)
        {
            <div class="menu-divider"></div>
            <div class="menu-label">Monitoring & Analytics</div>
            <ul class="sidebar-menu">
                @* Performance - Only Admin and HR can record *@
                @if (isAdmin || isHR)
                {
                    <li>
                        <a href="@Url.Action("Performance", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Performance" ? "active" : "")">
                            <i class="fas fa-chart-line"></i>
                            Performance Monitoring
                        </a>
                    </li>
                }
                @* Budget - Only Admin can view/manage *@
                @if (isAdmin)
                {
                    <li>
                        <a href="@Url.Action("Budget", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Budget" ? "active" : "")">
                            <i class="fas fa-coins"></i>
                            Budget Monitoring
                        </a>
                    </li>
                }
                @* Reports & Analytics - Only Admin can access *@
                @if (isAdmin)
                {
                    <li>
                        <a href="@Url.Action("Dashboard", "Reporting")" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Reporting" ? "active" : "")">
                            <i class="fas fa-chart-bar"></i>
                            Reports & Analytics
                        </a>
                    </li>
                }
            </ul>

            @* SuperAdmin-Only: Department Dashboards for Monitoring *@
            @if (userRole == "SuperAdmin")
            {
                <div class="menu-divider"></div>
                <div class="menu-label">Department Monitoring</div>
                <ul class="sidebar-menu">
                    <li>
                        <a href="@Url.Action("HRDashboard", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "HRDashboard" ? "active" : "")">
                            <i class="fas fa-users"></i>
                            HR Dashboard
                        </a>
                        @{
                            var empCount = ViewBag.TotalEmployees ?? 0;
                        }
                        @if (empCount > 0)
                        {
                            <div class="sidebar-kpi">
                                <div class="kpi-item">
                                    <span class="kpi-label">Employees</span>
                                    <span class="kpi-value">@empCount</span>
                                </div>
                            </div>
                        }
                    </li>
                    <li>
                        <a href="@Url.Action("AccountantDashboard", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AccountantDashboard" ? "active" : "")">
                            <i class="fas fa-chart-pie"></i>
                            Finance Dashboard
                        </a>
                        @{
                            var budgetRate = ViewBag.BudgetUtilizationRate;
                        }
                        @if (budgetRate != null && budgetRate > 0)
                        {
                            <div class="sidebar-kpi">
                                <div class="kpi-item">
                                    <span class="kpi-label">Budget Used</span>
                                    <span class="kpi-value">@budgetRate.ToString("F1")%</span>
                                </div>
                            </div>
                        }
                    </li>
                    <li>
                        <a href="@Url.Action("AuditorDashboard", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AuditorDashboard" ? "active" : "")">
                            <i class="fas fa-shield-alt"></i>
                            Audit Dashboard
                        </a>
                        @{
                            var auditCount = ViewBag.TotalAuditLogs ?? 0;
                        }
                        @if (auditCount > 0)
                        {
                            <div class="sidebar-kpi">
                                <div class="kpi-item">
                                    <span class="kpi-label">Audit Logs</span>
                                    <span class="kpi-value">@auditCount</span>
                                </div>
                            </div>
                        }
                    </li>
                </ul>
            }
        }

        @* Accountant-Specific Menu Section *@
        @if (isAccountant)
        {
            <div class="menu-divider"></div>
            <div class="menu-label">Financial Management</div>
            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("AccountantDashboard", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AccountantDashboard" ? "active" : "")">
                        <i class="fas fa-chart-pie"></i>
                        Finance Dashboard
                    </a>
                    @{
                        var acctBudgetRate = ViewBag.BudgetUtilizationRate;
                    }
                    @if (acctBudgetRate != null && acctBudgetRate > 0)
                    {
                        <!-- Finance Dashboard KPI -->
                        <div class="sidebar-kpi">
                            <div class="kpi-item">
                                <span class="kpi-label">Budget Used</span>
                                <span class="kpi-value">@acctBudgetRate.ToString("F1")%</span>
                            </div>
                        </div>
                    }
                </li>
                <li>
                    <a href="@Url.Action("ExpenseTracking", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ExpenseTracking" ? "active" : "")">
                        <i class="fas fa-receipt"></i>
                        Expense Tracking
                    </a>
                    <!-- Expense Tracking KPI -->
                    @{
                        var pendingExpenses = ViewBag.PendingExpenses ?? 0;
                    }
                    @if (pendingExpenses > 0)
                    {
                        <div class="sidebar-kpi">
                            <div class="kpi-item">
                                <span class="kpi-label">Pending</span>
                                <span class="kpi-value kpi-badge">@pendingExpenses</span>
                            </div>
                        </div>
                    }
                </li>
                <li>
                    <a href="@Url.Action("FinancialReports", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "FinancialReports" ? "active" : "")">
                        <i class="fas fa-file-invoice-dollar"></i>
                        Financial Reports
                    </a>
                    <!-- Financial Reports KPI -->
                    @{
                        var deptCount = ViewBag.DepartmentCount ?? 0;
                    }
                    @if (deptCount > 0)
                    {
                        <div class="sidebar-kpi">
                            <div class="kpi-item">
                                <span class="kpi-label">Total Depts</span>
                                <span class="kpi-value">@deptCount</span>
                            </div>
                        </div>
                    }
                </li>
            </ul>
        }
        
        @if (isAdmin)
        {
            <div class="menu-divider"></div>
            <div class="menu-label">Administration</div>
            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("Users", "Admin")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Users" ? "active" : "")">
                        <i class="fas fa-users-cog"></i>
                        Manage Users
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("PendingApprovals", "Admin")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "PendingApprovals" ? "active" : "")">
                        <i class="fas fa-user-clock"></i>
                        Pending Approvals
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("EmployeeRequests", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "EmployeeRequests" ? "active" : "")">
                        <i class="fas fa-file-alt"></i>
                        Employee Requests
                    </a>
                </li>
                @if (userRole == "SuperAdmin")
                {
                    <li>
                        <a href="@Url.Action("ArchivedUsers", "Admin")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "ArchivedUsers" ? "active" : "")">
                            <i class="fas fa-archive"></i>
                            Archived Users
                        </a>
                    </li>
                }
                <li>
                    <a href="@Url.Action("Logs", "Admin")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Logs" ? "active" : "")">
                        <i class="fas fa-history"></i>
                        System Logs
                    </a>
                </li>
            </ul>
        }

        @* HR-Specific Menu Section *@
        @if (isHR)
        {
            <div class="menu-divider"></div>
            <div class="menu-label">HR Management</div>
            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("HRDashboard", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "HRDashboard" ? "active" : "")">
                        <i class="fas fa-users"></i>
                        HR Dashboard
                    </a>
                    <!-- HR Dashboard KPI -->
                    <div class="sidebar-kpi">
                        <div class="kpi-item">
                            <span class="kpi-label">Employees</span>
                            <span class="kpi-value">@ViewBag.TotalEmployees ?? 0</span>
                        </div>
                    </div>
                </li>
                <li>
                    <a href="@Url.Action("Employees", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Employees" ? "active" : "")">
                        <i class="fas fa-address-card"></i>
                        Employee Directory
                    </a>
                </li>
                <li>
                    <a href="@Url.Action("Departments", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Departments" ? "active" : "")">
                        <i class="fas fa-sitemap"></i>
                        Department Management
                    </a>
                </li>
            </ul>
        }

        @* Auditor-Specific Menu Section *@
        @if (isAuditor)
        {
            <div class="menu-divider"></div>
            <div class="menu-label">Compliance & Audit</div>
            <ul class="sidebar-menu">
                <li>
                    <a href="@Url.Action("AuditorDashboard", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "AuditorDashboard" ? "active" : "")">
                        <i class="fas fa-shield-alt"></i>
                        Audit Dashboard
                    </a>
                    <!-- Audit Dashboard KPI -->
                    <div class="sidebar-kpi">
                        <div class="kpi-item">
                            <span class="kpi-label">Audit Logs</span>
                            <span class="kpi-value">@ViewBag.TotalAuditLogs ?? 0</span>
                        </div>
                    </div>
                </li>
                <li>
                    <a href="#" onclick="document.getElementById('exportAuditModal').click();">
                        <i class="fas fa-download"></i>
                        Export Logs
                    </a>
                </li>
            </ul>
        }
        
        <div class="menu-divider"></div>
        <div class="menu-label">Account</div>
        <ul class="sidebar-menu">
            <li>
                <a href="@Url.Action("Settings", "Dashboard")" class="@(ViewContext.RouteData.Values["action"]?.ToString() == "Settings" ? "active" : "")">
                    <i class="fas fa-user-cog"></i>
                    My Account
                </a>
            </li>
            <li>
                <form asp-area="Identity" asp-page="/Account/Logout" method="post" id="logoutForm">
                    <a href="javascript:document.getElementById('logoutForm').submit();">
                        <i class="fas fa-sign-out-alt"></i>
                        Logout
                    </a>
                </form>
            </li>
        </ul>
    </nav>

    <!-- Main Content -->
    <div class="main-content">
        <!-- Top Navbar -->
        <div class="top-navbar">
            <div class="navbar-left">
                <button class="mobile-toggle" onclick="toggleSidebar()">
                    <i class="fas fa-bars"></i>
                </button>
                <div class="navbar-search">
                    <i class="fas fa-search"></i>
                    <input type="text" placeholder="Search reports, employees..." />
                </div>
            </div>
            
            <div class="navbar-user">
                <button class="notification-btn" title="Notifications">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                </button>
                
                <div class="dropdown">
                    <div class="user-dropdown" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="user-avatar">
                            @{
                                var displayName = ViewBag.UserName as string ?? "User";
                                var displayRole = ViewBag.UserRole as string ?? "Employee";
                                var initial = !string.IsNullOrEmpty(displayName) ? displayName[0].ToString().ToUpper() : "U";
                            }
                            @initial
                        </div>
                        <div class="user-info">
                            <h6>@displayName</h6>
                            <small>@displayRole</small>
                        </div>
                        <i class="fas fa-chevron-down ms-1 text-muted" style="font-size: 0.7rem;"></i>
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end shadow">
                        <li><h6 class="dropdown-header">@ViewBag.UserEmail</h6></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="@Url.Action("Settings", "Dashboard")"><i class="fas fa-user me-2"></i>My Profile</a></li>
                        <li><a class="dropdown-item" href="@Url.Action("Settings", "Dashboard")"><i class="fas fa-cog me-2"></i>Settings</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                                <button type="submit" class="dropdown-item text-danger"><i class="fas fa-sign-out-alt me-2"></i>Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
        
        <!-- Page Content -->
        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('active');
            document.getElementById('sidebarOverlay').classList.toggle('active');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
