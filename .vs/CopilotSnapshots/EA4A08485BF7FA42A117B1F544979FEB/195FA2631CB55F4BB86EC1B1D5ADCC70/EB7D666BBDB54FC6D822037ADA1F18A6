using CVM_FinalProject.Data;
using CVM_FinalProject.Models;
using CVM_FinalProject.Models.ViewModels;
using Microsoft.EntityFrameworkCore;

namespace CVM_FinalProject.Services
{
    /// <summary>
    /// Service for managing performance records
    /// </summary>
    public class PerformanceService
    {
        private readonly ApplicationDbContext _context;
        private readonly ILogger<PerformanceService> _logger;

        public PerformanceService(ApplicationDbContext context, ILogger<PerformanceService> logger)
        {
            _context = context;
            _logger = logger;
        }

        // Record performance evaluation with task metrics and rating
        public async Task<PerformanceRecord> RecordPerformanceAsync(
            string employeeId, 
            string evaluationPeriod, 
            int tasksCompleted, 
            int tasksPending, 
            int performanceRating,
            string? remarks = null)
        {
            try
            {
                // Verify employee exists
                var employee = await _context.Employees
                    .Include(e => e.Department)
                    .FirstOrDefaultAsync(e => e.UserId == employeeId);
                
                if (employee == null)
                    throw new InvalidOperationException("Employee not found");

                var record = new PerformanceRecord
                {
                    EmployeeId = employeeId,
                    EvaluationPeriod = evaluationPeriod,
                    TasksCompleted = tasksCompleted,
                    TasksPending = tasksPending,
                    PerformanceRating = performanceRating,
                    Remarks = remarks,
                    RecordedAt = DateTime.UtcNow
                };

                _context.PerformanceRecords.Add(record);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Performance record created for employee: {employeeId} | Tasks: {tasksCompleted} completed, {tasksPending} pending | Rating: {performanceRating}/5");
                return record;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error recording performance");
                throw;
            }
        }


        // Get comprehensive employee performance monitoring data
        public async Task<EmployeePerformanceStatsViewModel> GetEmployeePerformanceStatsAsync()
        {
            try
            {
                // Get all employees with their latest performance records
                var employees = await _context.Employees
                    .Include(e => e.User)
                    .Include(e => e.Department)
                    .Include(e => e.PerformanceRecords)
                    .ToListAsync();

                var employeePerformances = new List<EmployeePerformanceMonitorViewModel>();
                var departmentPerformances = new Dictionary<int, DepartmentPerformanceAggregateViewModel>();

                foreach (var employee in employees)
                {
                    // Get latest performance record
                    var latestRecord = employee.PerformanceRecords?
                        .OrderByDescending(p => p.RecordedAt)
                        .FirstOrDefault();

                    if (latestRecord != null)
                    {
                        // Calculate metrics
                        var totalTasks = latestRecord.TasksCompleted + latestRecord.TasksPending;
                        var taskCompletionRate = totalTasks > 0 
                            ? (latestRecord.TasksCompleted / (double)totalTasks) * 100 
                            : 0;

                        var productivityScore = CalculateProductivityScore(
                            latestRecord.TasksCompleted,
                            latestRecord.TasksPending,
                            latestRecord.PerformanceRating);

                        var performanceStatus = GetPerformanceStatus(latestRecord.PerformanceRating);

                        var empPerf = new EmployeePerformanceMonitorViewModel
                        {
                            EmployeeId = employee.UserId,
                            EmployeeName = employee.User?.FullName ?? "Unknown",
                            Department = employee.Department?.DepartmentName ?? "Unassigned",
                            Position = employee.Position ?? "N/A",
                            TasksCompleted = latestRecord.TasksCompleted,
                            TasksPending = latestRecord.TasksPending,
                            PerformanceRating = latestRecord.PerformanceRating,
                            ProductivityScore = productivityScore,
                            PerformanceStatus = performanceStatus,
                            LastEvaluationDate = latestRecord.RecordedAt,
                            LastEvaluationPeriod = latestRecord.EvaluationPeriod ?? "N/A",
                            TotalTasksAssigned = totalTasks,
                            TaskCompletionRate = taskCompletionRate,
                            RecentRemarks = employee.PerformanceRecords?
                                .OrderByDescending(p => p.RecordedAt)
                                .Take(3)
                                .Select(p => p.Remarks ?? string.Empty)
                                .Where(r => !string.IsNullOrEmpty(r))
                                .ToList() ?? new()
                        };

                        employeePerformances.Add(empPerf);

                        // Aggregate by department
                        var deptId = employee.DepartmentId;
                        if (!departmentPerformances.ContainsKey(deptId))
                        {
                            departmentPerformances[deptId] = new DepartmentPerformanceAggregateViewModel
                            {
                                DepartmentName = employee.Department?.DepartmentName ?? "Unassigned",
                                EmployeeCount = 0,
                                AverageProductivityScore = 0,
                                AverageTaskCompletionRate = 0,
                                TotalTasksCompleted = 0,
                                TotalTasksPending = 0,
                                HighPerformers = 0,
                                AveragePerformers = 0,
                                BelowAveragePerformers = 0
                            };
                        }

                        var deptPerf = departmentPerformances[deptId];
                        deptPerf.EmployeeCount++;
                        deptPerf.TotalTasksCompleted += latestRecord.TasksCompleted;
                        deptPerf.TotalTasksPending += latestRecord.TasksPending;

                        if (latestRecord.PerformanceRating >= 4)
                            deptPerf.HighPerformers++;
                        else if (latestRecord.PerformanceRating == 3)
                            deptPerf.AveragePerformers++;
                        else
                            deptPerf.BelowAveragePerformers++;
                    }
                }

                // Calculate department averages
                foreach (var deptPerf in departmentPerformances.Values)
                {
                    if (deptPerf.EmployeeCount > 0)
                    {
                        var deptEmployeePerfs = employeePerformances
                            .Where(ep => ep.Department == deptPerf.DepartmentName)
                            .ToList();

                        deptPerf.AverageProductivityScore = deptEmployeePerfs.Any() 
                            ? deptEmployeePerfs.Average(ep => ep.ProductivityScore) 
                            : 0;
                        
                        deptPerf.AverageTaskCompletionRate = deptEmployeePerfs.Any() 
                            ? deptEmployeePerfs.Average(ep => ep.TaskCompletionRate) 
                            : 0;
                    }
                }

                var evaluatedEmployees = employeePerformances.Count;
                var totalEmployees = employees.Count;

                var stats = new EmployeePerformanceStatsViewModel
                {
                    TotalEmployees = totalEmployees,
                    EmployeesEvaluated = evaluatedEmployees,
                    AverageProductivityScore = employeePerformances.Any() 
                        ? employeePerformances.Average(ep => ep.ProductivityScore) 
                        : 0,
                    AverageTaskCompletionRate = employeePerformances.Any() 
                        ? employeePerformances.Average(ep => ep.TaskCompletionRate) 
                        : 0,
                    HighPerformers = employeePerformances.Count(ep => ep.PerformanceRating >= 4),
                    AveragePerformers = employeePerformances.Count(ep => ep.PerformanceRating == 3),
                    BelowAveragePerformers = employeePerformances.Count(ep => ep.PerformanceRating < 3),
                    TotalTasksCompleted = employeePerformances.Sum(ep => ep.TasksCompleted),
                    TotalTasksPending = employeePerformances.Sum(ep => ep.TasksPending),
                    EvaluationCoverage = totalEmployees > 0 
                        ? (evaluatedEmployees / (double)totalEmployees) * 100 
                        : 0,
                    EmployeePerformances = employeePerformances.OrderByDescending(ep => ep.ProductivityScore).ToList(),
                    DepartmentPerformances = departmentPerformances.Values.ToList()
                };

                return stats;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting employee performance stats");
                throw;
            }
        }

        // Calculate productivity score
        private double CalculateProductivityScore(int tasksCompleted, int tasksPending, int performanceRating)
        {
            // Score = (CompletionRate * 50%) + (PerformanceRating * 10%)
            var totalTasks = tasksCompleted + tasksPending;
            var completionRate = totalTasks > 0 
                ? (tasksCompleted / (double)totalTasks) * 100 
                : 0;

            var ratingScore = (performanceRating / 5.0) * 100;

            return (completionRate * 0.5) + (ratingScore * 0.5);
        }

        // Get performance status based on rating
        private string GetPerformanceStatus(int rating)
        {
            return rating switch
            {
                5 => "Excellent",
                4 => "Good",
                3 => "Average",
                2 => "Below Average",
                1 => "Poor",
                _ => "Unknown"
            };
        }

        // Get employee performance for monitoring dashboard
        public async Task<EmployeePerformanceMonitorViewModel?> GetEmployeePerformanceAsync(string employeeId)
        {
            try
            {
                var employee = await _context.Employees
                    .Include(e => e.User)
                    .Include(e => e.Department)
                    .Include(e => e.PerformanceRecords)
                    .FirstOrDefaultAsync(e => e.UserId == employeeId);

                if (employee == null)
                    return null;

                var latestRecord = employee.PerformanceRecords?
                    .OrderByDescending(p => p.RecordedAt)
                    .FirstOrDefault();

                if (latestRecord == null)
                    return null;

                var totalTasks = latestRecord.TasksCompleted + latestRecord.TasksPending;
                var taskCompletionRate = totalTasks > 0 
                    ? (latestRecord.TasksCompleted / (double)totalTasks) * 100 
                    : 0;

                return new EmployeePerformanceMonitorViewModel
                {
                    EmployeeId = employee.UserId,
                    EmployeeName = employee.User?.FullName ?? "Unknown",
                    Department = employee.Department?.DepartmentName ?? "Unassigned",
                    Position = employee.Position ?? "N/A",
                    TasksCompleted = latestRecord.TasksCompleted,
                    TasksPending = latestRecord.TasksPending,
                    PerformanceRating = latestRecord.PerformanceRating,
                    ProductivityScore = CalculateProductivityScore(
                        latestRecord.TasksCompleted,
                        latestRecord.TasksPending,
                        latestRecord.PerformanceRating),
                    PerformanceStatus = GetPerformanceStatus(latestRecord.PerformanceRating),
                    LastEvaluationDate = latestRecord.RecordedAt,
                    LastEvaluationPeriod = latestRecord.EvaluationPeriod ?? "N/A",
                    TotalTasksAssigned = totalTasks,
                    TaskCompletionRate = taskCompletionRate
                };
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting employee performance");
                throw;
            }
        }

        // Get top performers
        public async Task<List<EmployeePerformanceMonitorViewModel>> GetTopPerformersAsync(int topCount = 10)
        {
            try
            {
                var stats = await GetEmployeePerformanceStatsAsync();
                return stats.EmployeePerformances
                    .OrderByDescending(ep => ep.ProductivityScore)
                    .Take(topCount)
                    .ToList();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting top performers");
                throw;
            }
        }

        // Get all performance records
        public async Task<List<PerformanceRecord>> GetAllPerformanceRecordsAsync()
        {
            try
            {
                return await _context.PerformanceRecords
                    .Include(p => p.Employee)
                    .OrderByDescending(p => p.RecordedAt)
                    .ToListAsync();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting all performance records");
                throw;
            }
        }

        // Get performance by department
        public async Task<List<DepartmentPerformanceViewModel>> GetDepartmentPerformanceAsync(int departmentId)
        {
            try
            {
                var employees = await _context.Employees
                    .Where(e => e.DepartmentId == departmentId)
                    .Include(e => e.User)
                    .Include(e => e.PerformanceRecords)
                    .ToListAsync();

                return employees.Select(e => new DepartmentPerformanceViewModel
                {
                    EmployeeName = e.User?.FullName ?? "Unknown",
                    Position = e.Position ?? "N/A",
                    TotalEvaluations = e.PerformanceRecords?.Count ?? 0,
                    LastEvaluation = e.PerformanceRecords?
                        .OrderByDescending(p => p.RecordedAt)
                        .FirstOrDefault()?.EvaluationPeriod,
                    LastRemarks = e.PerformanceRecords?
                        .OrderByDescending(p => p.RecordedAt)
                        .FirstOrDefault()?.Remarks
                }).ToList();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting department performance");
                throw;
            }
        }

        // Get performance summary for reporting
        public async Task<PerformanceSummaryViewModel> GetPerformanceSummaryAsync()
        {
            try
            {
                var totalRecords = await _context.PerformanceRecords.CountAsync();
                var recordsThisMonth = await _context.PerformanceRecords
                    .Where(p => p.RecordedAt.Month == DateTime.UtcNow.Month 
                        && p.RecordedAt.Year == DateTime.UtcNow.Year)
                    .CountAsync();

                var employeesWithRecords = await _context.Employees
                    .Include(e => e.PerformanceRecords)
                    .Where(e => e.PerformanceRecords!.Count > 0)
                    .CountAsync();

                var totalEmployees = await _context.Employees.CountAsync();

                return new PerformanceSummaryViewModel
                {
                    TotalRecords = totalRecords,
                    RecordsThisMonth = recordsThisMonth,
                    EmployeesEvaluated = employeesWithRecords,
                    TotalEmployees = totalEmployees,
                    EvaluationCoverage = totalEmployees > 0 
                        ? (employeesWithRecords / (double)totalEmployees) * 100 
                        : 0
                };
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting performance summary");
                throw;
            }
        }

        // Update performance record
        public async Task<PerformanceRecord> UpdatePerformanceAsync(int performanceId, string evaluationPeriod, string remarks)
        {
            try
            {
                var record = await _context.PerformanceRecords.FindAsync(performanceId);
                if (record == null)
                    throw new InvalidOperationException("Performance record not found");

                record.EvaluationPeriod = evaluationPeriod;
                record.Remarks = remarks;

                _context.PerformanceRecords.Update(record);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Performance record updated: {performanceId}");
                return record;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error updating performance record");
                throw;
            }
        }

        // Delete performance record
        public async Task DeletePerformanceAsync(int performanceId)
        {
            try
            {
                var record = await _context.PerformanceRecords.FindAsync(performanceId);
                if (record == null)
                    throw new InvalidOperationException("Performance record not found");

                _context.PerformanceRecords.Remove(record);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Performance record deleted: {performanceId}");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error deleting performance record");
                throw;
            }
        }
    }

    // View model for department performance
    public class DepartmentPerformanceViewModel
    {
        public string EmployeeName { get; set; } = string.Empty;
        public string Position { get; set; } = string.Empty;
        public int TotalEvaluations { get; set; }
        public string? LastEvaluation { get; set; }
        public string? LastRemarks { get; set; }
    }

    // View model for performance summary
    public class PerformanceSummaryViewModel
    {
        public int TotalRecords { get; set; }
        public int RecordsThisMonth { get; set; }
        public int EmployeesEvaluated { get; set; }
        public int TotalEmployees { get; set; }
        public double EvaluationCoverage { get; set; }
    }
}
