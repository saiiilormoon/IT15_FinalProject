@page
@model ReportsModel
@using CVM_FinalProject.Models
@using CVM_FinalProject.Services
@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var reportStats = ViewBag.ReportStats as ReportStatsViewModel;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2>Reports</h2>
            <p>Generate and view system reports</p>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#generateReportModal">
            <i class="fas fa-file-pdf me-1"></i>Generate Report
        </button>
    </div>
</div>

<!-- Report Statistics -->
@if (reportStats != null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary">
                    <i class="fas fa-file-alt"></i>
                </div>
                <h3>@reportStats.TotalReports</h3>
                <p>Total Reports</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-calendar"></i>
                </div>
                <h3>@reportStats.ReportsThisMonth</h3>
                <p>This Month</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-chart-bar"></i>
                </div>
                <h3>@reportStats.ReportsByType.Count</h3>
                <p>Report Types</p>
            </div>
        </div>
    </div>
}

<!-- Generate Report Modal -->
<div class="modal fade" id="generateReportModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Generate Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="reportForm">
                    <div class="mb-3">
                        <label class="form-label">Report Type</label>
                        <select class="form-select" id="reportType" required>
                            <option value="">-- Select Report Type --</option>
                            <option value="Operational">Operational Processing</option>
                            <option value="Departmental">Departmental</option>
                            <option value="Performance">Performance Summary</option>
                            <option value="Budget">Budget Monitoring</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department (if applicable)</label>
                        <select class="form-select" id="department">
                            <option value="">-- All Departments --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Date Range</label>
                        <div class="row">
                            <div class="col-6">
                                <input type="date" class="form-control" id="startDate">
                            </div>
                            <div class="col-6">
                                <input type="date" class="form-control" id="endDate">
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Format</label>
                        <select class="form-select" id="format">
                            <option value="pdf">PDF</option>
                            <option value="excel">Excel</option>
                            <option value="html">HTML</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="generateReport()">
                    <i class="fas fa-file-pdf me-1"></i>Generate
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Reports Table -->
<div class="row mt-4">
    <div class="col-12">
        <div class="data-table">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
                <h5 class="mb-0">Generated Reports</h5>
                <div class="d-flex gap-2 mt-2 mt-md-0">
                    <input type="text" class="form-control form-control-sm" placeholder="Search reports..." id="searchReports" style="width: 200px;">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="reportsTable">
                    <thead>
                        <tr>
                            <th>Report Type</th>
                            <th>Generated By</th>
                            <th>Generated Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var report in Model)
                            {
                                <tr>
                                    <td>
                                        <i class="fas fa-file-pdf text-danger me-2"></i>
                                        <strong>@report.ReportType</strong>
                                    </td>
                                    <td>@report.User?.FullName</td>
                                    <td>@report.GeneratedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" onclick="viewReport('@report.ReportId')">
                                            <i class="fas fa-eye"></i> View
                                        </button>
                                        <a href="#" class="btn btn-sm btn-outline-secondary">
                                            <i class="fas fa-download"></i> Download
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">
                                    <i class="fas fa-inbox me-2"></i>No reports found
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function generateReport() {
            const reportType = document.getElementById('reportType').value;
            const format = document.getElementById('format').value;
            
            if (!reportType) {
                alert('Please select a report type');
                return;
            }
            
            alert(`Generating ${reportType} report in ${format} format...`);
            bootstrap.Modal.getInstance(document.getElementById('generateReportModal')).hide();
        }

        function viewReport(id) {
            alert('Viewing report: ' + id);
        }

        function searchReports() {
            const searchInput = document.getElementById('searchReports').value.toLowerCase();
            const rows = document.querySelectorAll('#reportsTable tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchInput) ? '' : 'none';
            });
        }

        document.getElementById('searchReports')?.addEventListener('keyup', searchReports);
    </script>
}
