@model List<Employee>
@using CVM_FinalProject.Models
@{
    ViewData["Title"] = "Employee Management";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2>Employees</h2>
            <p>Manage employees and departmental assignments</p>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#assignEmployeeModal">
            <i class="fas fa-plus me-1"></i>Assign Employee
        </button>
    </div>
</div>

<!-- Assign Employee Modal -->
<div class="modal fade" id="assignEmployeeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Assign Employee to Department</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="AssignEmployee">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">User</label>
                        <select class="form-select" name="userId" required>
                            <option value="">-- Select User --</option>
                            <!-- Users will be populated from controller -->
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Department</label>
                        <select class="form-select" name="departmentId" required>
                            <option value="">-- Select Department --</option>
                            <!-- Departments will be populated from controller -->
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Position</label>
                        <input type="text" class="form-control" name="position" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Assign</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Employees Table -->
<div class="row mt-4">
    <div class="col-12">
        <div class="data-table">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Employee Name</th>
                            <th>Email</th>
                            <th>Department</th>
                            <th>Position</th>
                            <th>Status</th>
                            <th>Hire Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var emp in Model)
                            {
                                <tr>
                                    <td><strong>@emp.User?.FullName</strong></td>
                                    <td>@emp.User?.Email</td>
                                    <td>@emp.Department?.DepartmentName</td>
                                    <td>@emp.Position</td>
                                    <td>
                                        <span class="badge bg-@(emp.EmployeeStatus == "Active" ? "success" : "secondary")">
                                            @emp.EmployeeStatus
                                        </span>
                                    </td>
                                    <td>@emp.DateHired?.ToString("MMM dd, yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-inbox me-2"></i>No employees found
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // TODO: Populate users and departments dropdowns
        });
    </script>
}
