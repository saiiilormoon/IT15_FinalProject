@page
@model PerformanceModel
@using CVM_FinalProject.Models
@using CVM_FinalProject.Services
@{
    ViewData["Title"] = "Performance Monitoring";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var perfSummary = ViewBag.PerfSummary as PerformanceSummaryViewModel;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2>Performance Monitoring</h2>
            <p>Track and monitor employee performance evaluations</p>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addPerformanceModal">
            <i class="fas fa-plus me-1"></i>Record Evaluation
        </button>
    </div>
</div>

<!-- Performance Summary Cards -->
@if (perfSummary != null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-primary">
                    <i class="fas fa-chart-line"></i>
                </div>
                <h3>@perfSummary.TotalRecords</h3>
                <p>Total Records</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-success">
                    <i class="fas fa-calendar-check"></i>
                </div>
                <h3>@perfSummary.RecordsThisMonth</h3>
                <p>This Month</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-users"></i>
                </div>
                <h3>@perfSummary.EmployeesEvaluated</h3>
                <p>Evaluated</p>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon bg-warning">
                    <i class="fas fa-percentage"></i>
                </div>
                <h3>@perfSummary.EvaluationCoverage.ToString("F1")%</h3>
                <p>Coverage</p>
            </div>
        </div>
    </div>
}

<!-- Add Performance Modal -->
<div class="modal fade" id="addPerformanceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Record Performance Evaluation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="post" asp-action="RecordPerformance">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Employee</label>
                        <select class="form-select" name="employeeId" required>
                            <option value="">-- Select Employee --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Evaluation Period</label>
                        <input type="text" class="form-control" name="evaluationPeriod" placeholder="e.g., Q1 2026" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Remarks</label>
                        <textarea class="form-control" name="remarks" rows="3" placeholder="Enter performance remarks..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Record Evaluation</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Performance Records Table -->
<div class="row mt-4">
    <div class="col-12">
        <div class="data-table">
            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
                <h5 class="mb-0">Performance Records</h5>
                <div class="d-flex gap-2 mt-2 mt-md-0">
                    <input type="text" class="form-control form-control-sm" placeholder="Search..." id="searchPerformance" style="width: 200px;">
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="performanceTable">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Position</th>
                            <th>Evaluation Period</th>
                            <th>Remarks</th>
                            <th>Recorded Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var record in Model)
                            {
                                <tr>
                                    <td><strong>@record.Employee?.User?.FullName</strong></td>
                                    <td>@record.Employee?.Position</td>
                                    <td>@record.EvaluationPeriod</td>
                                    <td>
                                        <span title="@record.Remarks">
                                            @(record.Remarks?.Length > 50 ? record.Remarks.Substring(0, 50) + "..." : record.Remarks)
                                        </span>
                                    </td>
                                    <td>@record.RecordedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <button class="btn btn-sm btn-outline-primary" onclick="viewRecord('@record.PerformanceId')">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">
                                    <i class="fas fa-inbox me-2"></i>No performance records found
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function searchPerformance() {
            const searchInput = document.getElementById('searchPerformance').value.toLowerCase();
            const rows = document.querySelectorAll('#performanceTable tbody tr');
            
            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchInput) ? '' : 'none';
            });
        }

        function viewRecord(id) {
            alert('Viewing performance record: ' + id);
        }

        document.getElementById('searchPerformance')?.addEventListener('keyup', searchPerformance);
    </script>
}
