using CVM_FinalProject.Models;
using Microsoft.EntityFrameworkCore;

namespace CVM_FinalProject.Services
{
    /// <summary>
    /// Service for managing reports
    /// </summary>
    public class ReportService
    {
        private readonly ApplicationDbContext _context;
        private readonly ILogger<ReportService> _logger;

        public ReportService(ApplicationDbContext context, ILogger<ReportService> logger)
        {
            _context = context;
            _logger = logger;
        }

        // Generate operational processing report
        public async Task<Report> GenerateOperationalReportAsync(string userId, string reportData)
        {
            try
            {
                var report = new Report
                {
                    ReportType = "Operational Processing",
                    GeneratedBy = userId,
                    GeneratedAt = DateTime.UtcNow,
                    ReportData = reportData
                };

                _context.Reports.Add(report);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Operational report generated by {userId}");
                return report;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error generating operational report");
                throw;
            }
        }

        // Generate departmental report
        public async Task<Report> GenerateDepartmentalReportAsync(string userId, int departmentId, string reportData)
        {
            try
            {
                var dept = await _context.Departments.FindAsync(departmentId);
                if (dept == null)
                    throw new InvalidOperationException("Department not found");

                var report = new Report
                {
                    ReportType = $"Departmental Report - {dept.DepartmentName}",
                    GeneratedBy = userId,
                    GeneratedAt = DateTime.UtcNow,
                    ReportData = reportData
                };

                _context.Reports.Add(report);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Departmental report generated for {dept.DepartmentName}");
                return report;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error generating departmental report");
                throw;
            }
        }

        // Generate performance report
        public async Task<Report> GeneratePerformanceReportAsync(string userId, string reportData)
        {
            try
            {
                var report = new Report
                {
                    ReportType = "Performance Summary",
                    GeneratedBy = userId,
                    GeneratedAt = DateTime.UtcNow,
                    ReportData = reportData
                };

                _context.Reports.Add(report);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Performance report generated by {userId}");
                return report;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error generating performance report");
                throw;
            }
        }

        // Generate budget report
        public async Task<Report> GenerateBudgetReportAsync(string userId, string reportData)
        {
            try
            {
                var report = new Report
                {
                    ReportType = "Budget Monitoring",
                    GeneratedBy = userId,
                    GeneratedAt = DateTime.UtcNow,
                    ReportData = reportData
                };

                _context.Reports.Add(report);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Budget report generated by {userId}");
                return report;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error generating budget report");
                throw;
            }
        }

        // Get all reports
        public async Task<List<Report>> GetAllReportsAsync()
        {
            try
            {
                return await _context.Reports
                    .Include(r => r.User)
                    .OrderByDescending(r => r.GeneratedAt)
                    .ToListAsync();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting all reports");
                throw;
            }
        }

        // Get reports by type
        public async Task<List<Report>> GetReportsByTypeAsync(string reportType)
        {
            try
            {
                return await _context.Reports
                    .Where(r => r.ReportType.Contains(reportType))
                    .Include(r => r.User)
                    .OrderByDescending(r => r.GeneratedAt)
                    .ToListAsync();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting reports by type");
                throw;
            }
        }

        // Get reports by user
        public async Task<List<Report>> GetReportsByUserAsync(string userId)
        {
            try
            {
                return await _context.Reports
                    .Where(r => r.GeneratedBy == userId)
                    .Include(r => r.User)
                    .OrderByDescending(r => r.GeneratedAt)
                    .ToListAsync();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting reports by user");
                throw;
            }
        }

        // Get report statistics
        public async Task<ReportStatsViewModel> GetReportStatsAsync()
        {
            try
            {
                var totalReports = await _context.Reports.CountAsync();
                var reportsThisMonth = await _context.Reports
                    .Where(r => r.GeneratedAt.Month == DateTime.UtcNow.Month 
                        && r.GeneratedAt.Year == DateTime.UtcNow.Year)
                    .CountAsync();

                var reportsByType = await _context.Reports
                    .GroupBy(r => r.ReportType)
                    .Select(g => new ReportTypeCountViewModel
                    {
                        ReportType = g.Key,
                        Count = g.Count()
                    })
                    .ToListAsync();

                return new ReportStatsViewModel
                {
                    TotalReports = totalReports,
                    ReportsThisMonth = reportsThisMonth,
                    ReportsByType = reportsByType
                };
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error getting report stats");
                throw;
            }
        }

        // Delete report
        public async Task DeleteReportAsync(int reportId)
        {
            try
            {
                var report = await _context.Reports.FindAsync(reportId);
                if (report == null)
                    throw new InvalidOperationException("Report not found");

                _context.Reports.Remove(report);
                await _context.SaveChangesAsync();

                _logger.LogInformation($"Report deleted: {reportId}");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error deleting report");
                throw;
            }
        }
    }

    // View model for report statistics
    public class ReportStatsViewModel
    {
        public int TotalReports { get; set; }
        public int ReportsThisMonth { get; set; }
        public List<ReportTypeCountViewModel> ReportsByType { get; set; } = new();
    }

    // View model for report type count
    public class ReportTypeCountViewModel
    {
        public string ReportType { get; set; } = string.Empty;
        public int Count { get; set; }
    }
}
