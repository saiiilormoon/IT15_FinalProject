@{
    ViewData["Title"] = "Approved & Completed Processes";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2>Approved & Completed Processes</h2>
            <p>View all approved and completed operational processes.</p>
        </div>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <a asp-action="Operations" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left me-1"></i>Back to Operations
            </a>
        </div>
    </div>
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-success">
                <i class="fas fa-check-circle"></i>
            </div>
            <h3>12</h3>
            <p>Approved Processes</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-secondary">
                <i class="fas fa-check-double"></i>
            </div>
            <h3>8</h3>
            <p>Completed Processes</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-info">
                <i class="fas fa-chart-bar"></i>
            </div>
            <h3>20</h3>
            <p>Total Processed</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="fas fa-percent"></i>
            </div>
            <h3>100%</h3>
            <p>Completion Rate</p>
        </div>
    </div>
</div>

<!-- Filter and Search -->
<div class="chart-card mb-4">
    <div class="row g-3">
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Search</label>
            <div class="input-group">
                <span class="input-group-text"><i class="fas fa-search"></i></span>
                <input type="text" class="form-control" placeholder="Search processes..." id="searchInput" onkeyup="filterTable()">
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Department</label>
            <select class="form-select" id="deptFilter" onchange="filterTable()">
                <option value="">All Departments</option>
                <option value="Finance">Finance</option>
                <option value="HR">Human Resources</option>
                <option value="Operations">Operations</option>
                <option value="Sales">Sales</option>
                <option value="IT">IT</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Status</label>
            <select class="form-select" id="statusFilter" onchange="filterTable()">
                <option value="">All Status</option>
                <option value="APPROVED">APPROVED</option>
                <option value="COMPLETED">COMPLETED</option>
            </select>
        </div>
        <div class="col-md-2">
            <label class="form-label small fw-semibold">&nbsp;</label>
            <button class="btn btn-outline-secondary w-100" onclick="resetFilters()">
                <i class="fas fa-redo me-1"></i>Reset
            </button>
        </div>
    </div>
</div>

<!-- Processes Table -->
