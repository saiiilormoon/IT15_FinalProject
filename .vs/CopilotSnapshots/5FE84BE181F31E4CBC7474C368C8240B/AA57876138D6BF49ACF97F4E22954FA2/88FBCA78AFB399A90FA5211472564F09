using iTextSharp.text;
using iTextSharp.text.pdf;
using System.IO;

namespace CVM_FinalProject.Services
{
    /// <summary>
    /// Service for generating PDF files from report data
    /// </summary>
    public class PdfGeneratorService
    {
        public byte[] GeneratePdfFromText(string reportTitle, string reportContent, string generatedBy, DateTime generatedAt)
        {
            using (var memoryStream = new MemoryStream())
            {
                var document = new Document(PageSize.A4, 50, 50, 50, 50);
                var writer = PdfWriter.GetInstance(document, memoryStream);
                
                document.Open();

                // Add title
                var titleFont = FontFactory.GetFont(FontFactory.HELVETICA_BOLD, 24, BaseColor.DARK_GRAY);
                var title = new Paragraph(reportTitle, titleFont)
                {
                    Alignment = Element.ALIGN_CENTER,
                    SpacingAfter = 20f
                };
                document.Add(title);

                // Add metadata
                var metaFont = FontFactory.GetFont(FontFactory.HELVETICA, 10, BaseColor.GRAY);
                var metadata = new Paragraph($"Generated by: {generatedBy}\nGenerated at: {generatedAt:MMMM dd, yyyy hh:mm tt}", metaFont)
                {
                    SpacingAfter = 20f
                };
                document.Add(metadata);

                // Add horizontal line
                var line = new LineSeparator(1f, 100f, BaseColor.LIGHT_GRAY, Element.ALIGN_CENTER, -2f);
                document.Add(new Chunk(line));

                // Add content
                var contentFont = FontFactory.GetFont(FontFactory.COURIER, 11, BaseColor.BLACK);
                var content = new Paragraph(reportContent, contentFont)
                {
                    SpacingBefore = 20f,
                    SpacingAfter = 20f
                };
                document.Add(content);

                // Add footer
                var footerFont = FontFactory.GetFont(FontFactory.HELVETICA_OBLIQUE, 9, BaseColor.GRAY);
                document.Add(new Paragraph(" "));
                var footer = new Paragraph($"Report ID: {Guid.NewGuid()}\nThis is an automatically generated report.", footerFont)
                {
                    Alignment = Element.ALIGN_CENTER,
                    SpacingBefore = 20f
                };
                document.Add(footer);

                document.Close();
                return memoryStream.ToArray();
            }
        }

        public byte[] GeneratePdfFromHtml(string reportTitle, string htmlContent, string generatedBy, DateTime generatedAt)
        {
            using (var memoryStream = new MemoryStream())
            {
                var document = new Document(PageSize.A4, 50, 50, 50, 50);
                var writer = PdfWriter.GetInstance(document, memoryStream);
                
                document.Open();

                // Add title
                var titleFont = FontFactory.GetFont(FontFactory.HELVETICA_BOLD, 24, BaseColor.DARK_GRAY);
                var title = new Paragraph(reportTitle, titleFont)
                {
                    Alignment = Element.ALIGN_CENTER,
                    SpacingAfter = 20f
                };
                document.Add(title);

                // Add metadata
                var metaFont = FontFactory.GetFont(FontFactory.HELVETICA, 10, BaseColor.GRAY);
                var metadata = new Paragraph($"Generated by: {generatedBy}\nGenerated at: {generatedAt:MMMM dd, yyyy hh:mm tt}", metaFont)
                {
                    SpacingAfter = 20f
                };
                document.Add(metadata);

                // Add horizontal line
                var line = new LineSeparator(1f, 100f, BaseColor.LIGHT_GRAY, Element.ALIGN_CENTER, -2f);
                document.Add(new Chunk(line));

                // Add content (strip HTML tags for basic PDF generation)
                var cleanContent = System.Text.RegularExpressions.Regex.Replace(htmlContent, "<[^>]*>", "");
                var contentFont = FontFactory.GetFont(FontFactory.COURIER, 11, BaseColor.BLACK);
                var content = new Paragraph(cleanContent, contentFont)
                {
                    SpacingBefore = 20f,
                    SpacingAfter = 20f
                };
                document.Add(content);

                // Add footer
                var footerFont = FontFactory.GetFont(FontFactory.HELVETICA_OBLIQUE, 9, BaseColor.GRAY);
                document.Add(new Paragraph(" "));
                var footer = new Paragraph($"Report ID: {Guid.NewGuid()}\nThis is an automatically generated report.", footerFont)
                {
                    Alignment = Element.ALIGN_CENTER,
                    SpacingBefore = 20f
                };
                document.Add(footer);

                document.Close();
                return memoryStream.ToArray();
            }
        }
    }
}
