@model List<Report>
@using CVM_FinalProject.Models
@using CVM_FinalProject.Services
@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var reportStats = ViewBag.ReportStats as ReportStatsViewModel;
    var userName = ViewBag.UserName as string ?? "User";
    var userRole = ViewBag.UserRole as string ?? "Employee";
}

<!-- Dashboard Header -->
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1">Reports & Analytics</h1>
            <p class="text-muted mb-0">Generate, view, and export detailed system reports</p>
        </div>
        <div>
            <button class="btn btn-primary btn-lg" data-bs-toggle="modal" data-bs-target="#generateReportModal">
                <i class="fas fa-plus-circle me-2"></i>Generate Report
            </button>
        </div>
    </div>
</div>

<!-- Report Statistics Cards -->
@if (reportStats != null)
{
    <div class="row mb-4 g-3">
        <!-- Total Reports -->
        <div class="col-lg-3 col-md-6">
            <div class="stat-card financial-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-2">Total Reports</p>
                        <h3 class="mb-1">@reportStats.TotalReports</h3>
                        <small class="text-muted">All Time</small>
                    </div>
                    <div class="stat-icon bg-primary">
                        <i class="fas fa-file-alt"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- This Month -->
        <div class="col-lg-3 col-md-6">
            <div class="stat-card financial-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-2">This Month</p>
                        <h3 class="mb-1">@reportStats.ReportsThisMonth</h3>
                        <small class="text-muted">Current Period</small>
                    </div>
                    <div class="stat-icon bg-success">
                        <i class="fas fa-calendar-check"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Report Types -->
        <div class="col-lg-3 col-md-6">
            <div class="stat-card financial-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-2">Report Types</p>
                        <h3 class="mb-1">@reportStats.ReportsByType.Count</h3>
                        <small class="text-muted">Available</small>
                    </div>
                    <div class="stat-icon bg-info">
                        <i class="fas fa-chart-bar"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Report Status -->
        <div class="col-lg-3 col-md-6">
            <div class="stat-card financial-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-2">Report Status</p>
                        <h3 class="mb-1">@(reportStats.TotalReports - reportStats.ReportsThisMonth)</h3>
                        <small class="text-muted">Ready to View</small>
                    </div>
                    <div class="stat-icon bg-warning">
                        <i class="fas fa-check-double"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

<!-- Quick Actions -->
<div class="row mb-5">
    <div class="col-12">
        <div class="d-flex gap-2 flex-wrap">
            <button class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#generateReportModal">
                <i class="fas fa-plus-circle"></i>
                <span>New Report</span>
            </button>
            @{
                var quickActionRole = ViewBag.UserRole as string ?? "Employee";
                var canExport = quickActionRole == "Admin" || quickActionRole == "SuperAdmin";
            }
            @if (canExport)
            {
                <a href="#" class="financial-action-btn" onclick="exportAllReports(event)">
                    <i class="fas fa-download"></i>
                    <span>Export Reports</span>
                </a>
            }
            <a href="#" class="financial-action-btn" onclick="refreshReports(event)">
                <i class="fas fa-sync-alt"></i>
                <span>Refresh</span>
            </a>
        </div>
    </div>
</div>

<!-- Generate Report Modal -->
<div class="modal fade" id="generateReportModal" tabindex="-1" aria-labelledby="generateReportModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="generateReportModalLabel">Generate New Report</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="reportForm">
                    @Html.AntiForgeryToken()
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Report Type</label>
                            <select class="form-select" id="reportType" required>
                                <option value="">-- Select Report Type --</option>
                                <option value="Operational">Operational Processing</option>
                                <option value="Departmental">Departmental</option>
                                <option value="Performance">Performance Summary</option>
                                <option value="Budget">Budget Monitoring</option>
                                <option value="Financial">Financial Overview</option>
                                <option value="Expense">Expense Tracking</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Department (Optional)</label>
                            <select class="form-select" id="department">
                                <option value="">-- All Departments --</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Start Date</label>
                            <input type="date" class="form-control" id="startDate">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">End Date</label>
                            <input type="date" class="form-control" id="endDate">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Export Format</label>
                            <select class="form-select" id="format" required>
                                <option value="pdf">PDF</option>
                                <option value="excel">Excel (.xlsx)</option>
                                <option value="csv">CSV</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Include Details</label>
                            <div class="form-check mt-2">
                                <input class="form-check-input" type="checkbox" id="includeCharts" checked>
                                <label class="form-check-label" for="includeCharts">
                                    Include Charts
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="generateReport()">
                    <i class="fas fa-file-pdf me-1"></i>Generate Report
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-check-circle me-2"></i>
        <strong>Success!</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>
        <strong>Error!</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i>
        <strong>Warning!</strong> @TempData["Warning"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Generated Reports Table -->
<div class="row mb-4">
    <div class="col-12">
        <div class="chart-card">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
                <h5 class="mb-2 mb-md-0">Generated Reports</h5>
                <div class="d-flex gap-2 flex-wrap">
                    <input type="text" class="form-control form-control-sm" placeholder="Search reports..." id="searchReports" style="width: 250px;">
                    <select class="form-select form-select-sm" id="filterType" style="width: 150px;" onchange="filterReports()">
                        <option value="">All Types</option>
                        @if (reportStats != null && reportStats.ReportsByType.Count > 0)
                        {
                            @foreach (var type in reportStats.ReportsByType)
                            {
                                <option value="@type.ReportType">@type.ReportType</option>
                            }
                        }
                    </select>
                </div>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="reportsTable">
                    <thead>
                        <tr>
                            <th>Report Type</th>
                            <th>Generated By</th>
                            <th>Generated Date</th>
                            <th>Size</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var report in Model)
                            {
                                <tr>
                                    <td>
                                        <i class="fas fa-file-pdf text-danger me-2"></i>
                                        <strong>@report.ReportType</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark">
                                            @(report.User?.FullName ?? "System")
                                        </span>
                                    </td>
                                    <td>
                                        <small>@report.GeneratedAt.ToString("MMM dd, yyyy hh:mm tt")</small>
                                    </td>
                                    <td>
                                        @{
                                            var size = report.ReportData?.Length ?? 0;
                                            var sizeDisplay = size > 1024 ? $"{(size / 1024.0):F1} KB" : $"{size} B";
                                        }
                                        <small>@sizeDisplay</small>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button type="button" class="btn btn-outline-primary" onclick="viewReport(@report.ReportId)" title="View Report">
                                                <i class="fas fa-eye"></i> View
                                            </button>
                                            <button type="button" class="btn btn-outline-secondary" onclick="downloadReport(@report.ReportId)" title="Download Report">
                                                <i class="fas fa-download"></i> Download
                                            </button>
                                            @{
                                                var reportUserRole = ViewBag.UserRole as string ?? "Employee";
                                                var isReportAdmin = reportUserRole == "Admin" || reportUserRole == "SuperAdmin";
                                            }
                                            @if (isReportAdmin)
                                            {
                                                <button type="button" class="btn btn-outline-danger" onclick="deleteReport('@report.ReportId')" title="Delete Report">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-5">
                                    <i class="fas fa-inbox me-2" style="font-size: 1.5rem;"></i>
                                    <p class="mt-2">No reports found. Generate your first report to get started.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Report Details Modal -->
<div class="modal fade" id="reportDetailsModal" tabindex="-1" aria-labelledby="reportDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <h5 class="modal-title" id="reportDetailsTitle">Report Details</h5>
                    <small class="text-muted" id="reportDetailsGeneratedBy">Generated details will appear here</small>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <span class="badge bg-primary" id="reportDetailsId">Report ID: N/A</span>
                </div>
                <div id="reportDetailsContent" class="report-content">
                    <p class="text-muted text-center">Loading report data...</p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="reportDetailsDownloadBtn">
                    <i class="fas fa-download me-2"></i>Download Report
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Generate Report
        function generateReport() {
            const reportType = document.getElementById('reportType').value;
            const department = document.getElementById('department').value;
            const startDate = document.getElementById('startDate').value;
            const endDate = document.getElementById('endDate').value;
            const format = document.getElementById('format').value;
            const includeCharts = document.getElementById('includeCharts').checked;

            if (!reportType) {
                showAlert('Please select a report type', 'warning');
                return;
            }

            // For Departmental reports, department is required
            if (reportType === 'Departmental' && !department) {
                showAlert('Please select a department for Departmental reports', 'warning');
                return;
            }

            const formData = {
                reportType: reportType,
                department: department || '',
                startDate: startDate || '',
                endDate: endDate || '',
                format: format,
                includeCharts: includeCharts
            };

            // Show loading state
            const generateBtn = document.querySelector('[onclick="generateReport()"]');
            if (generateBtn) {
                generateBtn.disabled = true;
                generateBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Generating...';
            }

            // Get CSRF token
            const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;
            
            // Call API to generate report
            fetch('/Dashboard/GenerateReportAjax', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(formData)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                console.log('Response data:', data);
                if (data.success) {
                    showAlert('Report generated successfully!', 'success');
                    // Close modal
                    const modal = bootstrap.Modal.getInstance(document.getElementById('generateReportModal'));
                    if (modal) {
                        modal.hide();
                    }
                    // Reload after delay
                    setTimeout(() => location.reload(), 1500);
                } else {
                    showAlert(data.message || 'Failed to generate report. Please check your inputs and try again.', 'error');
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showAlert('An error occurred while generating the report: ' + error.message, 'error');
            })
            .finally(() => {
                // Restore button state
                if (generateBtn) {
                    generateBtn.disabled = false;
                    generateBtn.innerHTML = '<i class="fas fa-file-pdf me-1"></i>Generate Report';
                }
            });
        }

        // View Report - Display in Modal
        function viewReport(reportId) {
            console.log('View Report called with ID:', reportId);
            
            try {
                // Show loading state
                const modal = new bootstrap.Modal(document.getElementById('reportDetailsModal'));
                document.getElementById('reportDetailsContent').innerHTML = '<div class="text-center"><span class="spinner-border spinner-border-sm me-2"></span>Loading report...</div>';
                modal.show();
                
                // Fetch the report details
                const url = `/Dashboard/GetReportDetailsAjax/${reportId}`;
                console.log('Fetching from URL:', url);
                
                fetch(url, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json',
                        'Content-Type': 'application/json'
                    },
                    credentials: 'include'
                })
                .then(response => {
                    console.log('Response status:', response.status, response.ok);
                    
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }
                    return response.json();
                })
                .then(data => {
                    console.log('Response data:', data);
                    
                    if (data && data.success && data.report) {
                        const report = data.report;
                        
                        // Update modal content
                        document.getElementById('reportDetailsTitle').textContent = report.reportType || 'Report';
                        document.getElementById('reportDetailsId').textContent = `Report ID: ${report.reportId}`;
                        document.getElementById('reportDetailsGeneratedBy').textContent = `Generated by: ${report.generatedBy} on ${report.generatedAt}`;
                        
                        // Format and display report content with word wrapping
                        const reportContent = report.reportData || 'No content available';
                        const formattedContent = `<div style="background-color: #f8f9fa; padding: 15px; border-radius: 4px; border: 1px solid #dee2e6; overflow-x: auto; white-space: pre-wrap; word-wrap: break-word; word-break: break-word; line-height: 1.6; font-size: 13px; font-family: 'Courier New', monospace; max-height: 500px; overflow-y: auto;">${escapeHtml(reportContent)}</div>`;
                        
                        document.getElementById('reportDetailsContent').innerHTML = formattedContent;
                        
                        // Setup download button
                        const downloadBtn = document.getElementById('reportDetailsDownloadBtn');
                        if (downloadBtn) {
                            downloadBtn.onclick = function(e) {
                                e.preventDefault();
                                downloadReport(reportId);
                            };
                        }
                        
                        console.log('Modal populated successfully');
                    } else {
                        const errorMsg = data?.message || 'Failed to load report - No data returned';
                        console.error('Error:', errorMsg);
                        document.getElementById('reportDetailsContent').innerHTML = `<div class="alert alert-danger">${escapeHtml(errorMsg)}</div>`;
                        showAlert(errorMsg, 'error');
                    }
                })
                .catch(error => {
                    console.error('Fetch error:', error);
                    const errorMsg = `Failed to load report: ${error.message}`;
                    document.getElementById('reportDetailsContent').innerHTML = `<div class="alert alert-danger">${escapeHtml(errorMsg)}</div>`;
                    showAlert(errorMsg, 'error');
                });
            } catch (error) {
                console.error('Exception:', error);
                showAlert('Error opening report: ' + error.message, 'error');
            }
        }

        // Helper function to escape HTML
        function escapeHtml(text) {
            const map = {
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#039;'
            };
            return text.replace(/[&<>"']/g, m => map[m]);
        }

        // Download Report
        function downloadReport(reportId) {
            const downloadBtn = document.getElementById('reportDetailsDownloadBtn');
            if (downloadBtn) {
                downloadBtn.disabled = true;
                downloadBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Downloading...';
            }

            fetch(`/Dashboard/DownloadReport/${reportId}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error(`HTTP error! status: ${response.status}`);
                    }
                    return response.blob();
                })
                .then(blob => {
                    const url = window.URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = `report-${reportId}.pdf`;
                    document.body.appendChild(a);
                    a.click();
                    window.URL.revokeObjectURL(url);
                    a.remove();
                    showAlert('Report downloaded successfully!', 'success');
                })
                .catch(error => {
                    console.error('Error:', error);
                    showAlert('Failed to download report: ' + error.message, 'error');
                })
                .finally(() => {
                    if (downloadBtn) {
                        downloadBtn.disabled = false;
                        downloadBtn.innerHTML = '<i class="fas fa-download me-2"></i>Download Report';
                    }
                });
        }

        // Delete Report
        function deleteReport(reportId) {
            if (confirm('Are you sure you want to delete this report? This action cannot be undone.')) {
                fetch(`/Dashboard/DeleteReport/${reportId}`, {
                    method: 'DELETE',
                    headers: {
                        'X-CSRF-TOKEN': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showAlert('Report deleted successfully', 'success');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showAlert(data.message || 'Failed to delete report', 'error');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    showAlert('An error occurred while deleting the report', 'error');
                });
            }
        }

        // Export All Reports
        function exportAllReports(event) {
            event.preventDefault();
            const format = prompt('Select export format:\n1. PDF\n2. Excel\n3. CSV\n\nEnter option number:');
            if (format) {
                const formatMap = { '1': 'pdf', '2': 'excel', '3': 'csv' };
                const selectedFormat = formatMap[format];
                if (selectedFormat) {
                    window.location.href = `/Dashboard/ExportAllReports?format=${selectedFormat}`;
                } else {
                    showAlert('Invalid format selected', 'warning');
                }
            }
        }

        // Refresh Reports
        function refreshReports(event) {
            event.preventDefault();
            location.reload();
        }

        // Filter Reports
        function filterReports() {
            const filterType = document.getElementById('filterType').value;
            const rows = document.querySelectorAll('#reportsTable tbody tr');

            rows.forEach(row => {
                if (!row.querySelector('td:first-child')) return;
                
                const reportType = row.textContent;
                if (filterType === '' || reportType.includes(filterType)) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        // Search Reports
        function searchReports() {
            const searchInput = document.getElementById('searchReports').value.toLowerCase();
            const rows = document.querySelectorAll('#reportsTable tbody tr');

            rows.forEach(row => {
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(searchInput) ? '' : 'none';
            });
        }

        // Show Alert
        function showAlert(message, type = 'info') {
            const alertDiv = document.createElement('div');
            alertDiv.className = `alert alert-${type} alert-dismissible fade show`;
            alertDiv.setAttribute('role', 'alert');
            alertDiv.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            
            const container = document.querySelector('.page-header');
            if (container) {
                container.insertAdjacentElement('afterend', alertDiv);
                setTimeout(() => alertDiv.remove(), 5000);
            }
        }

        // Event listeners
        document.getElementById('searchReports')?.addEventListener('keyup', searchReports);
    </script>
}
