@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Register - CVM MIS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body class="bg-white">

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow-lg p-4" style="width:450px;">

            <div class="text-center mb-4">
                <h3>Create Account</h3>
            </div>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label>Email</label>
                    <input asp-for="Input.Email" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Password</label>
                    <input asp-for="Input.Password" type="password" class="form-control" />
                </div>

                <div class="mb-3">
                    <label>Confirm Password</label>
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" />
                </div>

                <button type="submit" class="btn btn-success w-100">
                    Register
                </button>

                <div class="text-center mt-3">
                    <a asp-page="./Login">Already have an account? Login</a>
                </div>
            </form>

        </div>
    </div>

</body>
</html>
