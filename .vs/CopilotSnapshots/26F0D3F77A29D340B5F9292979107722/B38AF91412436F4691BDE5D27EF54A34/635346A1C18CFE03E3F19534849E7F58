@{
    ViewData["Title"] = "Home Page";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome - CVM MIS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4ecf7 100%);
            min-height: 100vh;
        }
        .hero-section {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 80px 0;
            border-radius: 0 0 50px 50px;
        }
        .feature-card {
            background: white;
            border-radius: 15px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: none;
        }
        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        .feature-icon {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 28px;
        }
        .btn-primary-custom {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            border: none;
            padding: 12px 40px;
            border-radius: 30px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .btn-primary-custom:hover {
            transform: scale(1.05);
            box-shadow: 0 10px 20px rgba(30,60,114,0.3);
        }
        .btn-outline-custom {
            border: 2px solid white;
            color: white;
            padding: 12px 40px;
            border-radius: 30px;
            font-weight: 600;
            transition: all 0.3s ease;
            background: transparent;
        }
        .btn-outline-custom:hover {
            background: white;
            color: #1e3c72;
        }
        .navbar-custom {
            background: white;
            box-shadow: 0 2px 15px rgba(0,0,0,0.1);
        }
        .navbar-brand-custom {
            font-weight: 700;
            color: #1e3c72 !important;
            font-size: 1.5rem;
        }
        .footer-section {
            background: #1e3c72;
            color: white;
            padding: 30px 0;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-custom fixed-top">
        <div class="container">
            <a class="navbar-brand navbar-brand-custom d-flex align-items-center" href="/">
                <img src="~/images/logo.png" alt="CVM MIS Logo" height="45" class="me-2" />
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Privacy">Privacy</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-semibold text-primary" asp-area="Identity" asp-page="/Account/Register">Register</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link fw-semibold text-primary" asp-area="Identity" asp-page="/Account/Login">Login</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section" style="padding-top: 150px;">
        <div class="container text-center">
            <img src="~/images/logo.png" alt="CVM MIS Logo" height="150" class="mb-4" style="filter: brightness(0) invert(1);" />
            <h1 class="display-4 fw-bold mb-3">Centralized</h1>
            <p class="lead mb-5" style="font-size: 1.3rem; opacity: 0.9;">Management Information System<br/>Streamline your operations with our comprehensive management solution.</p>
            <div class="d-flex justify-content-center gap-3 flex-wrap">
                <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-outline-custom btn-lg">
                    <i class="fas fa-sign-in-alt me-2"></i>Login
                </a>
                <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-light btn-lg" style="border-radius: 30px; padding: 12px 40px; font-weight: 600; color: #1e3c72;">
                    <i class="fas fa-user-plus me-2"></i>Register
                </a>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section class="py-5" style="margin-top: 60px;">
        <div class="container">
            <div class="text-center mb-5">
                <h2 class="fw-bold" style="color: #1e3c72;">Our Features</h2>
                <p class="text-muted">Discover what makes our system powerful and efficient</p>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon">
                            <i class="fas fa-database"></i>
                        </div>
                        <h5 class="fw-bold" style="color: #1e3c72;">Centralized Data</h5>
                        <p class="text-muted">All your important data in one secure, accessible location.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h5 class="fw-bold" style="color: #1e3c72;">Analytics & Reports</h5>
                        <p class="text-muted">Generate comprehensive reports and gain valuable insights.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="feature-card text-center h-100">
                        <div class="feature-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <h5 class="fw-bold" style="color: #1e3c72;">Secure Access</h5>
                        <p class="text-muted">Role-based access control to keep your data safe.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer-section mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 CVM MIS - Centralized Management System. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
