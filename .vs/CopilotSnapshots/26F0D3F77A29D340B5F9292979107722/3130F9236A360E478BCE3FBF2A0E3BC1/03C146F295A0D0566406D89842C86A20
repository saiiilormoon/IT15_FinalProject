@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Registration Successful";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Registration Successful - CVM MIS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4ecf7 100%);
            min-height: 100vh;
        }
        .confirmation-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            border: none;
            max-width: 500px;
        }
        .success-icon {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            color: white;
            font-size: 50px;
            animation: scaleIn 0.5s ease-out;
        }
        @@keyframes scaleIn {
            0% { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
        .btn-primary-custom {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            border: none;
            border-radius: 10px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(30,60,114,0.3);
        }
        .btn-outline-custom {
            border: 2px solid #1e3c72;
            color: #1e3c72;
            border-radius: 10px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
            background: transparent;
        }
        .btn-outline-custom:hover {
            background: #1e3c72;
            color: white;
        }
        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            color: #1e3c72;
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: white;
            border-radius: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }
        .back-btn:hover {
            background: #1e3c72;
            color: white;
            transform: translateX(-5px);
        }
        .email-badge {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            padding: 8px 20px;
            border-radius: 20px;
            font-weight: 500;
            display: inline-block;
            margin: 10px 0;
        }
    </style>
</head>
<body>

    <!-- Back Button -->
    <a href="/" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Home
    </a>

    <div class="container d-flex justify-content-center align-items-center vh-100">
        <div class="card confirmation-card p-5 text-center">
            
        <img src="~/images/logo.png" alt="CVM MIS Logo" height="70" class="mb-3 mx-auto" />
            
        <div class="success-icon">
            <i class="fas fa-check"></i>
        </div>
            
            <h2 class="fw-bold mb-3" style="color: #1e3c72;">Registration Successful!</h2>
            
            <p class="text-muted mb-4">
                Congratulations! Your account has been created successfully.
            </p>

            @if (Model.DisplayConfirmAccountLink)
            {
                <div class="alert alert-info" style="background: rgba(30,60,114,0.1); border: none; border-radius: 10px;">
                    <i class="fas fa-info-circle me-2" style="color: #1e3c72;"></i>
                    <span style="color: #1e3c72;">Please confirm your email to activate your account.</span>
                </div>
                
                <div class="mb-4">
                    <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-primary-custom w-100 mb-3">
                        <i class="fas fa-envelope-open-text me-2"></i>Confirm Your Email
                    </a>
                </div>
            }
            else
            {
                <div class="alert alert-success" style="background: rgba(39,174,96,0.1); border: none; border-radius: 10px;">
                    <i class="fas fa-envelope me-2 text-success"></i>
                    <span class="text-success">A confirmation email has been sent to your inbox.</span>
                </div>
                
                <p class="text-muted small mb-4">
                    Please check your email and click the confirmation link to activate your account.
                </p>
            }

            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-page="./Login" class="btn btn-outline-custom">
                    <i class="fas fa-sign-in-alt me-2"></i>Go to Login
                </a>
                <a href="/" class="btn btn-outline-secondary" style="border-radius: 10px; padding: 12px 30px;">
                    <i class="fas fa-home me-2"></i>Back to Home
                </a>
            </div>

            <div class="mt-4 pt-4" style="border-top: 1px solid #eee;">
                <small class="text-muted">
                    <i class="fas fa-shield-alt me-1"></i>
                    Your account is secured with Centralized MIS
                </small>
            </div>

        </div>
    </div>

</body>
</html>

