@{
    ViewData["Title"] = "Budget Monitoring";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <h2>Budget Monitoring</h2>
    <p>Track and manage organizational budget allocations.</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="fas fa-coins"></i>
            </div>
            <h3>?5.2M</h3>
            <p>Total Budget</p>
            <div class="stat-change">
                <i class="fas fa-calendar me-1"></i>FY 2026
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-success">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <h3>?3.8M</h3>
            <p>Allocated</p>
            <div class="stat-change positive">
                <i class="fas fa-check me-1"></i>73% utilized
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="fas fa-hand-holding-usd"></i>
            </div>
            <h3>?1.4M</h3>
            <p>Remaining</p>
            <div class="stat-change">
                <i class="fas fa-info-circle me-1"></i>27% available
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-info">
                <i class="fas fa-clock"></i>
            </div>
            <h3>Q1</h3>
            <p>Current Quarter</p>
            <div class="stat-change positive">
                <i class="fas fa-arrow-up me-1"></i>On track
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-8">
        <div class="chart-card">
            <h5>Budget Utilization by Month</h5>
            <canvas id="budgetChart" height="120"></canvas>
        </div>
    </div>
    <div class="col-xl-4">
        <div class="chart-card">
            <h5>Budget by Department</h5>
            <canvas id="departmentBudgetChart" height="200"></canvas>
        </div>
    </div>
</div>

<div class="data-table">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Department Budget Status</h5>
        <button class="btn btn-primary btn-sm"><i class="fas fa-plus me-2"></i>New Allocation</button>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Allocated</th>
                    <th>Spent</th>
                    <th>Remaining</th>
                    <th>Utilization</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><i class="fas fa-building text-primary me-2"></i>Operations</td>
                    <td>?1,500,000</td>
                    <td>?1,200,000</td>
                    <td>?300,000</td>
                    <td>
                        <div class="progress" style="height: 8px; width: 100px;">
                            <div class="progress-bar bg-success" style="width: 80%"></div>
                        </div>
                        <small class="text-muted">80%</small>
                    </td>
                    <td><span class="badge-status bg-success text-white">On Track</span></td>
                </tr>
                <tr>
                    <td><i class="fas fa-users text-info me-2"></i>HR</td>
                    <td>?800,000</td>
                    <td>?650,000</td>
                    <td>?150,000</td>
                    <td>
                        <div class="progress" style="height: 8px; width: 100px;">
                            <div class="progress-bar bg-warning" style="width: 81%"></div>
                        </div>
                        <small class="text-muted">81%</small>
                    </td>
                    <td><span class="badge-status bg-warning text-dark">Monitor</span></td>
                </tr>
                <tr>
                    <td><i class="fas fa-calculator text-success me-2"></i>Finance</td>
                    <td>?600,000</td>
                    <td>?420,000</td>
                    <td>?180,000</td>
                    <td>
                        <div class="progress" style="height: 8px; width: 100px;">
                            <div class="progress-bar bg-success" style="width: 70%"></div>
                        </div>
                        <small class="text-muted">70%</small>
                    </td>
                    <td><span class="badge-status bg-success text-white">On Track</span></td>
                </tr>
                <tr>
                    <td><i class="fas fa-chart-line text-warning me-2"></i>Sales</td>
                    <td>?500,000</td>
                    <td>?450,000</td>
                    <td>?50,000</td>
                    <td>
                        <div class="progress" style="height: 8px; width: 100px;">
                            <div class="progress-bar bg-danger" style="width: 90%"></div>
                        </div>
                        <small class="text-muted">90%</small>
                    </td>
                    <td><span class="badge-status bg-danger text-white">Critical</span></td>
                </tr>
                <tr>
                    <td><i class="fas fa-laptop-code text-secondary me-2"></i>IT</td>
                    <td>?400,000</td>
                    <td>?280,000</td>
                    <td>?120,000</td>
                    <td>
                        <div class="progress" style="height: 8px; width: 100px;">
                            <div class="progress-bar bg-success" style="width: 70%"></div>
                        </div>
                        <small class="text-muted">70%</small>
                    </td>
                    <td><span class="badge-status bg-success text-white">On Track</span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    // Budget Utilization Chart
    const budgetCtx = document.getElementById('budgetChart').getContext('2d');
    new Chart(budgetCtx, {
        type: 'bar',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: 'Budget Allocated',
                data: [500000, 550000, 600000, 650000, 700000, 750000],
                backgroundColor: 'rgba(30, 60, 114, 0.8)',
                borderRadius: 5
            }, {
                label: 'Budget Spent',
                data: [450000, 520000, 580000, 620000, 670000, 710000],
                backgroundColor: 'rgba(39, 174, 96, 0.8)',
                borderRadius: 5
            }]
        },
        options: {
            responsive: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: function(value) {
                            return '?' + (value / 1000) + 'K';
                        }
                    }
                }
            }
        }
    });

    // Department Budget Chart
    const deptBudgetCtx = document.getElementById('departmentBudgetChart').getContext('2d');
    new Chart(deptBudgetCtx, {
        type: 'doughnut',
        data: {
            labels: ['Operations', 'HR', 'Finance', 'Sales', 'IT'],
            datasets: [{
                data: [1500000, 800000, 600000, 500000, 400000],
                backgroundColor: [
                    '#1e3c72',
                    '#2a5298',
                    '#27ae60',
                    '#f1c40f',
                    '#3498db'
                ],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    position: 'bottom'
                }
            },
            cutout: '60%'
        }
    });
</script>
}
