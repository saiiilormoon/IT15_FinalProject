@{
    ViewData["Title"] = "Reports";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <h2>Reports Center</h2>
    <p>Generate and manage organizational reports.</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="fas fa-file-alt"></i>
            </div>
            <h3>256</h3>
            <p>Total Reports</p>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-success">
                <i class="fas fa-calendar-check"></i>
            </div>
            <h3>48</h3>
            <p>This Month</p>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="fas fa-hourglass-half"></i>
            </div>
            <h3>8</h3>
            <p>Scheduled</p>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="stat-card">
            <div class="stat-icon bg-info">
                <i class="fas fa-download"></i>
            </div>
            <h3>1,204</h3>
            <p>Downloads</p>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="chart-card text-center" style="cursor: pointer;">
            <div style="font-size: 3rem; color: #1e3c72; margin-bottom: 15px;">
                <i class="fas fa-chart-bar"></i>
            </div>
            <h5>Operational Reports</h5>
            <p class="text-muted">Daily operations and process reports</p>
            <button class="btn btn-outline-primary">Generate</button>
        </div>
    </div>
    <div class="col-md-4">
        <div class="chart-card text-center" style="cursor: pointer;">
            <div style="font-size: 3rem; color: #27ae60; margin-bottom: 15px;">
                <i class="fas fa-building"></i>
            </div>
            <h5>Departmental Reports</h5>
            <p class="text-muted">Department-wise performance reports</p>
            <button class="btn btn-outline-success">Generate</button>
        </div>
    </div>
    <div class="col-md-4">
        <div class="chart-card text-center" style="cursor: pointer;">
            <div style="font-size: 3rem; color: #f39c12; margin-bottom: 15px;">
                <i class="fas fa-chart-pie"></i>
            </div>
            <h5>Summary Reports</h5>
            <p class="text-muted">Executive summary and KPI reports</p>
            <button class="btn btn-outline-warning">Generate</button>
        </div>
    </div>
</div>

<div class="data-table">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Recent Reports</h5>
        <div>
            <select class="form-select form-select-sm d-inline-block me-2" style="width: auto;">
                <option>All Departments</option>
                <option>HR</option>
                <option>Finance</option>
                <option>Operations</option>
            </select>
            <button class="btn btn-primary btn-sm"><i class="fas fa-plus me-2"></i>New Report</button>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Report Name</th>
                    <th>Type</th>
                    <th>Department</th>
                    <th>Created By</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><i class="fas fa-file-pdf text-danger me-2"></i>Q4 Financial Summary</td>
                    <td>Summary</td>
                    <td>Finance</td>
                    <td>Admin</td>
                    <td>Jan 15, 2026</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-eye"></i></button>
                        <button class="btn btn-sm btn-outline-success"><i class="fas fa-download"></i></button>
                    </td>
                </tr>
                <tr>
                    <td><i class="fas fa-file-excel text-success me-2"></i>Employee Attendance</td>
                    <td>Operational</td>
                    <td>HR</td>
                    <td>HR Manager</td>
                    <td>Jan 14, 2026</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-eye"></i></button>
                        <button class="btn btn-sm btn-outline-success"><i class="fas fa-download"></i></button>
                    </td>
                </tr>
                <tr>
                    <td><i class="fas fa-file-alt text-primary me-2"></i>Department Performance</td>
                    <td>Departmental</td>
                    <td>All</td>
                    <td>Admin</td>
                    <td>Jan 13, 2026</td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary me-1"><i class="fas fa-eye"></i></button>
                        <button class="btn btn-sm btn-outline-success"><i class="fas fa-download"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
