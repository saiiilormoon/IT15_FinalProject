        public async Task<IActionResult> ExportAllReports(string format = "pdf")
        {
            try
            {
                var user = await _userManager.GetUserAsync(User);
                if (user == null)
                {
                    return NotFound();
                }

                var reports = await _reportService.GetAllReportsAsync();

                if (format.ToLower() == "pdf")
                {
                    // Generate comprehensive PDF with all reports
                    var sb = new System.Text.StringBuilder();
                    sb.AppendLine("SYSTEM REPORTS EXPORT");
                    sb.AppendLine($"Generated: {DateTime.UtcNow:yyyy-MM-dd HH:mm:ss}");
                    sb.AppendLine($"Exported by: {user.FullName}");
                    sb.AppendLine(new string('=', 80));

                    foreach (var report in reports)
                    {
                        sb.AppendLine($"\n\n{report.ReportType} Report");
                        sb.AppendLine($"Report ID: {report.ReportId}");
                        sb.AppendLine($"Generated At: {report.GeneratedAt:yyyy-MM-dd HH:mm:ss}");
                        sb.AppendLine($"Generated By: {report.User?.FullName ?? "System"}");
                        sb.AppendLine(new string('-', 80));
                        sb.AppendLine($"\n{report.ReportData ?? "No content available"}\n");
                        sb.AppendLine(new string('=', 80));
                    }

                    var pdfBytes = _pdfGeneratorService.GeneratePdfFromText(
                        reportTitle: "System Reports Export",
                        reportContent: sb.ToString(),
                        generatedBy: user.FullName,
                        generatedAt: DateTime.UtcNow
                    );

                    var fileName = $"system-reports-{DateTime.UtcNow:yyyyMMdd-HHmmss}.pdf";
                    return File(pdfBytes, "application/pdf", fileName);
                }
                else
                {
                    // CSV or Excel export (simplified text format)
                    var sb = new System.Text.StringBuilder();
                    sb.AppendLine("SYSTEM REPORTS EXPORT");
                    sb.AppendLine($"Generated: {DateTime.UtcNow:yyyy-MM-dd HH:mm:ss}");
                    sb.AppendLine($"Exported by: {user.FullName}");
                    sb.AppendLine(new string('-', 80));

                    foreach (var report in reports)
                    {
                        sb.AppendLine($"\n{report.ReportType}");
                        sb.AppendLine($"Generated At: {report.GeneratedAt:yyyy-MM-dd HH:mm:ss}");
                        sb.AppendLine($"Generated By: {report.User?.FullName ?? "System"}");
                        sb.AppendLine($"Data Length: {report.ReportData?.Length ?? 0} bytes");
                        sb.AppendLine(new string('-', 80));
                    }

                    var fileContent = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
                    var contentType = format switch
                    {
                        "excel" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                        "csv" => "text/csv",
                        _ => "text/plain"
                    };

                    var fileName = $"reports-export-{DateTime.UtcNow:yyyyMMdd-HHmmss}.{format}";
                    return File(fileContent, contentType, fileName);
                }
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error exporting reports");
                return StatusCode(500, "Error exporting reports");
            }
        }

