        /// <summary>
        /// Export Audit Logs for Auditor role
        /// </summary>
        [HttpGet]
        public async Task<IActionResult> ExportAuditLogs(string format = "csv")
        {
            try
            {
                var user = await _userManager.GetUserAsync(User);
                if (user == null)
                {
                    return NotFound();
                }

                var auditLogs = await _context.AuditLogs.OrderByDescending(a => a.AssignedAt).ToListAsync();

                var sb = new System.Text.StringBuilder();
                sb.AppendLine("AUDIT LOGS EXPORT");
                sb.AppendLine($"Generated: {DateTime.UtcNow:yyyy-MM-dd HH:mm:ss}");
                sb.AppendLine($"Exported by: {user.FullName}");
                sb.AppendLine(new string('-', 100));

                foreach (var log in auditLogs)
                {
                    sb.AppendLine($"\nTimestamp: {log.AssignedAt:yyyy-MM-dd HH:mm:ss}");
                    sb.AppendLine($"User: {log.UserId}");
                    sb.AppendLine($"Action: {log.Action}");
                    sb.AppendLine($"Entity: System");
                    sb.AppendLine(new string('-', 100));
                }

                var fileContent = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
                var contentType = format switch
                {
                    "excel" => "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                    "pdf" => "application/pdf",
                    _ => "text/csv"
                };

                var fileName = $"audit-logs-{DateTime.UtcNow:yyyyMMdd-HHmmss}.{format}";
                return File(fileContent, contentType, fileName);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error exporting audit logs");
                return StatusCode(500, "Error exporting audit logs");
            }
        }

