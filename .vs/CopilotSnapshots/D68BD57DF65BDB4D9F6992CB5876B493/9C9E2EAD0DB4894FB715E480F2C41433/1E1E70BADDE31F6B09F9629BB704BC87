        private async Task SetUserViewBagAsync()
        {
            var user = await _userManager.GetUserAsync(User);
            ViewBag.UserEmail = user?.Email ?? "user@example.com";
            ViewBag.UserFirstName = user?.FirstName ?? "";
            ViewBag.UserName = user?.FullName ?? user?.FirstName ?? "User";
            ViewBag.FullName = user?.FullName ?? "User";
            ViewBag.UserLastName = user?.LastName ?? "";
            ViewBag.UserPhone = user?.PhoneNumber ?? "";
            
            // Get the user's role(s)
            var roles = await _userManager.GetRolesAsync(user!);
            ViewBag.UserRole = roles.FirstOrDefault() ?? "Employee";
            ViewBag.UserRoles = roles;

            // Load Accountant KPI data if user is Accountant
            var userRole = ViewBag.UserRole as string ?? "Employee";
            if (userRole == "Accountant" || userRole == "Admin" || userRole == "SuperAdmin")
            {
                await LoadAccountantKPIDataAsync();
            }
            
            // Load HR KPI data if user is HR
            if (userRole == "HR" || userRole == "Admin" || userRole == "SuperAdmin")
            {
                await LoadHRKPIDataAsync();
            }
            
            // Load Auditor KPI data if user is Auditor
            if (userRole == "Auditor" || userRole == "SuperAdmin")
            {
                await LoadAuditorKPIDataAsync();
            }
        }

        private async Task LoadAccountantKPIDataAsync()
        {
            try
            {
                var kpi = await _accountantService.GetAccountantKPIAsync();
                ViewBag.BudgetUtilizationRate = kpi.BudgetUtilizationRate;
                ViewBag.PendingExpenses = kpi.PendingExpenses;
                ViewBag.DepartmentCount = kpi.DepartmentCount;
                ViewBag.TotalBudgetAllocated = kpi.TotalBudgetAllocated;
                ViewBag.TotalBudgetUsed = kpi.TotalBudgetUsed;
                ViewBag.RemainingBudget = kpi.RemainingBudget;
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error loading Accountant KPI data");
                ViewBag.BudgetUtilizationRate = 0;
                ViewBag.PendingExpenses = 0;
                ViewBag.DepartmentCount = 0;
            }
        }

        private async Task LoadHRKPIDataAsync()
        {
            try
            {
                var totalEmployees = await _context.Employees.CountAsync();
                var totalDepartments = await _context.Departments.CountAsync();
                var performanceRecords = await _context.PerformanceRecords.ToListAsync();
                var avgRating = performanceRecords.Count > 0 ? performanceRecords.Average(p => p.PerformanceRating) : 0;
                
                ViewBag.TotalEmployees = totalEmployees;
                ViewBag.TotalDepartments = totalDepartments;
                ViewBag.TotalPerformanceRecords = performanceRecords.Count;
                ViewBag.AvgPerformanceRating = avgRating;

                // Load employees list
                var employees = await _context.Employees
                    .Include(e => e.User)
                    .Include(e => e.Department)
                    .ToListAsync();
                var employeesList = employees.Select(e => new
                {
                    EmployeeName = e.User?.FullName ?? "Unknown",
                    DepartmentName = e.Department?.DepartmentName ?? "Unassigned",
                    Position = e.Position ?? "N/A"
                }).Cast<dynamic>().ToList();
                ViewBag.EmployeesList = employeesList;

                // Load department summary
                var deptSummary = await _context.Departments
                    .Select(d => new
                    {
                        DepartmentName = d.DepartmentName,
                        EmployeeCount = d.Employees.Count
                    })
                    .ToListAsync();
                ViewBag.DepartmentSummary = deptSummary.Cast<dynamic>().ToList();

                // Load top performers
                var topPerformers = performanceRecords
                    .OrderByDescending(p => p.PerformanceRating)
                    .Take(5)
                    .Select(p => new
                    {
                        EmployeeName = p.EmployeeId,
                        PerformanceRating = p.PerformanceRating
                    })
                    .Cast<dynamic>()
                    .ToList();
                ViewBag.TopPerformers = topPerformers;

                // Load performance records
                var perfRecords = performanceRecords
                    .OrderByDescending(p => p.PerformanceId)
                    .Take(10)
                    .Select(p => new
                    {
                        EmployeeName = p.EmployeeId,
                        EvaluationPeriod = p.EvaluationPeriod,
                        PerformanceRating = p.PerformanceRating,
                        TasksCompleted = p.TasksCompleted
                    })
                    .Cast<dynamic>()
                    .ToList();
                ViewBag.PerformanceRecords = perfRecords;

                // Performance distribution
                var excellentCount = performanceRecords.Count(p => p.PerformanceRating >= 4);
                var goodCount = performanceRecords.Count(p => p.PerformanceRating >= 3 && p.PerformanceRating < 4);
                var averageCount = performanceRecords.Count(p => p.PerformanceRating >= 2 && p.PerformanceRating < 3);
                var belowAverageCount = performanceRecords.Count(p => p.PerformanceRating < 2);

                ViewBag.ExcellentCount = excellentCount;
                ViewBag.GoodCount = goodCount;
                ViewBag.AverageCount = averageCount;
                ViewBag.BelowAverageCount = belowAverageCount;

                // Department performance data
                var deptPerformance = await _context.Departments
                    .Select(d => new
                    {
                        DepartmentName = d.DepartmentName,
                        AvgRating = d.Employees
                            .SelectMany(e => e.PerformanceRecords)
                            .Average(p => (decimal?)p.PerformanceRating) ?? 0
                    })
                    .ToListAsync();

                ViewBag.DepartmentLabels = deptPerformance.Select(d => d.DepartmentName).ToList();
                ViewBag.DepartmentPerformanceData = deptPerformance.Select(d => d.AvgRating).ToList();
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error loading HR KPI data");
                ViewBag.TotalEmployees = 0;
                ViewBag.TotalDepartments = 0;
                ViewBag.TotalPerformanceRecords = 0;
                ViewBag.AvgPerformanceRating = 0;
            }
        }

        private async Task LoadAuditorKPIDataAsync()
        {
            try
            {
                var auditLogs = await _context.AuditLogs.OrderByDescending(a => a.AssignedAt).Take(100).ToListAsync();
                var totalLogs = await _context.AuditLogs.CountAsync();

                ViewBag.TotalAuditLogs = totalLogs;
                ViewBag.UserActivitiesCount = auditLogs.Count(a => a.Action.Contains("Login") || a.Action.Contains("Logout"));
                ViewBag.DataModificationsCount = auditLogs.Count(a => a.Action.Contains("Create") || a.Action.Contains("Update") || a.Action.Contains("Delete"));
                ViewBag.ComplianceScore = 95; // Default compliance score

                // Load audit logs - Convert to list
                var logsDisplay = auditLogs
                    .Take(20)
                    .Select(a => new
                    {
                        Timestamp = a.AssignedAt,
                        UserName = a.UserId,
                        Action = a.Action,
                        EntityName = "System"
                    })
                    .ToList();
                ViewBag.AuditLogs = logsDisplay.Cast<dynamic>().ToList();

                // Load financial audit data - Convert to list of dynamic
                var financialAudit = await _context.Budgets
                    .Include(b => b.Department)
                    .GroupBy(b => b.Department)
                    .Select(g => new
                    {
                        DepartmentName = g.Key != null ? g.Key.DepartmentName : "Unassigned",
                        AllocatedAmount = g.Sum(b => b.AllocatedAmount),
                        UsedAmount = g.Sum(b => b.UsedAmount)
                    })
                    .ToListAsync();
                ViewBag.FinancialAuditData = financialAudit.Cast<dynamic>().ToList();

                // Load operational audit data - Convert to list of dynamic
                var operationalAudit = await _context.OperationalProcesses
                    .OrderByDescending(p => p.CreatedAt)
                    .Take(15)
                    .ToListAsync();
                ViewBag.OperationalAuditData = operationalAudit.Cast<dynamic>().ToList();

                // Activity distribution
                ViewBag.LoginCount = auditLogs.Count(a => a.Action.Contains("Login"));
                ViewBag.ModificationCount = auditLogs.Count(a => a.Action.Contains("Create") || a.Action.Contains("Update"));
                ViewBag.ReportCount = auditLogs.Count(a => a.Action.Contains("Report"));
                ViewBag.ApprovalCount = auditLogs.Count(a => a.Action.Contains("Approve"));
                ViewBag.OtherCount = auditLogs.Count(a => !a.Action.Contains("Login") && !a.Action.Contains("Create") && !a.Action.Contains("Update") && !a.Action.Contains("Report") && !a.Action.Contains("Approve"));

                // Monthly activities
                var now = DateTime.UtcNow;
                ViewBag.JanActivities = auditLogs.Count(a => a.AssignedAt.Month == 1);
                ViewBag.FebActivities = auditLogs.Count(a => a.AssignedAt.Month == 2);
                ViewBag.MarActivities = auditLogs.Count(a => a.AssignedAt.Month == 3);
                ViewBag.AprActivities = auditLogs.Count(a => a.AssignedAt.Month == 4);
                ViewBag.MayActivities = auditLogs.Count(a => a.AssignedAt.Month == 5);
                ViewBag.JunActivities = auditLogs.Count(a => a.AssignedAt.Month == 6);
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error loading Auditor KPI data");
                ViewBag.TotalAuditLogs = 0;
                ViewBag.UserActivitiesCount = 0;
                ViewBag.DataModificationsCount = 0;
                ViewBag.ComplianceScore = 0;
                ViewBag.AuditLogs = new List<dynamic>();
                ViewBag.FinancialAuditData = new List<dynamic>();
                ViewBag.OperationalAuditData = new List<dynamic>();
            }
        }

        public class ProfileUpdateModel
        {
            public string? FirstName { get; set; }
            public string? LastName { get; set; }
            public string? PhoneNumber { get; set; }
            public string? Role { get; set; }
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> UpdateProfilePost(ProfileUpdateModel model)
        {
            if (model == null)
            {
                TempData["Error"] = "Invalid request";
                return RedirectToAction("Settings");
            }

            var user = await _userManager.GetUserAsync(User);
            if (user == null)
            {
                TempData["Error"] = "User not found";
                return RedirectToAction("Settings");
            }

            var didChange = false;
            if (!string.IsNullOrWhiteSpace(model.FirstName) && model.FirstName.Trim() != user.FirstName)
            {
                user.FirstName = model.FirstName.Trim();
                didChange = true;
            }
            if (!string.IsNullOrWhiteSpace(model.LastName) && model.LastName.Trim() != user.LastName)
            {
                user.LastName = model.LastName.Trim();
                didChange = true;
            }

            if (didChange)
            {
                var updateResult = await _userManager.UpdateAsync(user);
                if (!updateResult.Succeeded)
                {
                    TempData["Error"] = string.Join("; ", updateResult.Errors.Select(e => e.Description));
                    return RedirectToAction("Settings");
                }
                await _signInManager.RefreshSignInAsync(user);
            }

            if (model.PhoneNumber != null && model.PhoneNumber.Trim() != user.PhoneNumber)
            {
                var phoneResult = await _userManager.SetPhoneNumberAsync(user, model.PhoneNumber.Trim());
                if (!phoneResult.Succeeded)
                {
                    TempData["Error"] = string.Join("; ", phoneResult.Errors.Select(e => e.Description));
                    return RedirectToAction("Settings");
                }
            }

            // Role change handling - same as AJAX endpoint
            if (!string.IsNullOrWhiteSpace(model.Role) && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
            {
                var currentRoles = await _userManager.GetRolesAsync(user);
                if (currentRoles.Contains("SuperAdmin"))
                {
                    // do not change SuperAdmin
                }
                else
                {
                    var newRole = model.Role.Trim();
                    if (!currentRoles.Contains(newRole))
                    {
                        var removeResult = await _userManager.RemoveFromRolesAsync(user, currentRoles);
                        if (!removeResult.Succeeded)
                        {
                            TempData["Error"] = string.Join("; ", removeResult.Errors.Select(e => e.Description));
                            return RedirectToAction("Settings");
                        }
                        var addResult = await _userManager.AddToRoleAsync(user, newRole);
                        if (!addResult.Succeeded)
                        {
                            TempData["Error"] = string.Join("; ", addResult.Errors.Select(e => e.Description));
                            return RedirectToAction("Settings");
                        }
                    }
                }
            }

            TempData["Success"] = "Profile updated successfully";
            return RedirectToAction("Settings");
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> UpdateProfile([FromBody] ProfileUpdateModel model)
        {
            if (model == null)
            {
                return Json(new { success = false, message = "Invalid request" });
            }

            var user = await _userManager.GetUserAsync(User);
            if (user == null)
            {
                return Json(new { success = false, message = "User not found" });
            }

            var didChange = false;
            if (!string.IsNullOrWhiteSpace(model.FirstName) && model.FirstName.Trim() != user.FirstName)
            {
                user.FirstName = model.FirstName.Trim();
                didChange = true;
            }
            if (!string.IsNullOrWhiteSpace(model.LastName) && model.LastName.Trim() != user.LastName)
            {
                user.LastName = model.LastName.Trim();
                didChange = true;
            }

            if (didChange)
            {
                var updateResult = await _userManager.UpdateAsync(user);
                if (!updateResult.Succeeded)
                {
                    var err = string.Join("; ", updateResult.Errors.Select(e => e.Description));
                    return Json(new { success = false, message = err });
                }
                await _signInManager.RefreshSignInAsync(user);
            }

            if (model.PhoneNumber != null && model.PhoneNumber.Trim() != user.PhoneNumber)
            {
                var phoneResult = await _userManager.SetPhoneNumberAsync(user, model.PhoneNumber.Trim());
                if (!phoneResult.Succeeded)
                {
                    var err = string.Join("; ", phoneResult.Errors.Select(e => e.Description));
                    return Json(new { success = false, message = err });
                }
            }

            if (!string.IsNullOrWhiteSpace(model.Role) && (User.IsInRole("Admin") || User.IsInRole("SuperAdmin")))
            {
                var currentRoles = await _userManager.GetRolesAsync(user);
                if (currentRoles.Contains("SuperAdmin"))
                {
                    goto SkipRoleChange;
                }
                var newRole = model.Role.Trim();
                if (!currentRoles.Contains(newRole))
                {
                    var removeResult = await _userManager.RemoveFromRolesAsync(user, currentRoles);
                    if (!removeResult.Succeeded)
                    {
                        var err = string.Join("; ", removeResult.Errors.Select(e => e.Description));
                        return Json(new { success = false, message = err });
                    }

                    var addResult = await _userManager.AddToRoleAsync(user, newRole);
                    if (!addResult.Succeeded)
                    {
                        var err = string.Join("; ", addResult.Errors.Select(e => e.Description));
                        return Json(new { success = false, message = err });
                    }
                }
            }
            SkipRoleChange:;

            await SetUserViewBagAsync();

            var updatedUser = await _userManager.FindByIdAsync(user.Id);
            var updatedRoles = await _userManager.GetRolesAsync(updatedUser!);

            if (updatedUser != null)
            {
                await _signInManager.RefreshSignInAsync(updatedUser);
            }

            return Json(new
            {
                success = true,
                message = "Profile updated successfully",
                firstName = updatedUser?.FirstName,
                lastName = updatedUser?.LastName,
                phoneNumber = updatedUser?.PhoneNumber,
                email = updatedUser?.Email,
                role = updatedRoles.FirstOrDefault()
            });
        }

        private async Task<bool> IsUserApprovedAsync()
        {
            var user = await _userManager.GetUserAsync(User);
            return user?.IsApproved ?? false;
        }

        public async Task<IActionResult> Index()
        {
            if (!await IsUserApprovedAsync())
            {
                return RedirectToAction("PendingApproval");
            }

            await SetUserViewBagAsync();

            // ============ KPI METRICS ============
            // Dashboard summary counts
            var totalEmployees = await _context.Employees.CountAsync();
            var totalDepartments = await _context.Departments.CountAsync();
            var activeProcesses = await _context.OperationalProcesses.CountAsync(p => p.Status == ProcessStatus.Approved || p.Status == ProcessStatus.Pending);
            var completedProcesses = await _context.OperationalProcesses.CountAsync(p => p.Status == ProcessStatus.Completed);
            var pendingRequests = await _context.EmployeeRequests.CountAsync(r => r.Status == RequestStatus.Pending);

            // Budget Utilization Rate
            var totalBudgetAllocated = await _context.Budgets.SumAsync(b => (decimal?)b.AllocatedAmount) ?? 0;
            var totalBudgetUsed = await _context.Budgets.SumAsync(b => (decimal?)b.UsedAmount) ?? 0;
            decimal budgetUtilizationRate = totalBudgetAllocated > 0 ? (totalBudgetUsed / totalBudgetAllocated * 100) : 0;

            ViewBag.TotalEmployees = totalEmployees;
            ViewBag.TotalDepartments = totalDepartments;
            ViewBag.ActiveProcesses = activeProcesses;
            ViewBag.CompletedProcesses = completedProcesses;
            ViewBag.PendingRequests = pendingRequests;
            ViewBag.BudgetUtilizationRate = Math.Round(budgetUtilizationRate, 2);
            ViewBag.TotalBudgetAllocated = totalBudgetAllocated;
            ViewBag.TotalBudgetUsed = totalBudgetUsed;

            // ============ CHART DATA: Processes per Department ============
            var processesByDept = await _context.OperationalProcesses
                .GroupBy(p => p.Department)
                .Select(g => new { Department = g.Key ?? "(Unassigned)", Count = g.Count() })
                .OrderByDescending(x => x.Count)
                .ToListAsync();

            ViewBag.ProcessDeptLabels = processesByDept.Select(x => x.Department).ToList();
            ViewBag.ProcessDeptCounts = processesByDept.Select(x => x.Count).ToList();

            // ============ CHART DATA: Request Status Distribution ============
            var requestStatusCounts = await _context.EmployeeRequests
                .GroupBy(r => r.Status)
                .Select(g => new { Status = g.Key.ToString(), Count = g.Count() })
                .ToListAsync();

            var pendingCount = requestStatusCounts.FirstOrDefault(x => x.Status == "Pending")?.Count ?? 0;
            var inProgressCount = requestStatusCounts.FirstOrDefault(x => x.Status == "InProgress")?.Count ?? 0;
            var completedCount = requestStatusCounts.FirstOrDefault(x => x.Status == "Completed")?.Count ?? 0;
            var rejectedCount = requestStatusCounts.FirstOrDefault(x => x.Status == "Rejected")?.Count ?? 0;

            ViewBag.RequestStatusLabels = new[] { "Pending", "In Progress", "Completed", "Rejected" };
            ViewBag.RequestStatusCounts = new[] { pendingCount, inProgressCount, completedCount, rejectedCount };

            // ============ CHART DATA: Monthly Requests Trend (Last 6 Months) ============
            var sixMonthsAgo = DateTime.UtcNow.AddMonths(-6);
            var monthlyRequests = await _context.EmployeeRequests
                .Where(r => r.CreatedAt >= sixMonthsAgo)
                .GroupBy(r => new { r.CreatedAt.Year, r.CreatedAt.Month })
                .Select(g => new { YearMonth = g.Key, Count = g.Count() })
                .OrderBy(x => x.YearMonth.Year).ThenBy(x => x.YearMonth.Month)
                .ToListAsync();

            var monthLabels = monthlyRequests.Select(x => DateTime.ParseExact($"{x.YearMonth.Year}-{x.YearMonth.Month:D2}", "yyyy-MM", System.Globalization.CultureInfo.InvariantCulture).ToString("MMM yyyy")).ToList();
            var monthCounts = monthlyRequests.Select(x => x.Count).ToList();

            // If no data, create 6 empty months
            if (!monthlyRequests.Any())
            {
                monthLabels.Clear();
                monthCounts.Clear();
                for (int i = 5; i >= 0; i--)
                {
                    var date = DateTime.UtcNow.AddMonths(-i);
                    monthLabels.Add(date.ToString("MMM yyyy"));
                    monthCounts.Add(0);
                }
            }

            ViewBag.MonthlyRequestLabels = monthLabels;
            ViewBag.MonthlyRequestCounts = monthCounts;

            // ============ CHART DATA: Process Status Distribution ============
            var processStatusCounts = await _context.OperationalProcesses
                .GroupBy(p => p.Status)
                .Select(g => new { Status = g.Key.ToString(), Count = g.Count() })
                .ToListAsync();

            var processPendingCount = processStatusCounts.FirstOrDefault(x => x.Status == "Pending")?.Count ?? 0;
            var processApprovedCount = processStatusCounts.FirstOrDefault(x => x.Status == "Approved" || x.Status == "Active")?.Count ?? 0;
            var processCompletedCount = processStatusCounts.FirstOrDefault(x => x.Status == "Completed")?.Count ?? 0;
            var processRejectedCount = 0; // No rejected status in enum

            ViewBag.ProcessStatusLabels = new[] { "Pending", "Approved", "Completed" };
            ViewBag.ProcessStatusCounts = new[] { processPendingCount, processApprovedCount, processCompletedCount };

            // ============ CHART DATA: Department Performance (Employees per Department) ============
            var deptEmployees = await _context.Departments
                .Select(d => new { Department = d.DepartmentName, EmployeeCount = d.Employees.Count })
                .OrderByDescending(x => x.EmployeeCount)
                .Take(10)
                .ToListAsync();

            ViewBag.DeptPerformanceLabels = deptEmployees.Select(x => x.Department).ToList();
            ViewBag.DeptPerformanceCounts = deptEmployees.Select(x => x.EmployeeCount).ToList();

            return View();
        }

