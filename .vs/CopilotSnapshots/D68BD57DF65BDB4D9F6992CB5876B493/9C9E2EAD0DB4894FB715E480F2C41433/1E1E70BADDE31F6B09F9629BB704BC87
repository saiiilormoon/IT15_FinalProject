        [Authorize(Roles = "Admin,SuperAdmin")]
        public async Task<IActionResult> QuickSetupEmployees()
        {
            try
            {
                // STEP 1: Create Departments
                var departments = new List<string> { "IT Department", "Human Resources", "Finance", "Operations" };
                
                foreach (var deptName in departments)
                {
                    if (!await _context.Departments.AnyAsync(d => d.DepartmentName == deptName))
                    {
                        _context.Departments.Add(new Department
                        {
                            DepartmentName = deptName,
                            Status = "Active"
