        /// <summary>
        /// Log New Expense - Create a new expense record
        /// Only Accountant, Admin, and SuperAdmin can log expenses
        /// </summary>
        [HttpPost]
        [ValidateAntiForgeryToken]
        [Authorize(Roles = "Accountant,Admin,SuperAdmin")]
        public async Task<IActionResult> LogExpense(
            [FromForm] DateTime expenseDate,
            [FromForm] string department,
            [FromForm] string category,
            [FromForm] decimal amount,
            [FromForm] string description)
        {
            try
            {
                var currentUser = await _userManager.GetUserAsync(User);
                if (currentUser == null)
                {
                    TempData["Error"] = "User not found";
                    return RedirectToAction("ExpenseTracking");
                }

                if (amount <= 0)
                {
                    TempData["Error"] = "Expense amount must be greater than 0";
                    return RedirectToAction("ExpenseTracking");
                }

                var expense = new Expense
                {
                    Description = description?.Trim() ?? string.Empty,
                    Amount = amount,
                    Category = category?.Trim() ?? "Other",
                    Department = department?.Trim() ?? "General",
                    ExpenseDate = expenseDate,
                    Status = "Pending", // Default status
                    RequestedBy = currentUser.FullName,
                    CreatedAt = DateTime.UtcNow
                };

                _context.Expenses.Add(expense);
                await _context.SaveChangesAsync();

                await _auditService.LogExpenseCreatedAsync(currentUser.Id, expense.ExpenseId, amount);

                TempData["Success"] = $"Expense of ?{amount:N0} logged successfully! Awaiting approval.";
                _logger.LogInformation($"New expense logged: ?{amount} in {category} by {currentUser.Email}");

                return RedirectToAction("ExpenseTracking");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error logging expense");
                TempData["Error"] = "Error logging expense: " + ex.Message;
                return RedirectToAction("ExpenseTracking");
            }
        }

