                await _context.SaveChangesAsync();

                // STEP 2: Define employees to create
                var employeeData = new List<(string Email, string Position, string DepartmentName)>
                {
                    // IT Department
                    ("john.smith@company.com", "Senior Developer", "IT Department"),
                    ("alice.johnson@company.com", "Software Engineer", "IT Department"),
                    ("bob.williams@company.com", "DevOps Engineer", "IT Department"),
                    
                    // HR Department
                    ("sarah.davis@company.com", "HR Manager", "Human Resources"),
                    ("michael.brown@company.com", "Recruiter", "Human Resources"),
                    
                    // Finance Department
                    ("emma.wilson@company.com", "Accountant", "Finance"),
                    ("david.miller@company.com", "Financial Analyst", "Finance"),
                    
                    // Operations Department
                    ("lisa.anderson@company.com", "Operations Manager", "Operations"),
                    ("james.taylor@company.com", "Logistics Officer", "Operations")
                };

                // STEP 3: Create employees
                int createdCount = 0;
                foreach (var (email, position, deptName) in employeeData)
                {
                    // Find user by email
                    var user = await _userManager.FindByEmailAsync(email);
                    if (user == null)
