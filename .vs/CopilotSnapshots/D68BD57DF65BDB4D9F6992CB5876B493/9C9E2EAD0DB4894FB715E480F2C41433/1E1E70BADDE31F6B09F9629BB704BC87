        public async Task<IActionResult> Operations()
        {
            if (!await IsUserApprovedAsync())
            {
                return RedirectToAction("PendingApproval");
            }
            
            await SetUserViewBagAsync();
            var userRole = ViewBag.UserRole as string;
            
            // Operations is restricted to Admin and HR ONLY
            if (userRole == "Accountant")
            {
                TempData["Error"] = "You do not have permission to access Operational Processing.";
                return RedirectToAction("Index");
            }
            
            var processes = await _context.OperationalProcesses
                .OrderByDescending(p => p.CreatedAt)
                .ToListAsync();
            
            ViewBag.OperationalProcesses = processes;
            return View();
        }

