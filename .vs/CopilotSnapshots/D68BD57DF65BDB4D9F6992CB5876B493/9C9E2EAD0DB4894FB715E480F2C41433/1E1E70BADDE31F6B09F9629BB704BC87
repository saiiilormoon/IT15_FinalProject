        public async Task<IActionResult> Performance()
        {
            if (!await IsUserApprovedAsync())
            {
                return RedirectToAction("PendingApproval");
            }

            await SetUserViewBagAsync();
            
            var userRole = ViewBag.UserRole as string;
            if (!RoleBasedAuthorizationHelper.DashboardAccess.CanAccessPerformance(userRole))
            {
                return Forbid();
            }

            // Load performance records with proper includes
            var performanceRecords = await _context.PerformanceRecords
                .Include(p => p.Employee)
                .ThenInclude(e => e!.User)
                .Include(p => p.Employee)
                .ThenInclude(e => e!.Department)
                .OrderByDescending(p => p.RecordedAt)
                .ToListAsync();

            // Load employees for dropdown - only include employees with User accounts
            var employees = await _context.Employees
                .Include(e => e.User)
                .Include(e => e.Department)
                .Where(e => e.User != null)
                .OrderBy(e => e.User!.FirstName)
                .ThenBy(e => e.User!.LastName)
                .ToListAsync();

            // Ensure ViewBag.Employees is always set (even if empty list)
            ViewBag.Employees = employees ?? new List<Employee>();

            // Calculate performance statistics
            var excellentCount = performanceRecords.Count(p => p.PerformanceRating >= 5);
            var goodCount = performanceRecords.Count(p => p.PerformanceRating == 4);
            var averageCount = performanceRecords.Count(p => p.PerformanceRating == 3);
            var belowAverageCount = performanceRecords.Count(p => p.PerformanceRating == 2);
            var poorCount = performanceRecords.Count(p => p.PerformanceRating == 1);

            var avgRating = performanceRecords.Count > 0 
                ? performanceRecords.Average(p => p.PerformanceRating) 
                : 0;

            ViewBag.TotalPerformanceRecords = performanceRecords.Count;
            ViewBag.AvgPerformanceRating = Math.Round(avgRating, 2);
            ViewBag.ExcellentCount = excellentCount;
            ViewBag.GoodCount = goodCount;
            ViewBag.AverageCount = averageCount;
            ViewBag.BelowAverageCount = belowAverageCount;
            ViewBag.PoorCount = poorCount;

            var perfStats = await _performanceService.GetEmployeePerformanceStatsAsync();
            ViewBag.PerfStats = perfStats;
            
            return View("EmployeePerformanceMonitor", performanceRecords);
        }

        [HttpPost]
        [ValidateAntiForgeryToken]
        [Authorize(Policy = "CanManageHR")]
        public async Task<IActionResult> RecordPerformance(
            [FromForm] string employeeId, 
            [FromForm] string evaluationPeriod, 
            [FromForm] int tasksCompleted,
            [FromForm] int tasksPending,
            [FromForm] int performanceRating,
            [FromForm] string? remarks = null)
        {
            try
            {
                var currentUser = await _userManager.GetUserAsync(User);
                if (currentUser == null)
                {
                    TempData["Error"] = "User not found";
                    return RedirectToAction("Performance");
                }

                // Get user role
                var roles = await _userManager.GetRolesAsync(currentUser);
                var userRole = roles.FirstOrDefault() ?? "Employee";

                // Authorization check - only SuperAdmin, Admin, and HR
                if (!RoleBasedAuthorizationHelper.RoleHierarchy.CanManageHR(userRole))
                {
                    TempData["Error"] = "You do not have permission to record performance";
                    return RedirectToAction("Performance");
                }

                // Validate input
                if (string.IsNullOrWhiteSpace(employeeId))
                {
                    TempData["Error"] = "Employee selection is required";
                    return RedirectToAction("Performance");
                }

                if (string.IsNullOrWhiteSpace(evaluationPeriod))
                {
                    TempData["Error"] = "Evaluation period is required";
                    return RedirectToAction("Performance");
                }

                if (performanceRating < 1 || performanceRating > 5)
                {
                    TempData["Error"] = "Performance rating must be between 1 and 5";
                    return RedirectToAction("Performance");
                }

                if (tasksCompleted < 0 || tasksPending < 0)
                {
                    TempData["Error"] = "Tasks cannot be negative";
                    return RedirectToAction("Performance");
                }

                // Verify employee exists and load related data
                var employee = await _context.Employees
                    .Include(e => e.User)
                    .FirstOrDefaultAsync(e => e.EmployeeId == employeeId);

                if (employee == null)
                {
                    TempData["Error"] = "Selected employee not found";
                    return RedirectToAction("Performance");
                }

                // Create performance record
                var performanceRecord = new PerformanceRecord
                {
                    EmployeeId = employeeId,
                    EvaluationPeriod = evaluationPeriod.Trim(),
                    TasksCompleted = tasksCompleted,
                    TasksPending = tasksPending,
                    PerformanceRating = performanceRating,
                    Remarks = string.IsNullOrWhiteSpace(remarks) ? null : remarks.Trim(),
                    RecordedAt = DateTime.UtcNow
                };

                _context.PerformanceRecords.Add(performanceRecord);
                await _context.SaveChangesAsync();

                // Log audit
                await _auditService.LogPerformanceRecordedAsync(currentUser.Id, employeeId);

                _logger.LogInformation($"Performance record created for {employee.User?.FullName} ({employeeId}) by {currentUser.Email}. Rating: {performanceRating}/5, Period: {evaluationPeriod}, Tasks: {tasksCompleted} completed, {tasksPending} pending");

                TempData["Success"] = $"✓ Performance evaluation for {employee.User?.FullName} recorded successfully! Rating: {performanceRating}/5 ({evaluationPeriod})";
                return RedirectToAction("Performance");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error recording performance");
                TempData["Error"] = "Error recording performance: " + ex.Message;
                return RedirectToAction("Performance");
            }
        }

