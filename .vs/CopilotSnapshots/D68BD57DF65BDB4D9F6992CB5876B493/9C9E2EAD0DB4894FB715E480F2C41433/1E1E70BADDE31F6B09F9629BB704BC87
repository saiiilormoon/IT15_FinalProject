            await SetUserViewBagAsync();

            var reportStats = await _reportService.GetReportStatsAsync();
            var allReports = await _reportService.GetAllReportsAsync();

            ViewBag.ReportStats = reportStats;
            return View(allReports);
        }

        [HttpPost]
        [Authorize]
        public async Task<IActionResult> GenerateReportAjax([FromBody] GenerateReportRequest request)
        {
            try
            {
                var user = await _userManager.GetUserAsync(User);
                if (user == null)
                {
                    return Json(new { success = false, message = "User not found" });
                }

                if (request == null || string.IsNullOrWhiteSpace(request.ReportType))
                {
                    return Json(new { success = false, message = "Report type is required" });
                }

                // Generate report data based on type
                string reportData = await GenerateReportDataAsync(request);

                // Store in database
                Report report = null;
                switch (request.ReportType)
                {
                    case "Operational":
                        report = await _reportService.GenerateOperationalReportAsync(user.Id, reportData);
                        break;
                    case "Departmental":
                        if (string.IsNullOrWhiteSpace(request.Department) || !int.TryParse(request.Department, out int deptId))
                        {
                            return Json(new { success = false, message = "Department is required for Departmental reports" });
                        }
                        report = await _reportService.GenerateDepartmentalReportAsync(user.Id, deptId, reportData);
                        break;
                    case "Performance":
                        report = await _reportService.GeneratePerformanceReportAsync(user.Id, reportData);
                        break;
                    case "Budget":
                    case "Financial":
                    case "Expense":
                        report = await _reportService.GenerateBudgetReportAsync(user.Id, reportData);
                        break;
                    default:
                        return Json(new { success = false, message = "Invalid report type" });
                }

                // Verify report was created successfully
                if (report == null)
                {
                    return Json(new { success = false, message = "Failed to generate report. Please try again." });
                }

                _logger.LogInformation($"Report generated by {user.Email}: {report.ReportType}");

                return Json(new
                {
                    success = true,
                    message = "Report generated successfully",
                    reportId = report.ReportId,
                    reportType = report.ReportType
                });
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error generating report");
                return Json(new { success = false, message = "Error generating report: " + ex.Message });
            }
        }

        private async Task<string> GenerateReportDataAsync(GenerateReportRequest request)
        {
            var data = new System.Text.StringBuilder();
            data.AppendLine($"Report Type: {request.ReportType}");
            data.AppendLine($"Generated Date: {DateTime.UtcNow:yyyy-MM-dd HH:mm:ss}");
            data.AppendLine($"Date Range: {request.StartDate} to {request.EndDate}");
            data.AppendLine();

            switch (request.ReportType)
            {
                case "Operational":
                    var processes = await _context.OperationalProcesses.ToListAsync();
                    data.AppendLine($"Total Processes: {processes.Count}");
                    data.AppendLine($"Pending: {processes.Count(p => p.Status == ProcessStatus.Pending)}");
                    data.AppendLine($"Approved: {processes.Count(p => p.Status == ProcessStatus.Approved)}");
                    data.AppendLine($"Completed: {processes.Count(p => p.Status == ProcessStatus.Completed)}");
                    break;

                case "Departmental":
                    var depts = await _context.Departments.ToListAsync();
                    data.AppendLine($"Total Departments: {depts.Count}");
                    data.AppendLine($"Employees: {await _context.Employees.CountAsync()}");
                    break;

                case "Performance":
                    var perfRecords = await _context.PerformanceRecords.ToListAsync();
                    var avgRating = perfRecords.Count > 0 ? perfRecords.Average(p => p.PerformanceRating) : 0;
                    data.AppendLine($"Total Records: {perfRecords.Count}");
                    data.AppendLine($"Average Rating: {avgRating:F2}/5.0");
                    break;

                case "Budget":
                case "Financial":
                    var budgets = await _context.Budgets.ToListAsync();
                    var totalAllocated = budgets.Sum(b => b.AllocatedAmount);
                    var totalUsed = budgets.Sum(b => b.UsedAmount);
                    data.AppendLine($"Total Budget Allocated: ? {totalAllocated:N0}");
                    data.AppendLine($"Total Budget Used: ? {totalUsed:N0}");
                    data.AppendLine($"Remaining: ? {(totalAllocated - totalUsed):N0}");
                    data.AppendLine($"Utilization: {(totalAllocated > 0 ? (totalUsed / totalAllocated * 100) : 0):F2}%");
                    break;

                case "Expense":
                    var expenses = await _context.Expenses.ToListAsync();
                    var totalExpenses = expenses.Sum(e => e.Amount);
                    data.AppendLine($"Total Expenses: ? {totalExpenses:N0}");
                    data.AppendLine($"Pending Approval: {expenses.Count(e => e.Status == "Pending")}");
                    data.AppendLine($"Approved: {expenses.Count(e => e.Status == "Approved")}");
                    data.AppendLine($"Rejected: {expenses.Count(e => e.Status == "Rejected")}");
                    break;
            }

            return data.ToString();
        }

