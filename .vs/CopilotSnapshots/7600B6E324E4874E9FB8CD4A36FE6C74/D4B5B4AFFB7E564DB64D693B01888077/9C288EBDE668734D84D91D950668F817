@model CVM_FinalProject.Models.ViewModels.UserManagementPageViewModel
@{
    ViewData["Title"] = "Manage Users";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var currentUserRole = ViewBag.UserRole as string ?? "Admin";
    var isSuperAdmin = currentUserRole == "SuperAdmin";
    var availableRolesAll = Model?.RoleCounts?.Keys?.ToList() ?? new List<string> { "SuperAdmin", "Admin", "Accountant", "HR", "Employee", "Auditor" };
    var availableRolesAssignable = availableRolesAll.Where(r => r != "SuperAdmin").ToList();
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2>Manage Users</h2>
            <p>Manage system users, roles, and permissions.</p>
        </div>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            @if (isSuperAdmin && Model.ArchivedUsersCount > 0)
            {
                <a asp-action="ArchivedUsers" class="btn btn-outline-secondary">
                    <i class="fas fa-archive me-1"></i>Archived (@Model.ArchivedUsersCount)
                </a>
            }
            <a asp-action="PendingApprovals" class="btn btn-outline-warning">
                <i class="fas fa-clock me-1"></i>Pending (@Model.PendingUsers)
            </a>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addUserModal">
                <i class="fas fa-plus me-1"></i>Add New User
            </button>
        </div>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="fas fa-users"></i>
            </div>
            <h3>@Model.TotalUsers</h3>
            <p>Total Users</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-success">
                <i class="fas fa-user-check"></i>
            </div>
            <h3>@Model.ActiveUsers</h3>
            <p>Active Users</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="fas fa-user-clock"></i>
            </div>
            <h3>@Model.PendingUsers</h3>
            <p>Pending Approval</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        @if (isSuperAdmin)
        {
            <a asp-action="ArchivedUsers" class="text-decoration-none">
                <div class="stat-card">
                    <div class="stat-icon" style="background: linear-gradient(135deg, #6c757d, #adb5bd);">
                        <i class="fas fa-archive"></i>
                    </div>
                    <h3>@Model.ArchivedUsersCount</h3>
                    <p>Archived Users</p>
                </div>
            </a>
        }
        else
        {
            <div class="stat-card">
                <div class="stat-icon bg-info">
                    <i class="fas fa-user-plus"></i>
                </div>
                <h3>@Model.NewUsersThisMonth</h3>
                <p>New This Month</p>
            </div>
        }
    </div>
</div>

<!-- Role Distribution -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="chart-card">
            <h5 class="mb-3">Users by Role</h5>
            <div class="d-flex flex-wrap gap-3">
                @foreach (var role in Model.RoleCounts)
                {
                    var badgeClass = role.Key switch
                    {
                        "SuperAdmin" => "bg-danger",
                        "Admin" => "bg-primary",
                        "Accountant" => "bg-success",
                        "HR" => "bg-info",
                        "Employee" => "bg-secondary",
                        "Auditor" => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                    <div class="d-flex align-items-center gap-2 p-2 bg-light rounded">
                        <span class="badge @badgeClass">@role.Key</span>
                        <strong>@role.Value</strong>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Users Table -->
<div class="data-table">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
        <h5 class="mb-0">All Users</h5>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <input type="text" class="form-control form-control-sm" placeholder="Search users..." id="searchInput" style="width: 200px;" onkeyup="searchUsers()">
            @{
                // Build a list of available roles from the model. Fallback to a reasonable default if none provided.
                var availableRoles = Model?.RoleCounts?.Keys?.ToList() ?? new List<string> { "Employee", "HR", "Accountant", "Auditor", "Admin" };
            }
            <select class="form-select form-select-sm" style="width: auto;" id="roleFilter" onchange="filterByRole()">
                <option value="">All Roles</option>
                @foreach (var r in availableRoles)
                {
                    <option value="@r">@r</option>
                }
            </select>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0" id="usersTable">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    var roleClass = user.Role switch
                    {
                        "SuperAdmin" => "bg-danger",
                        "Admin" => "bg-primary",
                        "Accountant" => "bg-success",
                        "HR" => "bg-info",
                        "Employee" => "bg-secondary",
                        "Auditor" => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                    <tr data-role="@user.Role">
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="user-avatar me-2" style="width: 35px; height: 35px; font-size: 0.85rem;">
                                    @(string.IsNullOrEmpty(user.FirstName) ? "U" : user.FirstName[0].ToString().ToUpper())
                                </div>
                                <div>
                                    <strong>@user.FullName</strong>
                                </div>
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td><span class="badge @roleClass">@user.Role</span></td>
                        <td>
                            @if (user.Role == "SuperAdmin")
                            {
                                <span class="badge bg-danger"><i class="fas fa-crown me-1"></i>PERMANENT</span>
                            }
                            else if (user.IsApproved)
                            {
                                <span class="badge bg-success"><i class="fas fa-check me-1"></i>Active</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark"><i class="fas fa-clock me-1"></i>Pending</span>
                            }
                        </td>
                        <td>@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                @* Do not show edit button for SuperAdmin accounts (PERMANENT) *@
                                @if (user.Role != "SuperAdmin")
                                {
                                    <button class="btn btn-outline-primary" title="Edit" onclick="openEditModal('@user.Id', '@user.FirstName', '@user.LastName', '@user.Email', '@user.Role', @user.IsApproved.ToString().ToLower())">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                }
                                @if (user.Role != "SuperAdmin")
                                {
                                    <form asp-action="DeleteUser" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user? They will be moved to Archive.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-outline-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add User Modal -->
<div class="modal fade" id="addUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-user-plus me-2 text-primary"></i>Add New User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="CreateUser" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="FirstName" required placeholder="Enter first name">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="LastName" required placeholder="Enter last name">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Email Address <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" name="Email" required placeholder="Enter email address">
                        </div>
                        <div class="col-12">
                            <label class="form-label">Password <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" name="Password" required placeholder="Enter password" minlength="6">
                            <small class="text-muted">Minimum 6 characters with uppercase, lowercase, and number</small>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Role <span class="text-danger">*</span></label>
                            <select class="form-select" name="Role" required>
                                <option value="Employee">Employee</option>
                                <option value="HR">HR</option>
                                <option value="Accountant">Accountant</option>
                                <option value="Auditor">Auditor</option>
                                <option value="Admin">Admin</option>
                                <!-- SuperAdmin creation is not allowed via UI -->
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="IsApproved" value="true" checked id="approvedCheck">
                                <label class="form-check-label" for="approvedCheck">Approved & Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i>Create User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-user-edit me-2 text-primary"></i>Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="UpdateUser" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" id="editUserId">
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="FirstName" id="editFirstName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" name="LastName" id="editLastName" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Email Address</label>
                            <input type="email" class="form-control" id="editEmail" readonly disabled>
                            <input type="hidden" name="Email" id="editEmailHidden">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Role <span class="text-danger">*</span></label>
                            <select class="form-select" name="Role" id="editRole" required>
                                <option value="Employee">Employee</option>
                                <option value="HR">HR</option>
                                <option value="Accountant">Accountant</option>
                                <option value="Auditor">Auditor</option>
                                <option value="Admin">Admin</option>
                                <!-- SuperAdmin role cannot be assigned/edited via UI -->
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Status</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" name="IsApproved" value="true" id="editApproved">
                                <label class="form-check-label" for="editApproved">Approved & Active</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openEditModal(id, firstName, lastName, email, role, isApproved) {
        document.getElementById('editUserId').value = id;
        document.getElementById('editFirstName').value = firstName;
        document.getElementById('editLastName').value = lastName;
        document.getElementById('editEmail').value = email;
        document.getElementById('editEmailHidden').value = email;
        document.getElementById('editRole').value = role;
        document.getElementById('editApproved').checked = isApproved;
        
        var modal = new bootstrap.Modal(document.getElementById('editUserModal'));
        modal.show();
    }

    function searchUsers() {
        var input = document.getElementById('searchInput').value.toLowerCase();
        var rows = document.querySelectorAll('#usersTable tbody tr');
        
        rows.forEach(function(row) {
            var text = row.textContent.toLowerCase();
            row.style.display = text.includes(input) ? '' : 'none';
        });
    }

    function filterByRole() {
        var role = document.getElementById('roleFilter').value;
        var rows = document.querySelectorAll('#usersTable tbody tr');
        
        rows.forEach(function(row) {
            var rowRole = row.getAttribute('data-role');
            row.style.display = (!role || rowRole === role) ? '' : 'none';
        });
    }
</script>
}
