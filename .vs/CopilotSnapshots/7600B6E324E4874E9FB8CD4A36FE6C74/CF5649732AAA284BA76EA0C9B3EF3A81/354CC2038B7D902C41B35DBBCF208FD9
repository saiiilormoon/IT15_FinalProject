        /// <summary>
        /// Accountant Dashboard - Financial Overview
        /// Only accessible to Accountant role (and SuperAdmin/Admin)
        /// </summary>
        public async Task<IActionResult> AccountantDashboard()
        {
            if (!await IsUserApprovedAsync())
            {
                return RedirectToAction("PendingApproval");
            }

            await SetUserViewBagAsync();

            var userRole = ViewBag.UserRole as string ?? "Employee";
            // Only Accountant and Admin can access
            if (userRole != "Accountant" && !User.IsInRole("Admin") && !User.IsInRole("SuperAdmin"))
            {
                return Forbid();
            }

            // Budget KPIs
            var totalBudgetAllocated = await _context.Budgets.SumAsync(b => (decimal?)b.AllocatedAmount) ?? 0;
            var totalBudgetUsed = await _context.Budgets.SumAsync(b => (decimal?)b.UsedAmount) ?? 0;
            var remainingBudget = totalBudgetAllocated - totalBudgetUsed;
            var budgetUtilizationRate = totalBudgetAllocated > 0 ? (totalBudgetUsed / totalBudgetAllocated * 100) : 0;

            ViewBag.TotalBudgetAllocated = totalBudgetAllocated;
            ViewBag.TotalBudgetUsed = totalBudgetUsed;
            ViewBag.RemainingBudget = remainingBudget;
            ViewBag.BudgetUtilizationRate = Math.Round(budgetUtilizationRate, 2);

            // Department-wise budget breakdown
            var deptBudgets = await _context.Budgets
                .Include(b => b.Department)
                .GroupBy(b => b.Department)
                .Select(g => new
                {
                    DepartmentName = g.Key != null ? g.Key.DepartmentName : "Unassigned",
                    AllocatedAmount = g.Sum(b => b.AllocatedAmount),
                    UsedAmount = g.Sum(b => b.UsedAmount),
                    RemainingAmount = g.Sum(b => b.AllocatedAmount) - g.Sum(b => b.UsedAmount)
                })
                .OrderByDescending(x => x.AllocatedAmount)
                .ToListAsync();

            ViewBag.DepartmentBudgets = deptBudgets;

            return View("AccountantDashboard");
        }

