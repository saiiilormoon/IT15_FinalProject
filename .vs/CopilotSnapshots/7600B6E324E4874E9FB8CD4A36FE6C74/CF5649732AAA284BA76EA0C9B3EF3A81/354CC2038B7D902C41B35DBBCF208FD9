        public async Task<IActionResult> EmployeeRequests()
        {
            var user = await _userManager.GetUserAsync(User);
            if (user == null)
            {
                return RedirectToAction("PendingApproval");
            }

            await SetUserViewBagAsync();

            if (User.IsInRole("Employee"))
            {
                var myRequests = await _context.EmployeeRequests
                    .Where(r => r.SubmittedByUserId == user.Id)
                    .OrderByDescending(r => r.CreatedAt)
                    .ToListAsync();
                
                ViewBag.EmployeeRequests = myRequests;
                ViewBag.IsAdminView = false;
            }
            else if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
            {
                var allRequests = await _context.EmployeeRequests
                    .OrderByDescending(r => r.CreatedAt)
                    .ToListAsync();
                
                ViewBag.EmployeeRequests = allRequests;
                ViewBag.IsAdminView = true;
            }
            else
            {
                return Forbid();
            }

            return View();
        }

