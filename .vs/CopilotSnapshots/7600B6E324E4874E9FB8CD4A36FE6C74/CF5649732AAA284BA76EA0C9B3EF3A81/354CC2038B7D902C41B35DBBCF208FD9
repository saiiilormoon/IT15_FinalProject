        [HttpPost]
        [ValidateAntiForgeryToken]
        [Authorize(Policy = "CanManageHR")]
        public async Task<IActionResult> RecordPerformance(
            [FromForm] string employeeId, 
            [FromForm] string evaluationPeriod, 
            [FromForm] int tasksCompleted,
            [FromForm] int tasksPending,
            [FromForm] int performanceRating,
            [FromForm] string? remarks = null)
        {
            try
            {
                // Authorization check - only SuperAdmin, Admin, and HR
                if (!RoleBasedAuthorizationHelper.RoleHierarchy.CanManageHR(ViewBag.UserRole as string))
                {
                    TempData["Error"] = "You do not have permission to record performance";
                    return RedirectToAction("Performance");
                }

                var currentUser = await _userManager.GetUserAsync(User);
                if (currentUser == null)
                {
                    TempData["Error"] = "User not found";
                    return RedirectToAction("Performance");
                }

                await _performanceService.RecordPerformanceAsync(
                    employeeId, 
                    evaluationPeriod, 
                    tasksCompleted, 
                    tasksPending, 
                    performanceRating,
                    remarks);
                await _auditService.LogPerformanceRecordedAsync(currentUser.Id, employeeId);

                TempData["Success"] = "Performance record created successfully!";
                return RedirectToAction("Performance");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error recording performance");
                TempData["Error"] = "Error recording performance: " + ex.Message;
                return RedirectToAction("Performance");
            }
        }

