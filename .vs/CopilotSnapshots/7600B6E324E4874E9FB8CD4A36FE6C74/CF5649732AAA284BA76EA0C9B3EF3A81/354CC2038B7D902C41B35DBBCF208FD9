        [HttpPost]
        [ValidateAntiForgeryToken]
        [Authorize(Policy = "CanManageBudgets")]
        public async Task<IActionResult> CreateBudget([FromForm] int departmentId, [FromForm] string budgetPeriod, [FromForm] decimal allocatedAmount)
        {
            try
            {
                // Authorization check - only SuperAdmin, Admin, and Accountant
                if (!RoleBasedAuthorizationHelper.RoleHierarchy.CanManageBudgets(ViewBag.UserRole as string))
                {
                    TempData["Error"] = "You do not have permission to create budgets";
                    return RedirectToAction("Budget");
                }

                var currentUser = await _userManager.GetUserAsync(User);
                if (currentUser == null)
                {
                    TempData["Error"] = "User not found";
                    return RedirectToAction("Budget");
                }

                await _budgetService.CreateBudgetAsync(departmentId, budgetPeriod, allocatedAmount);
                await _auditService.LogBudgetUpdatedAsync(currentUser.Id, departmentId, allocatedAmount);

                TempData["Success"] = "Budget created successfully!";
                return RedirectToAction("Budget");
            }
            catch (Exception ex)
            {
                _logger.LogError(ex, "Error creating budget");
                TempData["Error"] = "Error creating budget: " + ex.Message;
                return RedirectToAction("Budget");
            }
        }

