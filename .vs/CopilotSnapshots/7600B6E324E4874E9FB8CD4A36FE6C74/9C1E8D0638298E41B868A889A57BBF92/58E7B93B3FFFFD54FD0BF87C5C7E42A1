@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    
    var userRole = ViewBag.UserRole as string ?? "Employee";
    var isAdmin = userRole == "Admin" || userRole == "SuperAdmin";
    var isAccountant = userRole == "Accountant" || isAdmin;
    var isHR = userRole == "HR" || isAdmin;
    var isAuditor = userRole == "Auditor" || isAdmin;
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2>Welcome back, @ViewBag.UserName!</h2>
            <p>Here's your organization summary for today. <span class="badge bg-primary">@userRole</span></p>
        </div>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <select class="form-select form-select-sm" style="width: auto;" id="periodFilter">
                <option value="month">This Month</option>
                <option value="quarter">This Quarter</option>
                <option value="year">This Year</option>
            </select>
        </div>
    </div>
</div>

<!-- Quick Actions - Role Based -->
<div class="row g-3 mb-4">
    @if (isAdmin || isAccountant || isHR)
    {
        <div class="col-6 col-md-3">
            <a href="@Url.Action("Operations", "Dashboard")" class="quick-action-btn">
                <i class="fas fa-plus-circle"></i>
                <span>New Process</span>
            </a>
        </div>
    }
    <div class="col-6 col-md-3">
        <a href="@Url.Action("Reports", "Dashboard")" class="quick-action-btn">
            <i class="fas fa-file-export"></i>
            <span>View Reports</span>
        </a>
    </div>
    @if (isAdmin || isHR || isAuditor)
    {
        <div class="col-6 col-md-3">
            <a href="@Url.Action("Performance", "Dashboard")" class="quick-action-btn">
                <i class="fas fa-chart-bar"></i>
                <span>View Performance</span>
            </a>
        </div>
    }
    @if (isAdmin || isAccountant || isAuditor)
    {
        <div class="col-6 col-md-3">
            <a href="@Url.Action("Budget", "Dashboard")" class="quick-action-btn">
                <i class="fas fa-peso-sign"></i>
                <span>Budget Status</span>
            </a>
        </div>
    }
</div>

<!-- KPI Summary Cards - Dashboard at a Glance -->
<div class="row g-3 mb-4">
    <!-- Total Employees Card -->
    <div class="col-6 col-lg-4 col-xl-2">
        <div class="stat-card kpi-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1" style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">Total Employees</p>
                    <h3 class="mb-2">@(ViewBag.TotalEmployees ?? 0)</h3>
                </div>
                <div class="stat-icon bg-primary" style="width: 45px; height: 45px; font-size: 1.2rem;">
                    <i class="fas fa-users"></i>
                </div>
            </div>
            <div style="font-size: 0.75rem; color: #27ae60;"><i class="fas fa-arrow-up"></i> All Active</div>
        </div>
    </div>

    <!-- Total Departments Card -->
    <div class="col-6 col-lg-4 col-xl-2">
        <div class="stat-card kpi-card">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1" style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">Departments</p>
                    <h3 class="mb-2">@(ViewBag.TotalDepartments ?? 0)</h3>
                </div>
                <div class="stat-icon bg-info" style="width: 45px; height: 45px; font-size: 1.2rem;">
                    <i class="fas fa-building"></i>
                </div>
            </div>
            <div style="font-size: 0.75rem; color: #3498db;"><i class="fas fa-arrow-right"></i> Organized</div>
        </div>
    </div>

    <!-- Active Processes Card -->
    <div class="col-6 col-lg-4 col-xl-2">
        <div class="stat-card kpi-card" onclick="window.location.href='@Url.Action("Operations", "Dashboard")';" style="cursor: pointer;">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1" style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">Active Processes</p>
                    <h3 class="mb-2">@(ViewBag.ActiveProcesses ?? 0)</h3>
                </div>
                <div class="stat-icon" style="background: linear-gradient(135deg, #1e3c72, #2a5298); width: 45px; height: 45px; font-size: 1.2rem;">
                    <i class="fas fa-clipboard-check"></i>
                </div>
            </div>
            <div style="font-size: 0.75rem; color: #e74c3c;"><i class="fas fa-exclamation-circle"></i> In Progress</div>
        </div>
    </div>

    <!-- Pending Requests Card -->
    <div class="col-6 col-lg-4 col-xl-2">
        <div class="stat-card kpi-card" onclick="window.location.href='@Url.Action("EmployeeRequests", "Dashboard")';" style="cursor: pointer;">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1" style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">Pending</p>
                    <h3 class="mb-2">@(ViewBag.PendingRequests ?? 0)</h3>
                </div>
                <div class="stat-icon bg-warning" style="width: 45px; height: 45px; font-size: 1.2rem;">
                    <i class="fas fa-hourglass-half"></i>
                </div>
            </div>
            <div style="font-size: 0.75rem; color: #f39c12;"><i class="fas fa-clock"></i> Awaiting Action</div>
        </div>
    </div>

    <!-- Completed Processes Card -->
    <div class="col-6 col-lg-4 col-xl-2">
        <div class="stat-card kpi-card" onclick="window.location.href='@Url.Action("ApprovedAndCompleted", "Dashboard")';" style="cursor: pointer;">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1" style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">Completed</p>
                    <h3 class="mb-2">@(ViewBag.CompletedProcesses ?? 0)</h3>
                </div>
                <div class="stat-icon bg-success" style="width: 45px; height: 45px; font-size: 1.2rem;">
                    <i class="fas fa-check-double"></i>
                </div>
            </div>
            <div style="font-size: 0.75rem; color: #27ae60;"><i class="fas fa-arrow-up"></i> This Period</div>
        </div>
    </div>

    <!-- Budget Utilization Card -->
    <div class="col-6 col-lg-4 col-xl-2">
        <div class="stat-card kpi-card" onclick="window.location.href='@Url.Action("Budget", "Dashboard")';" style="cursor: pointer;">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <p class="text-muted mb-1" style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase;">Budget Used</p>
                    <h3 class="mb-2">@(Math.Round(ViewBag.BudgetUtilizationRate ?? 0, 0))%</h3>
                </div>
                <div class="stat-icon" style="background: linear-gradient(135deg, #27ae60, #229954); width: 45px; height: 45px; font-size: 1.2rem;">
                    <i class="fas fa-percent"></i>
                </div>
            </div>
            <div style="font-size: 0.75rem; color: #16a085;">
                <span id="budgetStatus">Optimal</span>
            </div>
        </div>
    </div>
</div>

<!-- KPI Details Row -->
<div class="row g-3 mb-4">
    <div class="col-lg-12">
        <div class="chart-card">
            <div class="row g-3">
                <div class="col-md-3 border-end">
                    <h6 class="text-muted mb-2">Total Budget Allocated</h6>
                    <h4 class="mb-0">₱ @ViewBag.TotalBudgetAllocated?.ToString("N2")</h4>
                </div>
                <div class="col-md-3 border-end">
                    <h6 class="text-muted mb-2">Total Budget Used</h6>
                    <h4 class="mb-0 text-success">₱ @ViewBag.TotalBudgetUsed?.ToString("N2")</h4>
                </div>
                <div class="col-md-3 border-end">
                    <h6 class="text-muted mb-2">Remaining Budget</h6>
                    <h4 class="mb-0 text-info">₱ @((ViewBag.TotalBudgetAllocated - ViewBag.TotalBudgetUsed)?.ToString("N2"))</h4>
                </div>
                <div class="col-md-3">
                    <h6 class="text-muted mb-2">Utilization Rate</h6>
                    <div style="display: flex; align-items: center; gap: 10px;">
                        <div style="flex: 1;">
                            <div class="progress" style="height: 6px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: @(ViewBag.BudgetUtilizationRate ?? 0)%"></div>
                            </div>
                        </div>
                        <small>@(Math.Round(ViewBag.BudgetUtilizationRate ?? 0, 1))%</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="chart-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Monthly Report Summary</h5>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-primary active" onclick="updateChart('monthly')">Monthly</button>
                    <button class="btn btn-outline-primary" onclick="updateChart('quarterly')">Quarterly</button>
                </div>
            </div>
            <div class="chart-container">
                <canvas id="reportChart"></canvas>
            </div>
            <div class="mt-3">
                <h6 class="mb-2">Processes per Department</h6>
                <canvas id="processDeptChart" style="height:160px"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="chart-card">
            <h5>Report Distribution</h5>
            <div class="chart-container-sm">
                <canvas id="distributionChart"></canvas>
            </div>
            <div class="mt-2">
                <div class="row">
                    <div class="col-6">
                        <small class="text-muted d-block mb-1"><i class="fas fa-circle me-1" style="color: #1e3c72; font-size: 8px;"></i> Operational (35%)</small>
                        <small class="text-muted d-block mb-1"><i class="fas fa-circle me-1" style="color: #2a5298; font-size: 8px;"></i> Departmental (28%)</small>
                    </div>
                    <div class="col-6">
                        <small class="text-muted d-block mb-1"><i class="fas fa-circle me-1" style="color: #27ae60; font-size: 8px;"></i> Performance (22%)</small>
                        <small class="text-muted d-block mb-1"><i class="fas fa-circle me-1" style="color: #f39c12; font-size: 8px;"></i> Budget (15%)</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Activity and Departments Row -->
<div class="row g-3">
    <div class="col-lg-5">
        <div class="chart-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Recent Activity</h5>
                <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#activityModal">View All</button>
            </div>
            <ul class="activity-list">
                <li class="activity-item">
                    <div class="activity-icon" style="background: rgba(30,60,114,0.1); color: #1e3c72;">
                        <i class="fas fa-file-alt"></i>
                    </div>
                    <div class="activity-content">
                        <h6>Monthly Performance Report generated</h6>
                        <small>Admin - 2 hours ago</small>
                    </div>
                </li>
                <li class="activity-item">
                    <div class="activity-icon" style="background: rgba(39,174,96,0.1); color: #27ae60;">
                        <i class="fas fa-check-circle"></i>
                    </div>
                    <div class="activity-content">
                        <h6>Budget allocation approved</h6>
                        <small>Accountant - 5 hours ago</small>
                    </div>
                </li>
                <li class="activity-item">
                    <div class="activity-icon" style="background: rgba(52,152,219,0.1); color: #3498db;">
                        <i class="fas fa-user-plus"></i>
                    </div>
                    <div class="activity-content">
                        <h6>New employee onboarded</h6>
                        <small>HR - Yesterday</small>
                    </div>
                </li>
                <li class="activity-item">
                    <div class="activity-icon" style="background: rgba(241,196,15,0.1); color: #f1c40f;">
                        <i class="fas fa-exclamation-triangle"></i>
                    </div>
                    <div class="activity-content">
                        <h6>Budget threshold alert - Sales</h6>
                        <small>System - Yesterday</small>
                    </div>
                </li>
            </ul>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="data-table">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">User Role Summary</h5>
                <a href="@Url.Action("Performance", "Dashboard")" class="btn btn-sm btn-outline-primary">View Details</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Role</th>
                            <th>Users</th>
                            <th>Activity</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Performance", "Dashboard")'">
                            <td><i class="fas fa-user-shield text-danger me-2"></i>SuperAdmin</td>
                            <td>1</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" style="width: 100%"></div>
                                    </div>
                                    <small>100%</small>
                                </div>
                            </td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Performance", "Dashboard")'">
                            <td><i class="fas fa-user-cog text-primary me-2"></i>Admin</td>
                            <td>3</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" style="width: 95%"></div>
                                    </div>
                                    <small>95%</small>
                                </div>
                            </td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Performance", "Dashboard")'">
                            <td><i class="fas fa-calculator text-success me-2"></i>Accountant</td>
                            <td>5</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" style="width: 88%"></div>
                                    </div>
                                    <small>88%</small>
                                </div>
                            </td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Performance", "Dashboard")'">
                            <td><i class="fas fa-users text-info me-2"></i>HR</td>
                            <td>4</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" style="width: 92%"></div>
                                    </div>
                                    <small>92%</small>
                                </div>
                            </td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Performance", "Dashboard")'">
                            <td><i class="fas fa-user text-secondary me-2"></i>Employee</td>
                            <td>45</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" style="width: 85%"></div>
                                    </div>
                                    <small>85%</small>
                                </div>
                            </td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                        <tr style="cursor: pointer;" onclick="window.location.href='@Url.Action("Performance", "Dashboard")'">
                            <td><i class="fas fa-search text-warning me-2"></i>Auditor</td>
                            <td>2</td>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="progress flex-grow-1" style="height: 6px;">
                                        <div class="progress-bar bg-success" style="width: 90%"></div>
                                    </div>
                                    <small>90%</small>
                                </div>
                            </td>
                            <td><span class="badge bg-success">Active</span></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Activity Modal -->
<div class="modal fade" id="activityModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Activity Log</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="table-responsive">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Action</th>
                                <th>User</th>
                                <th>Department</th>
                                <th>Date/Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Generated Monthly Performance Report</td>
                                <td>Admin</td>
                                <td>All</td>
                                <td>Feb 15, 2026 10:30 AM</td>
                            </tr>
                            <tr>
                                <td>Approved Budget Allocation</td>
                                <td>Accountant</td>
                                <td>Finance</td>
                                <td>Feb 15, 2026 8:15 AM</td>
                            </tr>
                            <tr>
                                <td>Onboarded New Employee</td>
                                <td>HR Manager</td>
                                <td>HR</td>
                                <td>Feb 14, 2026 3:45 PM</td>
                            </tr>
                            <tr>
                                <td>Budget Threshold Alert Triggered</td>
                                <td>System</td>
                                <td>Sales</td>
                                <td>Feb 14, 2026 2:00 PM</td>
                            </tr>
                            <tr>
                                <td>Generated Departmental Report</td>
                                <td>HR Manager</td>
                                <td>HR</td>
                                <td>Feb 14, 2026 11:20 AM</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Report Summary Chart - properly constrained
    const reportCtx = document.getElementById('reportChart').getContext('2d');
    const reportChart = new Chart(reportCtx, {
        type: 'bar',
        data: {
            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
            datasets: [{
                label: 'Operational',
                data: [12, 15, 18, 14, 20, 22],
                backgroundColor: '#1e3c72',
                borderRadius: 4,
                barThickness: 'flex',
                maxBarThickness: 30
            }, {
                label: 'Departmental',
                data: [8, 10, 12, 9, 15, 14],
                backgroundColor: '#2a5298',
                borderRadius: 4,
                barThickness: 'flex',
                maxBarThickness: 30
            }, {
                label: 'Performance',
                data: [5, 7, 8, 6, 10, 9],
                backgroundColor: '#27ae60',
                borderRadius: 4,
                barThickness: 'flex',
                maxBarThickness: 30
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                    labels: { 
                        boxWidth: 12, 
                        padding: 15, 
                        font: { size: 11 },
                        usePointStyle: true
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    grid: { color: 'rgba(0,0,0,0.05)' },
                    ticks: { font: { size: 10 } }
                },
                x: {
                    grid: { display: false },
                    ticks: { font: { size: 10 } }
                }
            }
        }
    });

    // Distribution Chart - properly constrained doughnut
    const distCtx = document.getElementById('distributionChart').getContext('2d');
    const distChart = new Chart(distCtx, {
        type: 'doughnut',
        data: {
            labels: ['Operational', 'Departmental', 'Performance', 'Budget'],
            datasets: [{
                data: [35, 28, 22, 15],
                backgroundColor: ['#1e3c72', '#2a5298', '#27ae60', '#f39c12'],
                borderWidth: 0,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(context) {
                            return context.label + ': ' + context.parsed + '%';
                        }
                    }
                }
            },
            cutout: '55%'
        }
    });

    // Update chart function
    function updateChart(period) {
        document.querySelectorAll('.btn-group .btn').forEach(btn => btn.classList.remove('active'));
        event.target.classList.add('active');
        
        if (period === 'quarterly') {
            reportChart.data.labels = ['Q1', 'Q2', 'Q3', 'Q4'];
            reportChart.data.datasets[0].data = [45, 52, 48, 55];
            reportChart.data.datasets[1].data = [30, 35, 32, 38];
            reportChart.data.datasets[2].data = [20, 25, 22, 28];
        } else {
            reportChart.data.labels = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'];
            reportChart.data.datasets[0].data = [12, 15, 18, 14, 20, 22];
            reportChart.data.datasets[1].data = [8, 10, 12, 9, 15, 14];
            reportChart.data.datasets[2].data = [5, 7, 8, 6, 10, 9];
        }
        reportChart.update();
    }

    // Processes per department chart
    (function() {
        const labels = @Html.Raw(Json.Serialize(ViewBag.ProcessDeptLabels ?? new List<string>()));
        const counts = @Html.Raw(Json.Serialize(ViewBag.ProcessDeptCounts ?? new List<int>()));

        // Fixed canvas height to prevent vertical stretching
        const canvas = document.getElementById('processDeptChart');
        canvas.height = 160; // pixels

        const ctx = canvas.getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Processes',
                    data: counts,
                    backgroundColor: '#2a5298',
                    borderRadius: 6,
                    maxBarThickness: 40,
                    barPercentage: 0.6,
                    categoryPercentage: 0.7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                aspectRatio: Math.max( (labels && labels.length) ? labels.length : 4, 4),
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { stepSize: 1 } },
                    x: { grid: { display: false }, ticks: { autoSkip: true, maxRotation: 45, minRotation: 0 } }
                },
                plugins: { legend: { display: false } }
            }
        });
    })();
</script>
}

