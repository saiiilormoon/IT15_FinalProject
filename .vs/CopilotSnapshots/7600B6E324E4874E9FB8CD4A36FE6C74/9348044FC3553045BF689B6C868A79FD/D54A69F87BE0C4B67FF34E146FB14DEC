using CVM_FinalProject.Data;
using CVM_FinalProject.Models;
using CVM_FinalProject.Models.ViewModels;
using CVM_FinalProject.Services;
using CVM_FinalProject.Helpers;
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Identity;
using Microsoft.AspNetCore.Mvc;
using Microsoft.EntityFrameworkCore;

namespace CVM_FinalProject.Controllers
{
    /// <summary>
    /// Dashboard Controller with Role-Based Access Control
    /// Implements different views and functionalities based on user roles:
    /// - SuperAdmin: Full system access
    /// - Admin: Administrative operations
    /// - Accountant: Financial management
    /// - HR: Human resources management
    /// - Auditor: Read-only audit access
    /// - Employee: Limited personal access
    /// </summary>
    [Authorize]
    public class DashboardRBACController : Controller
    {
        private readonly UserManager<ApplicationUser> _userManager;
        private readonly SignInManager<ApplicationUser> _signInManager;
        private readonly ILogger<DashboardRBACController> _logger;
        private readonly ApplicationDbContext _context;
        private readonly DepartmentService _departmentService;
        private readonly EmployeeService _employeeService;
        private readonly PerformanceService _performanceService;
        private readonly BudgetService _budgetService;
        private readonly ReportService _reportService;
        private readonly AuditService _auditService;

        public DashboardRBACController(
            UserManager<ApplicationUser> userManager,
            SignInManager<ApplicationUser> signInManager,
            ILogger<DashboardRBACController> logger,
            ApplicationDbContext context,
            DepartmentService departmentService,
            EmployeeService employeeService,
            PerformanceService performanceService,
            BudgetService budgetService,
            ReportService reportService,
            AuditService auditService)
        {
            _userManager = userManager;
            _signInManager = signInManager;
            _logger = logger;
            _context = context;
            _departmentService = departmentService;
            _employeeService = employeeService;
            _performanceService = performanceService;
            _budgetService = budgetService;
            _reportService = reportService;
            _auditService = auditService;
        }

        /// <summary>
        /// Get current user's role and information
        /// </summary>
        private async Task SetUserViewBagAsync()
        {
            var user = await _userManager.GetUserAsync(User);
            if (user == null) return;

            ViewBag.UserEmail = user.Email ?? "user@example.com";
            ViewBag.UserFirstName = user.FirstName ?? "";
            ViewBag.UserName = user.FullName ?? user.FirstName ?? "User";
            ViewBag.FullName = user.FullName ?? "User";
            ViewBag.UserLastName = user.LastName ?? "";
            ViewBag.UserPhone = user.PhoneNumber ?? "";

            var roles = await _userManager.GetRolesAsync(user);
            ViewBag.UserRole = roles.FirstOrDefault() ?? "Employee";
            ViewBag.UserRoles = roles;
            ViewBag.IsAdmin = roles.Contains("Admin") || roles.Contains("SuperAdmin");
            ViewBag.IsAccountant = roles.Contains("Accountant");
            ViewBag.IsHR = roles.Contains("HR");
            ViewBag.IsAuditor = roles.Contains("Auditor");
            ViewBag.IsEmployee = roles.Contains("Employee");
            ViewBag.IsSuperAdmin = roles.Contains("SuperAdmin");
        }

        /// <summary>
        /// Check if user is approved
        /// </summary>
        private async Task<bool> IsUserApprovedAsync()
        {
            var user = await _userManager.GetUserAsync(User);
            return user?.IsApproved ?? false;
        }

        /// <summary>
        /// Get user's role
        /// </summary>
        private async Task<string> GetUserRoleAsync()
        {
            var user = await _userManager.GetUserAsync(User);
            if (user == null) return "Employee";

            var roles = await _userManager.GetRolesAsync(user);
            return roles.FirstOrDefault() ?? "Employee";
        }

        /// <summary>
        /// Role-Based Dashboard - The main entry point
        /// Shows different data based on user's role
        /// </summary>
        [HttpGet("dashboard/rbac")]
        public async Task<IActionResult> IndexRBAC()
        {
            if (!await IsUserApprovedAsync())
            {
                return RedirectToAction("PendingApproval");
            }

            await SetUserViewBagAsync();
            var userRole = ViewBag.UserRole as string;
            var user = await _userManager.GetUserAsync(User);

            // Initialize dashboard view model
            var dashboard = new RoleBasedDashboardViewModel
            {
                UserRole = userRole,
                UserName = user?.FullName ?? "User",
                UserEmail = user?.Email ?? "",
                DataVisibility = RoleBasedAuthorizationHelper.GetDashboardVisibility(userRole)
            };

            // Load KPI Metrics (visible to all roles)
            await LoadKPIMetricsAsync(dashboard);

            // Load role-specific data
            switch (userRole)
            {
                case "SuperAdmin":
                case "Admin":
                    await LoadAdminDashboardAsync(dashboard);
                    break;

                case "Accountant":
                    await LoadAccountantDashboardAsync(dashboard);
                    break;

                case "HR":
                    await LoadHRDashboardAsync(dashboard);
                    break;

                case "Auditor":
                    await LoadAuditorDashboardAsync(dashboard);
                    break;

                case "Employee":
                    await LoadEmployeeDashboardAsync(dashboard);
                    break;
            }

            return View("DashboardRBAC", dashboard);
        }

        /// <summary>
        /// Load KPI metrics visible to all roles
        /// </summary>
        private async Task LoadKPIMetricsAsync(RoleBasedDashboardViewModel dashboard)
        {
            dashboard.TotalEmployees = await _context.Employees.CountAsync();
            dashboard.TotalDepartments = await _context.Departments.CountAsync();
            dashboard.ActiveProcesses = await _context.OperationalProcesses
                .CountAsync(p => p.Status == ProcessStatus.Approved || p.Status == ProcessStatus.Pending);
            dashboard.CompletedProcesses = await _context.OperationalProcesses
                .CountAsync(p => p.Status == ProcessStatus.Completed);
            dashboard.PendingRequests = await _context.EmployeeRequests
                .CountAsync(r => r.Status == RequestStatus.Pending);

            // Budget metrics
            var totalBudgetAllocated = await _context.Budgets.SumAsync(b => (decimal?)b.AllocatedAmount) ?? 0;
            var totalBudgetUsed = await _context.Budgets.SumAsync(b => (decimal?)b.UsedAmount) ?? 0;

            dashboard.TotalBudgetAllocated = totalBudgetAllocated;
            dashboard.TotalBudgetUsed = totalBudgetUsed;
            dashboard.BudgetUtilizationRate = totalBudgetAllocated > 0 
                ? Math.Round((totalBudgetUsed / totalBudgetAllocated * 100), 2) 
                : 0;

            // Chart data
            await LoadProcessChartDataAsync(dashboard);
            await LoadRequestChartDataAsync(dashboard);
        }

        /// <summary>
        /// Load Admin/SuperAdmin specific dashboard
        /// Shows full system overview
        /// </summary>
        private async Task LoadAdminDashboardAsync(RoleBasedDashboardViewModel dashboard)
        {
            // Load all department budget information
            var departmentBudgets = await _context.Budgets
                .GroupBy(b => b.DepartmentId)
                .Select(g => new
                {
                    DeptId = g.Key,
                    Allocated = g.Sum(b => b.AllocatedAmount),
                    Used = g.Sum(b => b.UsedAmount)
                })
                .ToListAsync();

            foreach (var budgetGroup in departmentBudgets)
            {
                var dept = await _context.Departments.FindAsync(budgetGroup.DeptId);
                if (dept != null)
                {
                    dashboard.DepartmentBudgets.Add(new DepartmentBudgetSummary
                    {
                        DepartmentId = budgetGroup.DeptId,
                        DepartmentName = dept.DepartmentName,
                        AllocatedAmount = budgetGroup.Allocated,
                        UsedAmount = budgetGroup.Used,
                        RemainingAmount = budgetGroup.Allocated - budgetGroup.Used,
                        UtilizationPercentage = budgetGroup.Allocated > 0
                            ? Math.Round((budgetGroup.Used / budgetGroup.Allocated * 100), 2)
                            : 0
                    });
                }
            }

            // Load audit logs (last 10)
            dashboard.TotalAuditLogs = await _context.AuditLogs.CountAsync();
            dashboard.LastAuditDate = await _context.AuditLogs
                .OrderByDescending(a => a.Timestamp)
                .Select(a => a.Timestamp)
                .FirstOrDefaultAsync();
        }

        /// <summary>
        /// Load Accountant-specific dashboard
        /// Shows financial information only
        /// </summary>
        private async Task LoadAccountantDashboardAsync(RoleBasedDashboardViewModel dashboard)
        {
            var departmentBudgets = await _context.Budgets
                .GroupBy(b => b.DepartmentId)
                .Select(g => new
                {
                    DeptId = g.Key,
                    Allocated = g.Sum(b => b.AllocatedAmount),
                    Used = g.Sum(b => b.UsedAmount)
                })
                .ToListAsync();

            foreach (var budgetGroup in departmentBudgets)
            {
                var dept = await _context.Departments.FindAsync(budgetGroup.DeptId);
                if (dept != null)
                {
                    dashboard.DepartmentBudgets.Add(new DepartmentBudgetSummary
                    {
                        DepartmentId = budgetGroup.DeptId,
                        DepartmentName = dept.DepartmentName,
                        AllocatedAmount = budgetGroup.Allocated,
                        UsedAmount = budgetGroup.Used,
                        RemainingAmount = budgetGroup.Allocated - budgetGroup.Used,
                        UtilizationPercentage = budgetGroup.Allocated > 0
                            ? Math.Round((budgetGroup.Used / budgetGroup.Allocated * 100), 2)
                            : 0
                    });
                }
            }
        }

        /// <summary>
        /// Load HR-specific dashboard
        /// Shows human resources information
        /// </summary>
        private async Task LoadHRDashboardAsync(RoleBasedDashboardViewModel dashboard)
        {
            var departments = await _context.Departments
                .Select(d => new
                {
                    DeptId = d.DepartmentId,
                    DeptName = d.DepartmentName,
                    EmployeeCount = d.Employees.Count
                })
                .ToListAsync();

            var performanceStats = await _context.PerformanceRecords
                .GroupBy(p => p.EmployeeId)
                .Select(g => new
                {
                    EmployeeId = g.Key,
                    AverageRating = g.Average(p => p.PerformanceRating)
                })
                .ToListAsync();

            foreach (var dept in departments)
            {
                var deptPerformances = performanceStats.Where(p => p.EmployeeId == dept.DeptId).ToList();
                dashboard.DepartmentPerformance.Add(new DepartmentPerformanceSummary
                {
                    DepartmentId = dept.DeptId,
                    DepartmentName = dept.DeptName,
                    EmployeeCount = dept.EmployeeCount,
                    AverageRating = deptPerformances.Any() 
                        ? Math.Round(deptPerformances.Average(p => p.AverageRating), 2) 
                        : 0,
                    CompletedTasks = 0, // Calculate from performance records
                    PendingTasks = 0 // Calculate from performance records
                });
            }

            dashboard.AveragePerformanceRating = performanceStats.Any()
                ? Math.Round(performanceStats.Average(p => p.AverageRating), 2)
                : 0;

            dashboard.HighPerformers = performanceStats.Count(p => p.AverageRating >= 4.0);
        }

        /// <summary>
        /// Load Auditor-specific dashboard
        /// Shows read-only audit information
        /// </summary>
        private async Task LoadAuditorDashboardAsync(RoleBasedDashboardViewModel dashboard)
        {
            dashboard.TotalAuditLogs = await _context.AuditLogs.CountAsync();
            var lastAudit = await _context.AuditLogs
                .OrderByDescending(a => a.CreatedAt)
                .FirstOrDefaultAsync();
            
            if (lastAudit != null)
            {
                dashboard.LastAuditDate = lastAudit.CreatedAt;
            }

            // Load recent audit activity
            var recentLogs = await _context.AuditLogs
                .OrderByDescending(a => a.CreatedAt)
                .Take(10)
                .Select(a => new AuditSummary
                {
                    AuditLogId = a.AuditLogId,
                    Action = a.Action,
                    PerformedBy = a.UserId,
                    PerformedAt = a.CreatedAt,
                    Details = a.Details
                })
                .ToListAsync();

            dashboard.RecentAuditActivity = recentLogs;
        }

        /// <summary>
        /// Load Employee-specific dashboard
        /// Shows limited personal information
        /// </summary>
        private async Task LoadEmployeeDashboardAsync(RoleBasedDashboardViewModel dashboard)
        {
            // Employees see only their own requests and public information
            var user = await _userManager.GetUserAsync(User);
            var employeeRequests = await _context.EmployeeRequests
                .Where(r => r.SubmittedByUserId == user.Id)
                .CountAsync();

            ViewBag.EmployeeOwnRequestsCount = employeeRequests;
        }

        /// <summary>
        /// Load process-related chart data
        /// </summary>
        private async Task LoadProcessChartDataAsync(RoleBasedDashboardViewModel dashboard)
        {
            var processesByDept = await _context.OperationalProcesses
                .GroupBy(p => p.Department)
                .Select(g => new { Department = g.Key ?? "(Unassigned)", Count = g.Count() })
                .OrderByDescending(x => x.Count)
                .ToListAsync();

            dashboard.ProcessDeptLabels = processesByDept.Select(x => x.Department).ToList();
            dashboard.ProcessDeptCounts = processesByDept.Select(x => x.Count).ToList();

            var processStatusCounts = await _context.OperationalProcesses
                .GroupBy(p => p.Status)
                .Select(g => new { Status = g.Key.ToString(), Count = g.Count() })
                .ToListAsync();

            var processPendingCount = processStatusCounts.FirstOrDefault(x => x.Status == "Pending")?.Count ?? 0;
            var processApprovedCount = processStatusCounts.FirstOrDefault(x => x.Status == "Approved" || x.Status == "Active")?.Count ?? 0;
            var processCompletedCount = processStatusCounts.FirstOrDefault(x => x.Status == "Completed")?.Count ?? 0;

            dashboard.ProcessStatusLabels = new[] { "Pending", "Approved", "Completed" }.ToList();
            dashboard.ProcessStatusCounts = new[] { processPendingCount, processApprovedCount, processCompletedCount }.ToList();
        }

        /// <summary>
        /// Load request-related chart data
        /// </summary>
        private async Task LoadRequestChartDataAsync(RoleBasedDashboardViewModel dashboard)
        {
            var requestStatusCounts = await _context.EmployeeRequests
                .GroupBy(r => r.Status)
                .Select(g => new { Status = g.Key.ToString(), Count = g.Count() })
                .ToListAsync();

            var pendingCount = requestStatusCounts.FirstOrDefault(x => x.Status == "Pending")?.Count ?? 0;
            var inProgressCount = requestStatusCounts.FirstOrDefault(x => x.Status == "InProgress")?.Count ?? 0;
            var completedCount = requestStatusCounts.FirstOrDefault(x => x.Status == "Completed")?.Count ?? 0;
            var rejectedCount = requestStatusCounts.FirstOrDefault(x => x.Status == "Rejected")?.Count ?? 0;

            dashboard.RequestStatusLabels = new[] { "Pending", "In Progress", "Completed", "Rejected" }.ToList();
            dashboard.RequestStatusCounts = new[] { pendingCount, inProgressCount, completedCount, rejectedCount }.ToList();

            // Monthly trends
            var sixMonthsAgo = DateTime.UtcNow.AddMonths(-6);
            var monthlyRequests = await _context.EmployeeRequests
                .Where(r => r.CreatedAt >= sixMonthsAgo)
                .GroupBy(r => new { r.CreatedAt.Year, r.CreatedAt.Month })
                .Select(g => new { YearMonth = g.Key, Count = g.Count() })
                .OrderBy(x => x.YearMonth.Year).ThenBy(x => x.YearMonth.Month)
                .ToListAsync();

            if (monthlyRequests.Any())
            {
                dashboard.MonthlyRequestLabels = monthlyRequests
                    .Select(x => DateTime.ParseExact($"{x.YearMonth.Year}-{x.YearMonth.Month:D2}", "yyyy-MM", 
                        System.Globalization.CultureInfo.InvariantCulture).ToString("MMM yyyy"))
                    .ToList();
                dashboard.MonthlyRequestCounts = monthlyRequests.Select(x => x.Count).ToList();
            }
            else
            {
                for (int i = 5; i >= 0; i--)
                {
                    var date = DateTime.UtcNow.AddMonths(-i);
                    dashboard.MonthlyRequestLabels.Add(date.ToString("MMM yyyy"));
                    dashboard.MonthlyRequestCounts.Add(0);
                }
            }
        }

        /// <summary>
        /// Redirect to pending approval if user not approved
        /// </summary>
        public async Task<IActionResult> PendingApproval()
        {
            var user = await _userManager.GetUserAsync(User);
            ViewBag.UserName = user?.FirstName ?? "User";
            ViewBag.UserEmail = user?.Email ?? "";
            return View();
        }

        /// <summary>
        /// Settings page - accessible by all authenticated users
        /// </summary>
        public async Task<IActionResult> Settings()
        {
            if (!await IsUserApprovedAsync())
            {
                return RedirectToAction("PendingApproval");
            }
            await SetUserViewBagAsync();
            return View();
        }
    }
}
