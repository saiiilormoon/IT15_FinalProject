@{
    ViewData["Title"] = "Financial Dashboard";
    var userRole = ViewBag.UserRole as string ?? "Employee";
    var userName = ViewBag.UserName as string ?? "User";
}

<!-- Dashboard Header -->
<div class="page-header mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h2 mb-1">Welcome back, <span class="text-primary">@userName</span>!</h1>
            <p class="text-muted mb-0">Here's your organization's financial summary for today.</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <span class="badge bg-primary px-3 py-2 fs-6">@userRole</span>
            <a href="@Url.Action("Index", "Dashboard")" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-arrow-left me-2"></i>Go Back to Dashboard
            </a>
        </div>
    </div>
</div>

<!-- Quick Actions - Enhanced with Full Capabilities -->
<div class="row mb-5">
    <div class="col-12">
        <div class="d-flex gap-2 flex-wrap">
            <a href="#" class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#createBudgetModal">
                <i class="fas fa-plus-circle"></i>
                <span>Create Budget</span>
            </a>
            <a href="@Url.Action("AccountantDashboard", "Dashboard")" class="financial-action-btn">
                <i class="fas fa-chart-bar"></i>
                <span>Budget Analysis</span>
            </a>
            <a href="@Url.Action("ExpenseTracking", "Dashboard")" class="financial-action-btn">
                <i class="fas fa-receipt"></i>
                <span>Track Expenses</span>
            </a>
            <a href="@Url.Action("FinancialReports", "Dashboard")" class="financial-action-btn">
                <i class="fas fa-file-pdf"></i>
                <span>Financial Reports</span>
            </a>
            <a href="#" class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#exportModal">
                <i class="fas fa-download"></i>
                <span>Export Data</span>
            </a>
            <a href="#" class="financial-action-btn" data-bs-toggle="modal" data-bs-target="#forecastModal">
                <i class="fas fa-chart-line"></i>
                <span>Budget Forecast</span>
            </a>
        </div>
    </div>
</div>

<!-- Operational Processes - SUPER ADMIN CONTROL -->
<div class="row mb-4">
    <!-- Operational Processes for Approval -->
    <div class="col-lg-8 mb-3">
        <div class="chart-card">
            <h5>Operational Processes - Approval & Completion</h5>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Process ID</th>
                            <th>Process Name</th>
                            <th>Department</th>
                            <th>Assigned To</th>
                            <th>Current Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="processesTableBody">
                        @{
                            var operationalProcesses = ViewBag.OperationalProcesses as List<CVM_FinalProject.Models.OperationalProcess>;
                            if (operationalProcesses != null && operationalProcesses.Count > 0)
                            {
                                foreach (var process in operationalProcesses)
                                {
                                    string statusBadgeClass = process.Status == CVM_FinalProject.Models.ProcessStatus.Pending ? "bg-warning" : 
                                                             (process.Status == CVM_FinalProject.Models.ProcessStatus.Approved ? "bg-success" : "bg-secondary");
                                    string statusText = process.Status.ToString();
                                    
                                    <tr data-process-id="@process.ProcessId">
                                        <td><strong>#@process.ProcessId</strong></td>
                                        <td>@process.Name</td>
                                        <td>@process.Department</td>
                                        <td>@process.AssignedTo</td>
                                        <td><span class="badge @statusBadgeClass">@statusText</span></td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                @if (process.Status == CVM_FinalProject.Models.ProcessStatus.Pending)
                                                {
                                                    <button type="button" class="btn btn-outline-success" title="Approve Process" onclick="approveProcessAjax('@process.ProcessId', this)">
                                                        <i class="fas fa-check me-1"></i>Approve
                                                    </button>
                                                }
                                                @if (process.Status == CVM_FinalProject.Models.ProcessStatus.Approved)
                                                {
                                                    <button type="button" class="btn btn-outline-primary" title="Mark as Completed" onclick="completeProcessAjax('@process.ProcessId', this)">
                                                        <i class="fas fa-check-double me-1"></i>Complete
                                                    </button>
                                                }
                                                @if (process.Status == CVM_FinalProject.Models.ProcessStatus.Pending || process.Status == CVM_FinalProject.Models.ProcessStatus.Approved)
                                                {
                                                    <button type="button" class="btn btn-outline-info" title="View Details" onclick="viewProcessDetails('@process.ProcessId', '@process.Name', '@process.Department', '@process.AssignedTo', '@statusText')">
                                                        <i class="fas fa-eye"></i>
                                                    </button>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">No processes available for action</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Department Budget Status & Budget Health -->
    <!-- Department Budget Status -->
    <div class="col-lg-4 mb-3">

    <!-- Budget Health Summary - Compact -->
    <div class="col-lg-4 mb-3">
        <div class="chart-card">
            <h5>Budget Health</h5>
            <div class="p-3">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Healthy</span>
                        <strong>70%</strong>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 70%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">At Risk</span>
                        <strong>25%</strong>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-warning" style="width: 25%"></div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small">Over Budget</span>
                        <strong>5%</strong>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-danger" style="width: 5%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Budget Modal - NEW FEATURE -->
<div class="modal fade" id="createBudgetModal" tabindex="-1" aria-labelledby="createBudgetModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createBudgetModalLabel">
                    <i class="fas fa-plus-circle me-2"></i>Create New Budget
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-action="CreateBudget" asp-controller="Dashboard">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="departmentSelect" class="form-label">Department</label>
                        <select id="departmentSelect" name="departmentId" class="form-select form-select-lg" required>
                            <option value="">-- Select Department --</option>
                            <option value="1">Operations</option>
                            <option value="2">IT</option>
                            <option value="3">Finance</option>
                            <option value="4">HR</option>
                            <option value="5">Marketing</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label for="budgetPeriod" class="form-label">Budget Period</label>
                        <input type="text" id="budgetPeriod" name="budgetPeriod" class="form-control form-control-lg" 
                               placeholder="e.g., FY 2024-2025" value="FY 2024-2025" required />
                    </div>

                    <div class="mb-3">
                        <label for="allocatedAmount" class="form-label">Allocated Amount (?)</label>
                        <input type="number" id="allocatedAmount" name="allocatedAmount" class="form-control form-control-lg" 
                               placeholder="0.00" step="0.01" min="0" required />
                    </div>

                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>
                        <strong>Note:</strong> Budget will be created in pending status and requires admin approval before activation.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-check me-2"></i>Create Budget
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Export Modal -->
<div class="modal fade" id="exportModal" tabindex="-1" aria-labelledby="exportModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="exportModalLabel">Export Financial Data</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Select format to export financial reports:</p>
                <div class="btn-group-vertical w-100" role="group">
                    <button type="button" class="btn btn-outline-primary text-start" onclick="exportFinancialData('excel')">
                        <i class="fas fa-file-excel me-2"></i>
                        Export to Excel (.xlsx)
                    </button>
                    <button type="button" class="btn btn-outline-primary text-start" onclick="exportFinancialData('pdf')">
                        <i class="fas fa-file-pdf me-2"></i>
                        Export to PDF
                    </button>
                    <button type="button" class="btn btn-outline-primary text-start" onclick="exportFinancialData('csv')">
                        <i class="fas fa-file-csv me-2"></i>
                        Export to CSV
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Forecast Modal -->
<div class="modal fade" id="forecastModal" tabindex="-1" aria-labelledby="forecastModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="forecastModalLabel">Budget Forecast</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="mb-3">Projected Budget Status:</p>
                <div class="alert alert-info">
                    <strong>Current Spending Rate:</strong> 15% per week
                </div>
                <div class="alert alert-warning">
                    <strong>Projected Year-End:</strong> 95% utilization (OVER BUDGET by 5%)
                </div>
                <div class="alert alert-success">
                    <strong>Recommendation:</strong> Implement cost controls in Q3 to avoid overage.
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function exportFinancialData(format) {
            try {
                // Get current date for filename
                const today = new Date();
                const dateStr = today.toISOString().split('T')[0];
                
                // Create download link
                const link = document.createElement('a');
                link.href = '@Url.Action("ExportAllReports", "Dashboard")?format=' + format;
                link.download = 'financial-report-' + dateStr + '.' + (format === 'excel' ? 'xlsx' : format);
                
                // Trigger download
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);
                
                // Close modal
                const modal = bootstrap.Modal.getInstance(document.getElementById('exportModal'));
                if (modal) {
                    modal.hide();
                }
                
                // Show success message
                showSuccessAlert('Financial data exported successfully!');
            } catch (error) {
                console.error('Export error:', error);
                showErrorAlert('Failed to export financial data. Please try again.');
            }
        }
        
        function showSuccessAlert(message) {
            const alertHtml = '<div class="alert alert-success alert-dismissible fade show" role="alert">' +
                '<i class="fas fa-check-circle me-2"></i>' + message +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '</div>';
            
            const container = document.querySelector('.page-header');
            if (container) {
                container.insertAdjacentHTML('afterend', alertHtml);
                setTimeout(() => {
                    const alert = document.querySelector('.alert');
                    if (alert) alert.remove();
                }, 3000);
            }
        }
        
        function showErrorAlert(message) {
            const alertHtml = '<div class="alert alert-danger alert-dismissible fade show" role="alert">' +
                '<i class="fas fa-exclamation-circle me-2"></i>' + message +
                '<button type="button" class="btn-close" data-bs-dismiss="alert"></button>' +
                '</div>';
            
            const container = document.querySelector('.page-header');
            if (container) {
                container.insertAdjacentHTML('afterend', alertHtml);
                setTimeout(() => {
                    const alert = document.querySelector('.alert');
                    if (alert) alert.remove();
                }, 4000);
            }
        }
    </script>
}


