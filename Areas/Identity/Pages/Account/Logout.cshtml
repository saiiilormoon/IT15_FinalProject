@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<header>
    <h1>@ViewData["Title"]</h1>
    @{
        if (User.Identity?.IsAuthenticated ?? false)
        {
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post" id="logoutForm">
                <button type="submit" class="nav-link btn btn-link text-dark" style="display: none;">Click here to Logout</button>
            </form>
            <p>Logging out...</p>
            <script>
                // Auto-submit the logout form immediately
                document.getElementById('logoutForm').submit();
            </script>
        }
        else
        {
            <p>You have successfully logged out of the application.</p>
        }
    }
</header>
