@page
@model RegisterConfirmationModel
@{
    ViewData["Title"] = "Registration Successful";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Registration Successful - CVM MIS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4ecf7 100%);
            min-height: 100vh;
        }
        .confirmation-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.15);
            border: none;
            max-width: 520px;
        }
        .success-icon {
            width: 90px;
            height: 90px;
            background: linear-gradient(135deg, #27ae60 0%, #2ecc71 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: white;
            font-size: 40px;
            animation: scaleIn 0.5s ease-out;
        }
        @@keyframes scaleIn {
            0% { transform: scale(0); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
        @@keyframes fadeInUp {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        .animate-in {
            animation: fadeInUp 0.6s ease-out forwards;
        }
        .btn-primary-custom {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            border: none;
            border-radius: 10px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
            color: white;
        }
        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(30,60,114,0.3);
            color: white;
        }
        .btn-outline-custom {
            border: 2px solid #1e3c72;
            color: #1e3c72;
            border-radius: 10px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
            background: transparent;
        }
        .btn-outline-custom:hover {
            background: #1e3c72;
            color: white;
        }
        .back-btn {
            position: absolute;
            top: 20px;
            left: 20px;
            color: #1e3c72;
            text-decoration: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: white;
            border-radius: 30px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
        }
        .back-btn:hover {
            background: #1e3c72;
            color: white;
            transform: translateX(-5px);
        }
        .info-box {
            background: linear-gradient(135deg, rgba(30,60,114,0.08), rgba(42,82,152,0.08));
            border: 1px solid rgba(30,60,114,0.2);
            border-radius: 12px;
            padding: 20px;
        }
        .step-number {
            width: 28px;
            height: 28px;
            background: linear-gradient(135deg, #1e3c72, #2a5298);
            color: white;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            font-weight: 600;
            margin-right: 10px;
        }
    </style>
</head>
<body>

    <!-- Back Button -->
    <a href="/" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Home
    </a>

    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh; padding: 40px 0;">
        <div class="card confirmation-card p-4 p-md-5 text-center animate-in">
            
            <img src="~/images/logo.png" alt="CVM MIS Logo" height="60" class="mb-3 mx-auto" onerror="this.style.display='none'" />
            
            <div class="success-icon">
                <i class="fas fa-check"></i>
            </div>
            
            <h2 class="fw-bold mb-2" style="color: #1e3c72;">Welcome, @Model.FirstName!</h2>
            <h5 class="text-muted mb-4">Your account has been created successfully!</h5>

            <div class="info-box text-start mb-4">
                <p class="mb-3 fw-semibold" style="color: #1e3c72;">
                    <i class="fas fa-info-circle me-2"></i>What happens next?
                </p>
                <div class="mb-2">
                    <span class="step-number">1</span>
                    <span class="text-muted">Verify your email address by clicking the button below</span>
                </div>
                <div class="mb-2">
                    <span class="step-number">2</span>
                    <span class="text-muted">Wait for admin approval to access the system</span>
                </div>
                <div>
                    <span class="step-number">3</span>
                    <span class="text-muted">Once approved, login with your credentials</span>
                </div>
            </div>

            @if (Model.DisplayConfirmAccountLink)
            {
                <a id="confirm-link" href="@Model.EmailConfirmationUrl" class="btn btn-primary-custom w-100 mb-3">
                    <i class="fas fa-envelope-open-text me-2"></i>Confirm Your Email Address
                </a>
                <p class="text-muted small mb-4">
                    <i class="fas fa-clock me-1"></i>
                    Your account will be reviewed by an administrator after email confirmation.
                </p>
            }
            else
            {
                <div class="alert alert-warning" style="background: rgba(241,196,15,0.15); border: 1px solid rgba(241,196,15,0.3); border-radius: 10px;">
                    <i class="fas fa-hourglass-half me-2" style="color: #f39c12;"></i>
                    <span style="color: #856404;">Please check your email (<strong>@Model.Email</strong>) for the confirmation link.</span>
                </div>
                
                <p class="text-muted small mb-4">
                    After confirming your email, an administrator will review and approve your account.
                </p>
            }

            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-page="./Login" class="btn btn-outline-custom">
                    <i class="fas fa-sign-in-alt me-2"></i>Go to Login
                </a>
                <a href="/" class="btn btn-outline-secondary" style="border-radius: 10px; padding: 12px 30px;">
                    <i class="fas fa-home me-2"></i>Back to Home
                </a>
            </div>

            <div class="mt-4 pt-4" style="border-top: 1px solid #eee;">
                <small class="text-muted">
                    <i class="fas fa-shield-alt me-1"></i>
                    Your account is secured with Centralized MIS
                </small>
            </div>

        </div>
    </div>

</body>
</html>

