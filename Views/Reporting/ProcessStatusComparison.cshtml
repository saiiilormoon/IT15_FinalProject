@model CVM_FinalProject.Models.ViewModels.ProcessStatusComparisonViewModel
@{
    ViewData["Title"] = "Process Status Comparison";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .report-container { background: white; border-radius: 12px; padding: 25px; box-shadow: 0 3px 15px rgba(0,0,0,0.05); }
    .report-header { border-bottom: 3px solid #2a5298; padding-bottom: 15px; margin-bottom: 25px; }
    .report-title { color: #1e3c72; font-size: 28px; font-weight: 700; margin: 0; }
    .report-meta { color: #666; font-size: 14px; margin-top: 8px; }
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin: 20px 0; }
    .summary-box { background: linear-gradient(135deg, #1e3c72, #2a5298); color: white; padding: 20px; border-radius: 8px; text-align: center; }
    .summary-value { font-size: 32px; font-weight: 700; margin: 10px 0; }
    .summary-label { font-size: 14px; opacity: 0.9; }
    .chart-container { position: relative; height: 400px; margin: 30px 0; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th { background-color: #f2f2f2; padding: 12px; text-align: left; font-weight: 600; border-bottom: 2px solid #ddd; }
    td { padding: 12px; border-bottom: 1px solid #eee; text-align: center; }
    td:first-child { text-align: left; }
    tr:hover { background-color: #f9f9f9; }
    .btn-container { margin-top: 25px; display: flex; gap: 10px; }
    .btn { padding: 10px 20px; border-radius: 6px; border: none; cursor: pointer; text-decoration: none; display: inline-block; }
    .btn-back { background: #95a5a6; color: white; }
    .btn-back:hover { background: #7f8c8d; }
    .btn-export { background: #27ae60; color: white; }
    .btn-export:hover { background: #229954; }
</style>

<div class="page-header">
    <h2>?? Completed vs Pending Processes</h2>
    <p>Track process status trends and completion progression</p>
</div>

<div class="report-container">
    <div class="report-header">
        <h1 class="report-title">Process Status Comparison Report</h1>
        <div class="report-meta">
            Generated by: @Model.GeneratedBy<br>
            Date: @Model.GeneratedAt.ToString("dddd, MMMM dd, yyyy HH:mm:ss")
        </div>
    </div>

    <!-- Summary Metrics -->
    <div class="summary-grid">
        <div class="summary-box">
            <div class="summary-label">Completed</div>
            <div class="summary-value">@Model.CompletedCount</div>
        </div>
        <div class="summary-box">
            <div class="summary-label">Pending</div>
            <div class="summary-value">@Model.PendingCount</div>
        </div>
        <div class="summary-box">
            <div class="summary-label">Approved</div>
            <div class="summary-value">@Model.ApprovedCount</div>
        </div>
        <div class="summary-box">
            <div class="summary-label">Completion Rate</div>
            <div class="summary-value">@Model.CompletionPercentage.ToString("F1")%</div>
        </div>
    </div>

    <!-- Status Distribution Pie Chart -->
    <h3 style="color: #1e3c72;">Overall Status Distribution</h3>
    <div class="chart-container">
        <canvas id="statusDistributionChart"></canvas>
    </div>

    <!-- Trend Line Chart -->
    <h3 style="color: #1e3c72; margin-top: 30px;">Monthly Trend</h3>
    <div class="chart-container">
        <canvas id="trendChart"></canvas>
    </div>

    <!-- Monthly Details Table -->
    <h3 style="color: #1e3c72; margin-top: 30px;">Monthly Breakdown</h3>
    @if (Model.MonthlyData.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>Month</th>
                    <th>Completed</th>
                    <th>Pending</th>
                    <th>Approved</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var month in Model.MonthlyData)
                {
                    var total = month.Completed + month.Pending + month.Approved;
                    <tr>
                        <td><strong>@month.Month</strong></td>
                        <td><span class="badge bg-success">@month.Completed</span></td>
                        <td><span class="badge bg-warning text-dark">@month.Pending</span></td>
                        <td><span class="badge bg-info">@month.Approved</span></td>
                        <td><strong>@total</strong></td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <p class="text-muted">No monthly data available</p>
    }

    <!-- Action Buttons -->
    <div class="btn-container">
        <a href="/Reporting/Dashboard" class="btn btn-back">? Back to Dashboard</a>
        <form method="post" action="/Reporting/ExportStatusComparison" style="display: inline;">
            <button type="submit" name="format" value="csv" class="btn btn-export">
                <i class="fas fa-download me-2"></i>Export as CSV
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Distribution Pie Chart
        fetch('/api/reports/status-distribution')
            .then(response => response.json())
            .then(data => {
                var ctx = document.getElementById('statusDistributionChart').getContext('2d');
                new Chart(ctx, {
                    type: 'doughnut',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom'
                            }
                        }
                    }
                });
            });

        // Trend Line Chart
        fetch('/api/reports/process-trends')
            .then(response => response.json())
            .then(data => {
                var ctx = document.getElementById('trendChart').getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            });
    </script>
}
