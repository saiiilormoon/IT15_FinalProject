@model CVM_FinalProject.Models.ViewModels.DepartmentActivitySummaryViewModel
@{
    ViewData["Title"] = "Department Activity Summary";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .report-container { background: white; border-radius: 12px; padding: 25px; box-shadow: 0 3px 15px rgba(0,0,0,0.05); }
    .report-header { border-bottom: 3px solid #2a5298; padding-bottom: 15px; margin-bottom: 25px; }
    .report-title { color: #1e3c72; font-size: 28px; font-weight: 700; margin: 0; }
    .report-meta { color: #666; font-size: 14px; margin-top: 8px; }
    .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px; margin: 20px 0; }
    .summary-box { background: linear-gradient(135deg, #1e3c72, #2a5298); color: white; padding: 20px; border-radius: 8px; text-align: center; }
    .summary-value { font-size: 32px; font-weight: 700; margin: 10px 0; }
    .summary-label { font-size: 14px; opacity: 0.9; }
    .chart-container { position: relative; height: 400px; margin: 30px 0; }
    table { width: 100%; border-collapse: collapse; margin-top: 20px; }
    th { background-color: #f2f2f2; padding: 12px; text-align: left; font-weight: 600; border-bottom: 2px solid #ddd; }
    td { padding: 12px; border-bottom: 1px solid #eee; }
    tr:hover { background-color: #f9f9f9; }
    .btn-container { margin-top: 25px; display: flex; gap: 10px; }
    .btn { padding: 10px 20px; border-radius: 6px; border: none; cursor: pointer; text-decoration: none; display: inline-block; }
    .btn-back { background: #95a5a6; color: white; }
    .btn-back:hover { background: #7f8c8d; }
    .btn-export { background: #27ae60; color: white; }
    .btn-export:hover { background: #229954; }
    .activity-bar { position: relative; height: 30px; background: #e0e0e0; border-radius: 4px; overflow: hidden; margin: 5px 0; }
    .activity-fill { height: 100%; background: linear-gradient(90deg, #2a5298, #1e3c72); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 12px; }
</style>

<div class="page-header">
    <h2>?? Department Activity Summary</h2>
    <p>Comprehensive departmental performance and activity metrics</p>
</div>

<div class="report-container">
    <div class="report-header">
        <h1 class="report-title">Department Activity Summary Report</h1>
        <div class="report-meta">
            Generated by: @Model.GeneratedBy<br>
            Date: @Model.GeneratedAt.ToString("dddd, MMMM dd, yyyy HH:mm:ss")
        </div>
    </div>

    <!-- Summary Metrics -->
    <div class="summary-grid">
        <div class="summary-box">
            <div class="summary-label">Total Departments</div>
            <div class="summary-value">@Model.TotalDepartments</div>
        </div>
        <div class="summary-box">
            <div class="summary-label">Total Employees</div>
            <div class="summary-value">@Model.TotalEmployees</div>
        </div>
        <div class="summary-box">
            <div class="summary-label">Total Processes</div>
            <div class="summary-value">@Model.TotalProcesses</div>
        </div>
    </div>

    <!-- Activity Chart -->
    <h3 style="color: #1e3c72;">Department Activity Index</h3>
    <div class="chart-container">
        <canvas id="activityChart"></canvas>
    </div>

    <!-- Detailed Department Table -->
    <h3 style="color: #1e3c72; margin-top: 30px;">Department Details</h3>
    <div style="overflow-x: auto;">
        <table>
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Employees</th>
                    <th>Processes</th>
                    <th>Completed</th>
                    <th>Pending</th>
                    <th>Budget Used</th>
                    <th>Activity Index</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model.Departments)
                {
                    var activityPercentage = Math.Min(dept.ActivityIndex, 100);
                    <tr>
                        <td><strong>@dept.DepartmentName</strong></td>
                        <td>@dept.EmployeeCount</td>
                        <td>@dept.ProcessCount</td>
                        <td><span class="badge bg-success">@dept.CompletedCount</span></td>
                        <td><span class="badge bg-warning text-dark">@dept.PendingCount</span></td>
                        <td>$@dept.BudgetUsed.ToString("F2")</td>
                        <td>
                            <div class="activity-bar">
                                <div class="activity-fill" style="width: @activityPercentage%;">
                                    @Math.Round(dept.ActivityIndex)
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Budget Analysis Section -->
    <h3 style="color: #1e3c72; margin-top: 30px;">Budget Analysis</h3>
    <div style="overflow-x: auto;">
        <table>
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Budget Allocated</th>
                    <th>Budget Used</th>
                    <th>Remaining</th>
                    <th>% Utilization</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model.Departments)
                {
                    var remaining = dept.BudgetAllocated - dept.BudgetUsed;
                    var utilization = dept.BudgetAllocated > 0 ? (dept.BudgetUsed / dept.BudgetAllocated * 100) : 0;
                    <tr>
                        <td><strong>@dept.DepartmentName</strong></td>
                        <td>$@dept.BudgetAllocated.ToString("F2")</td>
                        <td><span class="badge bg-info">$@dept.BudgetUsed.ToString("F2")</span></td>
                        <td>$@remaining.ToString("F2")</td>
                        <td>
                            <div class="progress" style="height: 24px;">
                                <div class="progress-bar" style="width: @utilization%; background: linear-gradient(90deg, #3498db, #2980b9);" role="progressbar">
                                    @utilization.ToString("F0")%
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Action Buttons -->
    <div class="btn-container">
        <a href="/Reporting/Dashboard" class="btn btn-back">? Back to Dashboard</a>
        <form method="post" action="/Reporting/ExportActivitySummary" style="display: inline;">
            <button type="submit" name="format" value="csv" class="btn btn-export">
                <i class="fas fa-download me-2"></i>Export as CSV
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        fetch('/api/reports/department-activity')
            .then(response => response.json())
            .then(data => {
                var ctx = document.getElementById('activityChart').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        indexAxis: 'y',
                        scales: {
                            x: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            });
    </script>
}
