@model CVM_FinalProject.Models.ViewModels.OperationalProcessesByDepartmentViewModel
@{
    ViewData["Title"] = "Operational Processes by Department";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .report-container {
        background: white;
        border-radius: 12px;
        padding: 25px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.05);
    }
    
    .report-header {
        border-bottom: 3px solid #2a5298;
        padding-bottom: 15px;
        margin-bottom: 25px;
    }
    
    .report-title {
        color: #1e3c72;
        font-size: 28px;
        font-weight: 700;
        margin: 0;
    }
    
    .report-meta {
        color: #666;
        font-size: 14px;
        margin-top: 8px;
    }
    
    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 15px;
        margin: 20px 0;
    }
    
    .summary-box {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
    }
    
    .summary-value {
        font-size: 32px;
        font-weight: 700;
        margin: 10px 0;
    }
    
    .summary-label {
        font-size: 14px;
        opacity: 0.9;
    }
    
    .chart-container {
        position: relative;
        height: 400px;
        margin: 30px 0;
    }
    
    .table-responsive {
        margin-top: 30px;
    }
    
    table {
        width: 100%;
        border-collapse: collapse;
    }
    
    th {
        background-color: #f2f2f2;
        padding: 12px;
        text-align: left;
        font-weight: 600;
        border-bottom: 2px solid #ddd;
    }
    
    td {
        padding: 12px;
        border-bottom: 1px solid #eee;
    }
    
    tr:hover {
        background-color: #f9f9f9;
    }
    
    .btn-container {
        margin-top: 25px;
        display: flex;
        gap: 10px;
    }
    
    .btn-back {
        background: #95a5a6;
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }
    
    .btn-back:hover {
        background: #7f8c8d;
    }
    
    .btn-export {
        background: #27ae60;
        color: white;
        padding: 10px 20px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
    }
    
    .btn-export:hover {
        background: #229954;
    }
</style>

<div class="page-header">
    <h2>?? Operational Processes by Department</h2>
    <p>Analyze process distribution and completion rates across departments</p>
</div>

<div class="report-container">
    <div class="report-header">
        <h1 class="report-title">Operational Processes by Department</h1>
        <div class="report-meta">
            Generated by: @Model.GeneratedBy<br>
            Date: @Model.GeneratedAt.ToString("dddd, MMMM dd, yyyy HH:mm:ss")
        </div>
    </div>

    <!-- Summary Metrics -->
    <div class="summary-grid">
        <div class="summary-box">
            <div class="summary-label">Total Processes</div>
            <div class="summary-value">@Model.TotalProcesses</div>
        </div>
        <div class="summary-box">
            <div class="summary-label">Completed</div>
            <div class="summary-value">@Model.CompletedProcesses</div>
        </div>
        <div class="summary-box">
            <div class="summary-label">Pending</div>
            <div class="summary-value">@Model.PendingProcesses</div>
        </div>
        <div class="summary-box">
            <div class="summary-label">Completion Rate</div>
            <div class="summary-value">@Model.CompletionRate.ToString("F1")%</div>
        </div>
    </div>

    <!-- Chart -->
    <div class="chart-container">
        <canvas id="processChart"></canvas>
    </div>

    <!-- Detailed Table -->
    <h3 style="color: #1e3c72; margin-top: 30px;">Department Details</h3>
    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>Department</th>
                    <th>Total</th>
                    <th>Completed</th>
                    <th>Pending</th>
                    <th>Approved</th>
                    <th>Completion %</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model.Departments)
                {
                    <tr>
                        <td><strong>@dept.DepartmentName</strong></td>
                        <td>@dept.TotalCount</td>
                        <td><span class="badge bg-success">@dept.CompletedCount</span></td>
                        <td><span class="badge bg-warning text-dark">@dept.PendingCount</span></td>
                        <td><span class="badge bg-info">@dept.ApprovedCount</span></td>
                        <td>
                            <div class="progress" style="height: 24px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: @dept.CompletionPercentage%;" aria-valuenow="@dept.CompletionPercentage" aria-valuemin="0" aria-valuemax="100">
                                    @dept.CompletionPercentage.ToString("F1")%
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Action Buttons -->
    <div class="btn-container">
        <a href="/Reporting/Dashboard" class="btn-back">? Back to Dashboard</a>
        <form method="post" action="/Reporting/ExportOperationalProcesses" style="display: inline;">
            <button type="submit" name="format" value="csv" class="btn-export">
                <i class="fas fa-download me-2"></i>Export as CSV
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        fetch('/api/reports/processes-by-department')
            .then(response => response.json())
            .then(data => {
                var ctx = document.getElementById('processChart').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                display: true,
                                position: 'top'
                            },
                            title: {
                                display: true,
                                text: 'Process Status by Department'
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                title: {
                                    display: true,
                                    text: 'Number of Processes'
                                }
                            }
                        }
                    }
                });
            });
    </script>
}
