@model CVM_FinalProject.Models.ViewModels.ReportDashboardViewModel
@{
    ViewData["Title"] = "Reporting Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<style>
    .report-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.05);
        margin-bottom: 25px;
    }
    
    .report-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
        flex-wrap: wrap;
        gap: 10px;
    }
    
    .report-title {
        color: #1e3c72;
        font-weight: 700;
        font-size: 1.3rem;
        margin: 0;
    }
    
    .metric-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin: 20px 0;
    }
    
    .metric-box {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
        color: white;
        padding: 20px;
        border-radius: 8px;
        text-align: center;
    }
    
    .metric-value {
        font-size: 32px;
        font-weight: 700;
        margin: 10px 0;
    }
    
    .metric-label {
        font-size: 14px;
        opacity: 0.9;
    }
    
    .chart-container {
        position: relative;
        height: 300px;
        margin: 20px 0;
    }
    
    .export-buttons {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }
    
    .btn-export {
        padding: 8px 16px;
        border-radius: 6px;
        border: none;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.3s ease;
    }
    
    .btn-export-csv {
        background: #27ae60;
        color: white;
    }
    
    .btn-export-csv:hover {
        background: #229954;
    }
    
    .btn-export-html {
        background: #3498db;
        color: white;
    }
    
    .btn-export-html:hover {
        background: #2980b9;
    }
    
    .btn-view {
        background: #2a5298;
        color: white;
    }
    
    .btn-view:hover {
        background: #1e3c72;
    }
</style>

<div class="page-header">
    <h2>?? Reporting Dashboard</h2>
    <p>Comprehensive analytics and insights for organizational performance management</p>
</div>

<!-- Overall Metrics -->
<div class="report-card">
    <h3 class="report-title">Overall Performance Metrics</h3>
    <div class="metric-grid">
        <div class="metric-box">
            <div class="metric-label">Total Processes</div>
            <div class="metric-value">@Model.TotalProcesses</div>
        </div>
        <div class="metric-box">
            <div class="metric-label">Completed</div>
            <div class="metric-value">@Model.CompletedProcesses</div>
        </div>
        <div class="metric-box">
            <div class="metric-label">Pending</div>
            <div class="metric-value">@Model.PendingProcesses</div>
        </div>
        <div class="metric-box">
            <div class="metric-label">Completion Rate</div>
            <div class="metric-value">@Model.OverallCompletionRate.ToString("F1")%</div>
        </div>
    </div>
</div>

<!-- Quick Actions -->
<div class="report-card">
    <h3 class="report-title">Generate Reports</h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 15px;">
        <a href="/Reporting/OperationalProcessesByDepartment" class="btn btn-view" style="padding: 12px; text-decoration: none; text-align: center; border-radius: 6px;">
            <i class="fas fa-chart-bar me-2"></i>Processes by Department
        </a>
        <a href="/Reporting/EmployeeTaskPerformance" class="btn btn-view" style="padding: 12px; text-decoration: none; text-align: center; border-radius: 6px;">
            <i class="fas fa-users me-2"></i>Employee Performance
        </a>
        <a href="/Reporting/ProcessStatusComparison" class="btn btn-view" style="padding: 12px; text-decoration: none; text-align: center; border-radius: 6px;">
            <i class="fas fa-exchange-alt me-2"></i>Status Comparison
        </a>
        <a href="/Reporting/DepartmentActivitySummary" class="btn btn-view" style="padding: 12px; text-decoration: none; text-align: center; border-radius: 6px;">
            <i class="fas fa-building me-2"></i>Department Activity
        </a>
    </div>
</div>

<!-- Status Distribution Chart -->
<div class="report-card">
    <div class="report-header">
        <h3 class="report-title">Process Status Distribution</h3>
    </div>
    <div class="chart-container">
        <canvas id="statusChart"></canvas>
    </div>
</div>

<!-- Processes by Department Chart -->
<div class="report-card">
    <div class="report-header">
        <h3 class="report-title">Operational Processes by Department</h3>
    </div>
    <div class="chart-container">
        <canvas id="departmentChart"></canvas>
    </div>
</div>

<!-- Department Activity Chart -->
<div class="report-card">
    <div class="report-header">
        <h3 class="report-title">Department Activity Index</h3>
    </div>
    <div class="chart-container">
        <canvas id="activityChart"></canvas>
    </div>
</div>

<!-- Department Summary Table -->
<div class="report-card">
    <div class="report-header">
        <h3 class="report-title">Department Summary</h3>
    </div>
    <div class="table-responsive">
        <table class="table table-hover">
            <thead style="background-color: #f2f2f2;">
                <tr>
                    <th>Department</th>
                    <th>Employees</th>
                    <th>Processes</th>
                    <th>Completed</th>
                    <th>Pending</th>
                    <th>Budget Used</th>
                    <th>Activity</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dept in Model.ActivitySummary.Departments)
                {
                    <tr>
                        <td><strong>@dept.DepartmentName</strong></td>
                        <td>@dept.EmployeeCount</td>
                        <td>@dept.ProcessCount</td>
                        <td><span class="badge bg-success">@dept.CompletedCount</span></td>
                        <td><span class="badge bg-warning text-dark">@dept.PendingCount</span></td>
                        <td>?@dept.BudgetUsed.ToString("F2")</td>
                        <td>
                            <div style="width: 100%; background: #e0e0e0; border-radius: 4px; overflow: hidden;">
                                <div style="width: @((int)(dept.ActivityIndex % 100))%; height: 20px; background: linear-gradient(90deg, #2a5298, #1e3c72); display: flex; align-items: center; justify-content: center; color: white; font-size: 12px; font-weight: bold;">
                                    @Math.Round(dept.ActivityIndex)%
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Export Section -->
<div class="report-card">
    <h3 class="report-title">Export Reports</h3>
    <p class="text-muted">Download reports in various formats for analysis and presentation</p>
    <div class="export-buttons">
        <form method="post" action="/Reporting/ExportOperationalProcesses" style="display: inline;">
            <button type="submit" name="format" value="csv" class="btn btn-export btn-export-csv">
                <i class="fas fa-download me-1"></i>Export Processes (CSV)
            </button>
        </form>
        <form method="post" action="/Reporting/ExportEmployeePerformance" style="display: inline;">
            <button type="submit" name="format" value="csv" class="btn btn-export btn-export-csv">
                <i class="fas fa-download me-1"></i>Export Performance (CSV)
            </button>
        </form>
        <form method="post" action="/Reporting/ExportStatusComparison" style="display: inline;">
            <button type="submit" name="format" value="csv" class="btn btn-export btn-export-csv">
                <i class="fas fa-download me-1"></i>Export Status (CSV)
            </button>
        </form>
        <form method="post" action="/Reporting/ExportActivitySummary" style="display: inline;">
            <button type="submit" name="format" value="csv" class="btn btn-export btn-export-csv">
                <i class="fas fa-download me-1"></i>Export Activity (CSV)
            </button>
        </form>
        <form method="post" action="/Reporting/ExportAllReportsAsHtml" style="display: inline;">
            <button type="submit" class="btn btn-export btn-export-html">
                <i class="fas fa-file-pdf me-1"></i>Export All (HTML/Print)
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Status Distribution Pie Chart
        fetch('/api/reports/status-distribution')
            .then(response => response.json())
            .then(data => {
                var ctx = document.getElementById('statusChart').getContext('2d');
                new Chart(ctx, {
                    type: 'doughnut',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom'
                            }
                        }
                    }
                });
            });

        // Processes by Department Bar Chart
        fetch('/api/reports/processes-by-department')
            .then(response => response.json())
            .then(data => {
                var ctx = document.getElementById('departmentChart').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            });

        // Department Activity Bar Chart
        fetch('/api/reports/department-activity')
            .then(response => response.json())
            .then(data => {
                var ctx = document.getElementById('activityChart').getContext('2d');
                new Chart(ctx, {
                    type: 'bar',
                    data: data,
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true
                            }
                        }
                    }
                });
            });
    </script>
}
