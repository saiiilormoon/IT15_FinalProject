@{
    ViewData["Title"] = "Pending Approval";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Account Pending Approval - CVM MIS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            min-height: 100vh;
        }
        .pending-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            border: none;
            max-width: 500px;
        }
        .pending-icon {
            width: 100px;
            height: 100px;
            background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 25px;
            color: white;
            font-size: 45px;
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(243, 156, 18, 0.4); }
            50% { box-shadow: 0 0 0 20px rgba(243, 156, 18, 0); }
        }
        .btn-primary-custom {
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            border: none;
            border-radius: 10px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
            color: white;
        }
        .btn-primary-custom:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(30,60,114,0.3);
            color: white;
        }
        .info-box {
            background: linear-gradient(135deg, rgba(241,196,15,0.1), rgba(230,126,34,0.1));
            border: 1px solid rgba(241,196,15,0.3);
            border-radius: 12px;
            padding: 20px;
        }
    </style>
</head>
<body>

    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh; padding: 40px 0;">
        <div class="card pending-card p-4 p-md-5 text-center">
            
            <img src="~/images/logo.png" alt="CVM MIS Logo" height="60" class="mb-3 mx-auto" onerror="this.style.display='none'" />
            
            <div class="pending-icon">
                <i class="fas fa-hourglass-half"></i>
            </div>
            
            <h2 class="fw-bold mb-2" style="color: #1e3c72;">Hello, @ViewBag.UserName!</h2>
            <h5 class="text-muted mb-4">Your Account is Pending Approval</h5>

            <div class="info-box text-start mb-4">
                <p class="mb-3" style="color: #856404;">
                    <i class="fas fa-info-circle me-2"></i>
                    <strong>What does this mean?</strong>
                </p>
                <ul class="mb-0 text-muted" style="padding-left: 20px;">
                    <li class="mb-2">Your registration has been received successfully</li>
                    <li class="mb-2">An administrator needs to approve your account</li>
                    <li class="mb-2">You will be able to access the system once approved</li>
                    <li>This usually takes 1-2 business days</li>
                </ul>
            </div>

            <div class="alert alert-info mb-4" style="border-radius: 10px;">
                <i class="fas fa-envelope me-2"></i>
                Registered email: <strong>@ViewBag.UserEmail</strong>
            </div>

            <p class="text-muted small mb-4">
                If you believe this is taking too long, please contact your system administrator.
            </p>

            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <form asp-area="Identity" asp-page="/Account/Logout" method="post">
                    <button type="submit" class="btn btn-primary-custom">
                        <i class="fas fa-sign-out-alt me-2"></i>Logout
                    </button>
                </form>
                <a href="/" class="btn btn-outline-secondary" style="border-radius: 10px; padding: 12px 30px;">
                    <i class="fas fa-home me-2"></i>Back to Home
                </a>
            </div>

            <div class="mt-4 pt-4" style="border-top: 1px solid #eee;">
                <small class="text-muted">
                    <i class="fas fa-shield-alt me-1"></i>
                    CVM Centralized Organizational Management Information System
                </small>
            </div>

        </div>
    </div>

</body>
</html>
