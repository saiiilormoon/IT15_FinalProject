@model List<CVM_FinalProject.Models.ViewModels.SystemLogViewModel>
@{
    ViewData["Title"] = "System Logs";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2>System Logs</h2>
            <p>View system activity and audit trail.</p>
        </div>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <select class="form-select form-select-sm" style="width: auto;" id="logLevelFilter" onchange="filterLogs()">
                <option value="">All Levels</option>
                <option value="Info">Info</option>
                <option value="Warning">Warning</option>
                <option value="Error">Error</option>
            </select>
            <button class="btn btn-outline-primary" onclick="exportLogs()">
                <i class="fas fa-download me-1"></i>Export
            </button>
        </div>
    </div>
</div>

<!-- Log Statistics -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-primary">
                <i class="fas fa-list"></i>
            </div>
            <h3>@Model.Count</h3>
            <p>Total Logs</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-info">
                <i class="fas fa-info-circle"></i>
            </div>
            <h3>@Model.Count(l => l.LogLevel == "Info")</h3>
            <p>Info Events</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon bg-warning">
                <i class="fas fa-exclamation-triangle"></i>
            </div>
            <h3>@Model.Count(l => l.LogLevel == "Warning")</h3>
            <p>Warnings</p>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card">
            <div class="stat-icon" style="background: linear-gradient(135deg, #e74c3c, #c0392b);">
                <i class="fas fa-times-circle"></i>
            </div>
            <h3>@Model.Count(l => l.LogLevel == "Error")</h3>
            <p>Errors</p>
        </div>
    </div>
</div>

<!-- Logs Table -->
<div class="data-table">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap">
        <h5 class="mb-0">Activity Log</h5>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <input type="text" class="form-control form-control-sm" placeholder="Search logs..." id="searchInput" style="width: 200px;" onkeyup="searchLogs()">
            <input type="date" class="form-control form-control-sm" style="width: auto;" id="dateFilter" onchange="filterLogs()">
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0" id="logsTable">
            <thead>
                <tr>
                    <th style="width: 50px;">Level</th>
                    <th>Action</th>
                    <th>User</th>
                    <th>Details</th>
                    <th>IP Address</th>
                    <th>Timestamp</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.OrderByDescending(l => l.Timestamp))
                {
                    var levelClass = log.LogLevel switch
                    {
                        "Info" => "bg-info",
                        "Warning" => "bg-warning text-dark",
                        "Error" => "bg-danger",
                        _ => "bg-secondary"
                    };
                    var levelIcon = log.LogLevel switch
                    {
                        "Info" => "fa-info-circle",
                        "Warning" => "fa-exclamation-triangle",
                        "Error" => "fa-times-circle",
                        _ => "fa-circle"
                    };
                    <tr data-level="@log.LogLevel">
                        <td>
                            <span class="badge @levelClass">
                                <i class="fas @levelIcon"></i>
                            </span>
                        </td>
                        <td><strong>@log.Action</strong></td>
                        <td>@log.UserName</td>
                        <td><small class="text-muted">@log.Details</small></td>
                        <td><code>@log.IpAddress</code></td>
                        <td>
                            <small>@log.Timestamp.ToString("MMM dd, yyyy")</small><br>
                            <small class="text-muted">@log.Timestamp.ToString("hh:mm tt")</small>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-end mb-0">
            <li class="page-item disabled"><a class="page-link" href="#">Previous</a></li>
            <li class="page-item active"><a class="page-link" href="#">1</a></li>
            <li class="page-item"><a class="page-link" href="#">2</a></li>
            <li class="page-item"><a class="page-link" href="#">3</a></li>
            <li class="page-item"><a class="page-link" href="#">Next</a></li>
        </ul>
    </nav>
</div>

<!-- Log Details Modal -->
<div class="modal fade" id="logDetailModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-info-circle me-2 text-primary"></i>Log Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="logDetailContent">
                    <!-- Content will be loaded dynamically -->
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function searchLogs() {
        var input = document.getElementById('searchInput').value.toLowerCase();
        var rows = document.querySelectorAll('#logsTable tbody tr');
        
        rows.forEach(function(row) {
            var text = row.textContent.toLowerCase();
            row.style.display = text.includes(input) ? '' : 'none';
        });
    }

    function filterLogs() {
        var level = document.getElementById('logLevelFilter').value;
        var rows = document.querySelectorAll('#logsTable tbody tr');
        
        rows.forEach(function(row) {
            var rowLevel = row.getAttribute('data-level');
            row.style.display = (!level || rowLevel === level) ? '' : 'none';
        });
    }

    function exportLogs() {
        alert('Exporting logs to CSV...\n\nDownload will start shortly.');
    }
</script>
}
