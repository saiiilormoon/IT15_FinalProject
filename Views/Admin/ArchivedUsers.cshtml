@model List<CVM_FinalProject.Models.ViewModels.UserManagementViewModel>
@{
    ViewData["Title"] = "Archived Users";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="page-header">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <div>
            <h2><i class="fas fa-archive me-2 text-secondary"></i>Archived Users</h2>
            <p>View and restore deactivated user accounts.</p>
        </div>
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <a asp-action="Users" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left me-1"></i>Back to Users
            </a>
        </div>
    </div>
</div>

<!-- Alert Messages -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (Model.Count == 0)
{
    <!-- Empty State -->
    <div class="chart-card text-center py-5">
        <div style="font-size: 4rem; color: #27ae60; margin-bottom: 20px;">
            <i class="fas fa-check-circle"></i>
        </div>
        <h4 class="mb-2">No Archived Users</h4>
        <p class="text-muted mb-4">There are no deactivated user accounts at this time.</p>
        <a asp-action="Users" class="btn btn-primary">
            <i class="fas fa-users me-1"></i>View Active Users
        </a>
    </div>
}
else
{
    <!-- Archived Count -->
    <div class="alert alert-secondary mb-4">
        <i class="fas fa-archive me-2"></i>
        <strong>@Model.Count user(s)</strong> currently archived (deactivated)
    </div>

    <!-- Archived Users Table -->
    <div class="data-table">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Original Status</th>
                        <th>Archived On</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roleClass = user.Role switch
                        {
                            "SuperAdmin" => "bg-danger",
                            "Admin" => "bg-primary",
                            "Accountant" => "bg-success",
                            "HR" => "bg-info",
                            "Employee" => "bg-secondary",
                            "Auditor" => "bg-warning text-dark",
                            _ => "bg-secondary"
                        };
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="user-avatar me-2" style="width: 35px; height: 35px; font-size: 0.85rem; opacity: 0.6;">
                                        @(string.IsNullOrEmpty(user.FirstName) ? "U" : user.FirstName[0].ToString().ToUpper())
                                    </div>
                                    <div>
                                        <strong class="text-muted">@user.FullName</strong>
                                    </div>
                                </div>
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td><span class="badge @roleClass" style="opacity: 0.7;">@user.Role</span></td>
                            <td>
                                @if (user.IsApproved)
                                {
                                    <span class="text-muted"><i class="fas fa-check me-1"></i>Was Active</span>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="fas fa-clock me-1"></i>Was Pending</span>
                                }
                            </td>
                            <td>
                                @if (user.ArchivedAt.HasValue)
                                {
                                    <small>@user.ArchivedAt.Value.ToString("MMM dd, yyyy")</small>
                                    <br>
                                    <small class="text-muted">@user.ArchivedAt.Value.ToString("hh:mm tt")</small>
                                }
                            </td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <form asp-action="RestoreUser" method="post" style="display: inline;" onsubmit="return confirm('Are you sure you want to restore this user? They will be able to login again.');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-success" title="Restore User">
                                            <i class="fas fa-undo me-1"></i>Restore
                                        </button>
                                    </form>
                                    <form asp-action="PermanentDeleteUser" method="post" style="display: inline;" onsubmit="return confirm('?? WARNING: This will PERMANENTLY delete this user and cannot be undone!\n\nAre you absolutely sure?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@user.Id" />
                                        <button type="submit" class="btn btn-danger" title="Permanently Delete">
                                            <i class="fas fa-trash-alt me-1"></i>Delete Forever
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<style>
    .user-avatar {
        background: linear-gradient(135deg, #6c757d, #adb5bd);
    }
</style>
